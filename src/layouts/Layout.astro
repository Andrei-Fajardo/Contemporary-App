---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
export interface Props {
  title: string;
}
const { title } = Astro.props;

const langList = [
  { code: 'en', label: 'EN', href: '/' },
  { code: 'kr', label: 'KR', href: '/kr' },
  { code: 'kk', label: 'KK', href: '/kk' },
  { code: 'zh', label: '简', href: '/zh' },
  { code: 'ru', label: 'RU', href: '/ru' },
];

const currentLang = Astro.url.pathname.split('/')[1] || 'en';
---

<!doctype html>
<html lang="en" style="color-scheme: light only; background-color: #141414;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="light only" />
    <meta name="supported-color-schemes" content="light" />
    <meta name="theme-color" content="#141414" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <style is:inline>
      html, body { background-color: #141414 !important; color: #F0EEE9 !important; color-scheme: dark; }
    </style>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Anna Dauyl Rockswell</title>
    <ClientRouter />
  </head>
  <body class="font-body text-neutral-800 antialiased bg-[#141414]">
    <!-- Film Grain Overlay -->
    <div class="grain-overlay" />

    <!-- 5-Language Toggle — with active state detection -->
    <div id="lang-toggle" class="fixed top-6 right-6 z-50 flex items-stretch border border-black/20 font-mono text-[10px] font-bold bg-white/60 backdrop-blur-md rounded overflow-hidden">
      {langList.map(({ code, label, href }) => (
        <a
          href={href}
          class={`lang-btn px-2.5 py-1.5 block transition-colors duration-150 ${
            currentLang === code ? 'bg-[#F0EEE9] text-white' : 'text-[#555] hover:bg-[#F0EEE9] hover:text-white'
          }`}
          data-lang={code}
        >
          {label}
        </a>
      ))}
    </div>

    <slot />
  </body>
</html>

<script>
  function syncLangToggle() {
    const path = window.location.pathname;
    const seg = path.split("/")[1];
    const codes = ["en", "kr", "kk", "zh", "ru"];
    const active = seg && codes.includes(seg) ? seg : "en";

    document.querySelectorAll("#lang-toggle .lang-btn").forEach((btn) => {
      const lang = btn.getAttribute("data-lang");
      const isMatch = lang === active;
      btn.classList.toggle("bg-[#F0EEE9]", isMatch);
      btn.classList.toggle("text-white", isMatch);
      if (!isMatch) {
        btn.classList.remove("bg-[#F0EEE9]", "bg-[#111]", "text-white");
      }
    });
  }

  function boot() {
    syncLangToggle();
  }

  document.addEventListener("astro:page-load", boot);
  document.addEventListener("astro:after-swap", boot);
  document.addEventListener("DOMContentLoaded", boot);

  if (document.readyState !== "loading") {
    boot();
  }
</script>
