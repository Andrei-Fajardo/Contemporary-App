---
import '../styles/global.css';
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Anna Dauyl Rockswell</title>
  </head>
  <body class="font-sans text-neutral-800 antialiased bg-[#E3E2DA]">
    <!-- Film Grain Overlay -->
    <div class="grain-overlay" />

    <!-- Trilingual Language Toggle -->
    <div class="fixed top-6 right-6 z-50 flex items-center gap-0 border border-neutral-900 font-mono text-[11px] font-bold divide-x divide-neutral-900 bg-white/10 backdrop-blur-md">
      <a href="/" class="px-3 py-1.5 block hover:bg-neutral-900 hover:text-white transition-colors text-neutral-900">EN</a>
      <a href="/kr" class="px-3 py-1.5 block hover:bg-neutral-900 hover:text-white transition-colors text-neutral-500">KR</a>
      <a href="/kk" class="px-3 py-1.5 block hover:bg-neutral-900 hover:text-white transition-colors text-neutral-500">KK</a>
    </div>

    <slot />
  </body>
</html>
