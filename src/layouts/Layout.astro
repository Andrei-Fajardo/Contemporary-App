---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
export interface Props {
  title: string;
}
const { title } = Astro.props;

const langList = [
  { code: 'en', label: 'EN', href: '/' },
  { code: 'kr', label: 'KR', href: '/kr' },
  { code: 'kk', label: 'KK', href: '/kk' },
  { code: 'zh', label: '简', href: '/zh' },
  { code: 'ru', label: 'RU', href: '/ru' },
];

const currentLang = Astro.url.pathname.split('/')[1] || 'en';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Anna Dauyl Rockswell</title>
    <ClientRouter />
  </head>
  <body class="font-sans text-neutral-800 antialiased bg-[#F0EEE9]">
    <!-- Film Grain Overlay -->
    <div class="grain-overlay" />

    <!-- 5-Language Toggle — with active state detection -->
    <div id="lang-toggle" class="fixed top-6 right-6 z-50 flex items-stretch border border-black/20 font-mono text-[10px] font-bold bg-white/60 backdrop-blur-md rounded overflow-hidden">
      {langList.map(({ code, label, href }) => (
        <a
          href={href}
          class={`lang-btn px-2.5 py-1.5 block transition-colors duration-150 ${
            currentLang === code ? 'bg-[#111111] text-white' : 'text-[#555] hover:bg-[#111111] hover:text-white'
          }`}
          data-lang={code}
        >
          {label}
        </a>
      ))}
    </div>

    <slot />
  </body>
</html>

<script>
  document.addEventListener("astro:page-load", () => {
    const path = window.location.pathname;
    const seg = path.split('/')[1];
    const codes = ['en', 'kr', 'kk', 'zh', 'ru'];
    const active = seg && codes.includes(seg) ? seg : 'en';

    document.querySelectorAll("#lang-toggle .lang-btn").forEach((btn) => {
      const lang = btn.getAttribute("data-lang");
      const isMatch = lang === active;
      btn.classList.toggle("bg-[#111111]", isMatch);
      btn.classList.toggle("text-white", isMatch);
      if (!isMatch) {
        btn.classList.remove("bg-[#111111]", "bg-[#111]", "text-white");
      }
    });
  });
</script>
