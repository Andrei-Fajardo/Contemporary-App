---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SiteFooter from '../components/SiteFooter.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { t, langLabels, type LocaleKey, type Lang } from '../data/translations';

export interface Props {
  title: string;
  activeSection?: string;
  locale?: LocaleKey;
}

const { title, activeSection = '', locale = 'en' } = Astro.props;
const l = t[locale];
const langList: Lang[] = ['en', 'kr', 'kk', 'zh', 'ru'];

// Derive active language from URL pathname — reliable across all routes and ClientRouter
const pathSeg = Astro.url.pathname.split('/')[1];
const activeLang = pathSeg && langList.includes(pathSeg as Lang) ? (pathSeg as Lang) : 'en';

function isActiveLang(lang: string): boolean {
  if (lang === 'en') return activeLang === 'en';
  return activeLang === lang;
}

const homePath = locale === 'en' ? '/' : `/${locale}`;

const menuItems: { key: string; href: string }[] = [
  { key: "about", href: `${homePath}#about` },
  { key: "art", href: `${homePath}#art` },
  { key: "exhibitions", href: `${homePath}#exhibitions` },
  { key: "publications", href: `${homePath}#publications` },
  { key: "research", href: `${homePath}#research` },
  { key: "press", href: `${homePath}#press` },
  { key: "contacts", href: `${homePath}#contacts` },
];
---

<!doctype html>
<html lang={l.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#141414" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('site-theme');
          document.documentElement.setAttribute('data-theme', theme === 'light' ? 'light' : 'dark');
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — {l.siteTitle}</title>
    <!-- tabular-v1: sidebar tabs, instant panel swap -->
    <ClientRouter />
    <script is:inline>
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        document.documentElement.classList.add("motion-live");
      })();
    </script>
  </head>
  <body class="font-body antialiased bg-[var(--canvas)] text-[var(--ink)]" data-layout="tabular">
    <!-- Film grain overlay -->
    <div class="grain-overlay" />

    <!-- Language switch transition (persists across ClientRouter swaps) -->
    <div id="lang-transition-overlay" class="lang-transition-overlay" transition:persist="lang-overlay" aria-hidden="true" aria-live="polite">
      <div class="lang-transition-overlay__panel">
        <span class="lang-transition-overlay__eyebrow font-mono text-[10px] tracking-[0.35em] uppercase text-[var(--ink-muted)]/70">Language</span>
        <p class="lang-transition-overlay__code type-subheading text-6xl md:text-7xl text-[var(--ink)] leading-none" data-lang-code>EN</p>
        <p class="lang-transition-overlay__name type-body text-xl md:text-2xl text-[var(--ink-muted)] mt-3" data-lang-name>English</p>
        <div class="lang-transition-overlay__bar" aria-hidden="true">
          <span class="lang-transition-overlay__bar-fill"></span>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var LANG = {
          en: { code: "EN", name: "English" },
          kr: { code: "KR", name: "한국어" },
          kk: { code: "KK", name: "Қазақша" },
          zh: { code: "简", name: "中文" },
          ru: { code: "RU", name: "Русский" },
        };
        var switching = false;

        function currentLang() {
          var seg = location.pathname.split("/")[1];
          var langs = ["kr", "kk", "zh", "ru"];
          return langs.indexOf(seg) >= 0 ? seg : "en";
        }

        function showOverlay(lang) {
          var overlay = document.getElementById("lang-transition-overlay");
          var display = LANG[lang] || { code: lang.toUpperCase(), name: lang };
          var codeEl = overlay && overlay.querySelector("[data-lang-code]");
          var nameEl = overlay && overlay.querySelector("[data-lang-name]");
          var barFill = overlay && overlay.querySelector(".lang-transition-overlay__bar-fill");
          if (codeEl) codeEl.textContent = display.code;
          if (nameEl) nameEl.textContent = display.name;
          if (barFill) {
            barFill.style.animation = "none";
            void barFill.offsetWidth;
            barFill.style.animation = "";
          }
          if (overlay) {
            overlay.classList.add("is-active");
            overlay.setAttribute("aria-hidden", "false");
          }
          document.documentElement.classList.add("lang-switching");
          document.body.classList.add("lang-switching");
        }

        window.__showLangOverlay = showOverlay;

        document.addEventListener(
          "click",
          function (e) {
            var btn = e.target && e.target.closest ? e.target.closest(".lang-btn") : null;
            if (!btn) return;
            var lang = btn.getAttribute("data-lang");
            if (!lang || lang === currentLang()) {
              e.preventDefault();
              return;
            }
            if (switching) {
              e.preventDefault();
              return;
            }

            e.preventDefault();
            e.stopImmediatePropagation();
            switching = true;

            var href = lang === "en" ? "/" : "/" + lang;
            sessionStorage.setItem("lang-preserve-tab", location.hash.replace("#", "") || "about");
            sessionStorage.setItem("lang-switching", "1");
            showOverlay(lang);

            setTimeout(function () {
              window.location.assign(href);
            }, 1500);
          },
          true
        );
      })();
    </script>

    <!-- Mobile header bar (<1024px) -->
    <header class="lg:hidden fixed top-0 left-0 right-0 z-50 h-14 bg-[var(--canvas)] border-b border-[var(--border-sidebar)] flex items-center justify-between px-4">
      <a href={`${homePath}#about`} class="type-subheading text-xl md:text-2xl whitespace-nowrap text-[var(--ink)] hover:opacity-70 transition-opacity text-left" data-nav-key="about">
        Anna Dauyl Rockswell
      </a>
      <button
          id="hamburger-btn"
          class="w-11 h-11 flex items-center justify-center focus:outline-none active:scale-95 transition-transform"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6 text-[var(--ink)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path class="ham-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path class="ham-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
    </header>

    <!-- Mobile drawer backdrop -->
    <div id="drawer-backdrop" class="lg:hidden fixed inset-0 z-40 bg-black/0 pointer-events-none transition-all duration-[400ms] ease-out" />

    <!-- Mobile slide-out drawer (<1024px) -->
    <aside
      id="mobile-drawer"
      class="lg:hidden fixed top-0 right-0 bottom-0 w-[85vw] max-w-[320px] z-50 bg-[var(--canvas)] border-l border-[var(--border-sidebar)] translate-x-full transition-transform duration-[400ms] ease-out flex flex-col overflow-y-auto"
    >
      <nav class="flex-1 pt-20 px-6 overflow-y-auto">
        <ul class="space-y-0">
          {menuItems.map((item) => {
            const navKey = item.key as keyof typeof l.nav;
            return (
              <li>
                <a
                  href={item.href}
                  data-nav-key={item.key}
                  id={`nav-${item.key}-mobile`}
                  aria-current={item.key === "about" ? "true" : "false"}
                  class="sidebar-nav-link block type-subheading text-base rounded-md transition-all duration-300 text-[var(--ink-muted)] hover:text-[var(--ink)] whitespace-nowrap overflow-hidden text-ellipsis"
                >
                  <span class="sidebar-nav-label">{l.nav[navKey]}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
      <div class="mobile-drawer__footer px-5 py-5 border-t border-[var(--border-sidebar)] mt-auto">
        <div class="mobile-drawer__theme">
          <span class="font-sans text-[11px] uppercase tracking-[0.25em] text-[var(--ink-muted)] block mb-3">Theme</span>
          <ThemeToggle />
        </div>
        <span class="font-sans text-[11px] uppercase tracking-[0.25em] text-[var(--ink-muted)] block mb-2 mt-5">{l.basedIn}</span>
        <span class="font-sans text-xs text-[var(--ink-muted)] font-medium tracking-wide block mb-5">{l.location}</span>
        <span class="font-sans text-[11px] uppercase tracking-[0.25em] text-[var(--ink-muted)] block mb-2">Language</span>
        <div id="lang-toggle-mobile" class="lang-toggle lang-toggle--drawer">
          {langList.map((lang) => (
            <button
              type="button"
              class:list={["lang-btn", isActiveLang(lang) && "lang-btn--active"]}
              data-lang={lang}
              aria-pressed={isActiveLang(lang) ? 'true' : 'false'}
              aria-label={`Switch to ${langLabels[lang]}`}
            >
              <span class="lang-btn__label">{langLabels[lang]}</span>
            </button>
          ))}
        </div>
      </div>
    </aside>

    <!-- Desktop sidebar — always visible -->
    <aside class="desktop-sidebar magazine-sidebar hidden lg:flex" aria-label="Site navigation">
      <div class="desktop-sidebar__inner flex flex-col h-full">
        <div class="desktop-sidebar__brand p-6 pb-4">
          <a href={`${homePath}#about`} class="block group" data-nav-key="about">
            <h1 class="desktop-sidebar__title type-subheading text-2xl text-[var(--ink)] leading-[1.05] transition-opacity duration-300 group-hover:opacity-70">
              Anna Dauyl Rockswell
            </h1>
            <span class="desktop-sidebar__subtitle type-heading text-[12px] text-[var(--ink-muted)]/70 mt-2 block" set:html={l.subtitle} />
          </a>
        </div>
        <div class="desktop-sidebar__nav px-6 flex-1">
          <nav class="sidebar-nav">
            {menuItems.map((item) => {
              const navKey = item.key as keyof typeof l.nav;
              return (
                <a
                  href={item.href}
                  data-nav-key={item.key}
                  id={`nav-${item.key}`}
                  aria-current={item.key === "about" ? "true" : "false"}
                  class="sidebar-nav-link group relative type-subheading text-[17px] block rounded-lg transition-all duration-300 text-[var(--ink-muted)]/80 hover:text-[var(--ink)]"
                >
                  <span class="sidebar-nav-label whitespace-nowrap">{l.nav[navKey]}</span>
                </a>
              );
            })}
          </nav>
        </div>
        <div class="desktop-sidebar__theme">
          <span class="desktop-sidebar__footer-label font-sans text-[11px] uppercase tracking-[0.25em] text-[var(--ink-muted)]/50 block mb-3">Theme</span>
          <ThemeToggle />
        </div>
        <div class="desktop-sidebar__footer px-5 py-8 mt-auto">
          <span class="desktop-sidebar__footer-label font-sans text-[11px] uppercase tracking-[0.25em] text-[var(--ink-muted)]/50 block mb-1">{l.basedIn}</span>
          <span class="desktop-sidebar__footer-text font-sans text-[14px] text-[var(--ink-muted)]/80 font-medium tracking-wide">{l.location}</span>
        </div>
      </div>
    </aside>

    <div class="site-shell min-h-screen">
      <header class="site-topbar hidden lg:flex">
        <a href={`${homePath}#about`} class="site-topbar__logo type-subheading text-lg text-[var(--ink)]" aria-label="Anna Dauyl Rockswell" data-nav-key="about">A·R</a>
        <div id="lang-toggle-desktop" class="lang-toggle lang-toggle--desktop site-topbar__langs">
          {langList.map((lang) => (
            <button
              type="button"
              class:list={["lang-btn", isActiveLang(lang) && "lang-btn--active"]}
              data-lang={lang}
              aria-pressed={isActiveLang(lang) ? 'true' : 'false'}
              aria-label={`Switch to ${langLabels[lang]}`}
            >
              <span class="lang-btn__label">{langLabels[lang]}</span>
            </button>
          ))}
        </div>
      </header>
      <div class="site-main-column min-w-0 pt-14 lg:pt-8 lg:pl-[15rem]">
        <main class="tabular-main motion-main">
          <slot name="content" />
        </main>
        <SiteFooter locale={locale} />
      </div>
    </div>
  </body>
</html>

<script>
  import { initMotion } from "../scripts/motion/init";
  import { initLangSwitch, syncLangHrefs, syncLangToggle, restoreLangScroll } from "../scripts/lang-switch";
  import { initTabView, resetTabView } from "../scripts/tab-view";
  import { resetGlobalLightbox } from "../scripts/lightbox";
  import { initArtworkParallax } from "../scripts/artwork-parallax";
  import { initThemeToggle } from "../scripts/theme";

  function initDrawer() {
    const hamburgerBtn = document.getElementById("hamburger-btn");
    const drawer = document.getElementById("mobile-drawer");
    const backdrop = document.getElementById("drawer-backdrop");
    if (!hamburgerBtn || !drawer || hamburgerBtn.dataset.drawerBound === "true") return;
    hamburgerBtn.dataset.drawerBound = "true";
    const hamOpen = hamburgerBtn.querySelector(".ham-open");
    const hamClose = hamburgerBtn.querySelector(".ham-close");
    let isOpen = false;

    const toggleDrawer = (forceClose = false) => {
      if (forceClose && !isOpen) return;
      isOpen = forceClose ? false : !isOpen;

      if (isOpen) {
        drawer?.classList.remove("translate-x-full");
        drawer?.classList.add("translate-x-0");
        backdrop?.classList.remove("bg-black/0", "pointer-events-none");
        backdrop?.classList.add("bg-black/60", "pointer-events-auto");
        hamOpen?.classList.add("hidden");
        hamClose?.classList.remove("hidden");
        hamburgerBtn?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
      } else {
        drawer?.classList.remove("translate-x-0");
        drawer?.classList.add("translate-x-full");
        backdrop?.classList.remove("bg-black/60", "pointer-events-auto");
        backdrop?.classList.add("bg-black/0", "pointer-events-none");
        hamOpen?.classList.remove("hidden");
        hamClose?.classList.add("hidden");
        hamburgerBtn?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      }
    };

    // Close drawer on navigation link click
    const navLinks = drawer?.querySelectorAll("a");
    navLinks?.forEach(link => {
      link.addEventListener("click", () => {
        setTimeout(() => toggleDrawer(true), 150);
      });
    });

    hamburgerBtn?.addEventListener("click", () => toggleDrawer());
    backdrop?.addEventListener("click", () => toggleDrawer());
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) toggleDrawer();
    });
  }

  function bootPageScripts() {
    document.documentElement.classList.add("motion-live");
    initDrawer();
    syncLangHrefs();
    syncLangToggle();
    initLangSwitch();
    initTabView();
    initMotion();
    initArtworkParallax();
    initThemeToggle();
    restoreLangScroll();
  }

  document.addEventListener("astro:after-swap", () => {
    document.querySelectorAll("[data-drawer-bound]").forEach((el) => {
      delete (el as HTMLElement).dataset.drawerBound;
    });
    document.querySelectorAll("[data-carousel-bound]").forEach((el) => {
      delete (el as HTMLElement).dataset.carouselBound;
    });
    document.querySelectorAll("[data-accordion-motion]").forEach((el) => {
      delete (el as HTMLElement).dataset.accordionMotion;
    });
    document.querySelectorAll("[data-nav-hover]").forEach((el) => {
      delete (el as HTMLElement).dataset.navHover;
    });
    document.querySelectorAll("[data-tab-bound]").forEach((el) => {
      delete (el as HTMLElement).dataset.tabBound;
    });
    document.querySelectorAll("[data-theme-bound]").forEach((el) => {
      delete (el as HTMLElement).dataset.themeBound;
    });
    resetGlobalLightbox();
    resetTabView();
    bootPageScripts();
  });

  document.addEventListener("DOMContentLoaded", bootPageScripts);

  document.addEventListener("astro:page-load", bootPageScripts);

  if (document.readyState !== "loading") {
    bootPageScripts();
  }
</script>
