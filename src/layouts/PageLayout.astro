---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SiteFooter from '../components/SiteFooter.astro';
import { t, langLabels, type LocaleKey, type Lang } from '../data/translations';

export interface Props {
  title: string;
  activeSection?: string;
  locale?: LocaleKey;
}

const { title, activeSection = '', locale = 'en' } = Astro.props;
const l = t[locale];
const langList: Lang[] = ['en', 'kr', 'kk', 'zh', 'ru'];

// Derive active language from URL pathname — reliable across all routes and ClientRouter
const pathSeg = Astro.url.pathname.split('/')[1];
const activeLang = pathSeg && langList.includes(pathSeg as Lang) ? (pathSeg as Lang) : 'en';

function isActiveLang(lang: string): boolean {
  if (lang === 'en') return activeLang === 'en';
  return activeLang === lang;
}

const homePath = locale === 'en' ? '/' : `/${locale}`;

const menuItems: { key: string; href: string }[] = [
  { key: "home", href: `${homePath}#home` },
  { key: "about", href: `${homePath}#about` },
  { key: "art", href: `${homePath}#art` },
  { key: "exhibitions", href: `${homePath}#exhibitions` },
  { key: "publications", href: `${homePath}#publications` },
  { key: "research", href: `${homePath}#research` },
  { key: "press", href: `${homePath}#press` },
  { key: "contacts", href: `${homePath}#contacts` },
];
---

<!doctype html>
<html lang={l.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — {l.siteTitle}</title>
    <!-- spa-scroll-v2: single-page 8 sections -->
    <ClientRouter />
    <script is:inline>
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        document.documentElement.classList.add("motion-live");
        var y = sessionStorage.getItem("lang-preserve-scroll");
        if (y !== null) {
          var top = parseInt(y, 10);
          if (!Number.isNaN(top)) window.scrollTo(0, top);
        }
      })();
    </script>
    <script is:inline>
      (function () {
        function updateSidebarRail() {
          var nav = document.querySelector(".desktop-sidebar .sidebar-nav");
          var thumb = document.getElementById("sidebar-scroll-progress");
          if (!nav || !thumb) return;

          var links = nav.querySelectorAll(".sidebar-nav-link[data-nav-key]");
          if (!links.length) return;

          var maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
          var progress = Math.min(1, Math.max(0, window.scrollY / maxScroll));
          var navRect = nav.getBoundingClientRect();
          var first = links[0].getBoundingClientRect();
          var last = links[links.length - 1].getBoundingClientRect();
          var startY = first.top - navRect.top + first.height * 0.5;
          var endY = last.top - navRect.top + last.height * 0.5;
          var thumbH = 21;
          var y = startY + (endY - startY) * progress - thumbH * 0.5;
          thumb.style.transform = "translate3d(0, " + y + "px, 0)";

          var marker = window.scrollY + window.innerHeight * 0.3;
          var sections = document.querySelectorAll("section[id].scroll-section");
          var active = sections[0] ? sections[0].id : "home";
          for (var i = 0; i < sections.length; i++) {
            var top = sections[i].getBoundingClientRect().top + window.scrollY;
            if (top <= marker + 4) active = sections[i].id;
          }
          for (var j = 0; j < links.length; j++) {
            var link = links[j];
            var on = link.getAttribute("data-nav-key") === active;
            link.classList.toggle("nav-link--active", on);
            link.setAttribute("aria-current", on ? "true" : "false");
          }
        }

        var railTicking = false;
        function onRailScroll() {
          if (!railTicking) {
            railTicking = true;
            requestAnimationFrame(function () {
              updateSidebarRail();
              railTicking = false;
            });
          }
        }

        window.addEventListener("scroll", onRailScroll, { passive: true });
        window.addEventListener("resize", onRailScroll, { passive: true });
        document.addEventListener("DOMContentLoaded", updateSidebarRail);
        document.addEventListener("astro:page-load", updateSidebarRail);
        document.addEventListener("lang-scroll-restored", updateSidebarRail);
        if (document.readyState !== "loading") updateSidebarRail();
      })();
    </script>
  </head>
  <body class="font-sans antialiased bg-[#F0EEE9] text-[#111]" data-layout="spa-scroll">
    <!-- Film grain overlay -->
    <div class="grain-overlay" />

    <!-- Language switch transition (persists across ClientRouter swaps) -->
    <div id="lang-transition-overlay" class="lang-transition-overlay" transition:persist="lang-overlay" aria-hidden="true" aria-live="polite">
      <div class="lang-transition-overlay__panel">
        <span class="lang-transition-overlay__eyebrow font-mono text-[10px] tracking-[0.35em] uppercase text-[#555]/70">Language</span>
        <p class="lang-transition-overlay__code font-forum text-6xl md:text-7xl text-[#111] leading-none" data-lang-code>EN</p>
        <p class="lang-transition-overlay__name font-serif italic text-xl md:text-2xl text-[#555] mt-3" data-lang-name>English</p>
        <div class="lang-transition-overlay__bar" aria-hidden="true">
          <span class="lang-transition-overlay__bar-fill"></span>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var LANG = {
          en: { code: "EN", name: "English" },
          kr: { code: "KR", name: "한국어" },
          kk: { code: "KK", name: "Қазақша" },
          zh: { code: "简", name: "中文" },
          ru: { code: "RU", name: "Русский" },
        };
        var switching = false;

        function currentLang() {
          var seg = location.pathname.split("/")[1];
          var langs = ["kr", "kk", "zh", "ru"];
          return langs.indexOf(seg) >= 0 ? seg : "en";
        }

        function showOverlay(lang) {
          var overlay = document.getElementById("lang-transition-overlay");
          var display = LANG[lang] || { code: lang.toUpperCase(), name: lang };
          var codeEl = overlay && overlay.querySelector("[data-lang-code]");
          var nameEl = overlay && overlay.querySelector("[data-lang-name]");
          var barFill = overlay && overlay.querySelector(".lang-transition-overlay__bar-fill");
          if (codeEl) codeEl.textContent = display.code;
          if (nameEl) nameEl.textContent = display.name;
          if (barFill) {
            barFill.style.animation = "none";
            void barFill.offsetWidth;
            barFill.style.animation = "";
          }
          if (overlay) {
            overlay.classList.add("is-active");
            overlay.setAttribute("aria-hidden", "false");
          }
          document.documentElement.classList.add("lang-switching");
          document.body.classList.add("lang-switching");
        }

        window.__showLangOverlay = showOverlay;

        document.addEventListener(
          "click",
          function (e) {
            var btn = e.target && e.target.closest ? e.target.closest(".lang-btn") : null;
            if (!btn) return;
            var lang = btn.getAttribute("data-lang");
            if (!lang || lang === currentLang()) {
              e.preventDefault();
              return;
            }
            if (switching) {
              e.preventDefault();
              return;
            }

            e.preventDefault();
            e.stopImmediatePropagation();
            switching = true;

            var href = lang === "en" ? "/" : "/" + lang;
            sessionStorage.setItem("lang-preserve-scroll", String(window.scrollY));
            sessionStorage.setItem("lang-switching", "1");
            showOverlay(lang);

            setTimeout(function () {
              window.location.assign(href);
            }, 1500);
          },
          true
        );
      })();
    </script>

    <!-- 5-Language Toggle — desktop (hidden on mobile) -->
    <div id="lang-toggle-desktop" transition:persist="lang-toggle-desktop" class="lang-toggle lang-toggle--desktop hidden lg:flex">
      {langList.map((lang) => (
        <button
          type="button"
          class:list={["lang-btn", isActiveLang(lang) && "lang-btn--active"]}
          data-lang={lang}
          aria-pressed={isActiveLang(lang) ? 'true' : 'false'}
          aria-label={`Switch to ${langLabels[lang]}`}
        >
          <span class="lang-btn__label">{langLabels[lang]}</span>
        </button>
      ))}
    </div>

    <!-- Mobile header bar (<1024px) -->
    <header class="lg:hidden fixed top-0 left-0 right-0 z-50 h-16 bg-[#F0EEE9]/95 backdrop-blur-md border-b border-black/10 flex items-center justify-between px-5">
      <a href={`${homePath}#home`} class="font-forum text-xl md:text-2xl font-bold whitespace-nowrap tracking-tight text-[#111] hover:opacity-70 transition-opacity">
        Anna Dauyl Rockswell
      </a>
      <div class="flex items-center gap-3">
        <!-- Mobile language pills -->
        <div id="lang-toggle-mobile" transition:persist="lang-toggle-mobile" class="lang-toggle lang-toggle--mobile">
          {langList.map((lang) => (
            <button
              type="button"
              class:list={["lang-btn", isActiveLang(lang) && "lang-btn--active"]}
              data-lang={lang}
              aria-pressed={isActiveLang(lang) ? 'true' : 'false'}
              aria-label={`Switch to ${langLabels[lang]}`}
            >
              <span class="lang-btn__label">{langLabels[lang]}</span>
            </button>
          ))}
        </div>
        <!-- Hamburger -->
        <button
          id="hamburger-btn"
          class="w-11 h-11 flex items-center justify-center focus:outline-none active:scale-95 transition-transform"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6 text-[#111]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path class="ham-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path class="ham-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile drawer backdrop -->
    <div id="drawer-backdrop" class="lg:hidden fixed inset-0 z-40 bg-black/0 pointer-events-none transition-all duration-[400ms] ease-out" />

    <!-- Mobile slide-out drawer (<1024px) -->
    <aside
      id="mobile-drawer"
      class="lg:hidden fixed top-0 right-0 bottom-0 w-[85vw] max-w-[320px] z-50 bg-[#111] border-l border-white/10 translate-x-full transition-transform duration-[400ms] ease-out flex flex-col overflow-y-auto"
    >
      <nav class="flex-1 pt-24 px-6 overflow-y-auto">
        <ul class="space-y-1">
          {menuItems.map((item) => {
            const navKey = item.key as keyof typeof l.nav;
            return (
              <li>
                <a
                  href={item.href}
                  data-nav-key={item.key}
                  class="sidebar-nav-link block py-4 px-5 text-sm uppercase tracking-[0.2em] font-medium rounded-md transition-all duration-400 text-[#888] hover:bg-white/5 hover:text-white"
                >
                  {l.nav[navKey]}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
      <div class="px-6 py-10 border-t border-white/10">
        <span class="font-sans text-[9px] uppercase tracking-[0.25em] text-[#555] block mb-3">{l.basedIn}</span>
        <span class="font-sans text-xs text-[#888] font-medium tracking-wide">{l.location}</span>
      </div>
    </aside>

    <!-- Desktop sidebar — collapsed rail, expands on hover -->
    <aside class="desktop-sidebar hidden lg:flex" aria-label="Site navigation">
      <div class="desktop-sidebar__inner flex flex-col h-full">
        <div class="desktop-sidebar__brand p-6">
          <a href={`${homePath}#home`} class="block group">
            <h1 class="desktop-sidebar__title font-forum text-3xl font-bold tracking-tight text-[#111] leading-[1.05] transition-opacity duration-300 group-hover:opacity-70">
              Anna Dauyl Rockswell
            </h1>
            <span class="desktop-sidebar__monogram font-forum text-xl font-bold text-[#111]" aria-hidden="true">A·R</span>
            <span class="desktop-sidebar__subtitle font-sans text-[9px] uppercase tracking-[0.25em] text-[#555]/70 mt-2 block" set:html={l.subtitle} />
          </a>
        </div>
        <div class="desktop-sidebar__nav px-5 flex-1">
          <nav class="sidebar-nav">
            <div id="sidebar-scroll-progress" class="sidebar-scroll-progress" aria-hidden="true"></div>
            {menuItems.map((item) => {
              const navKey = item.key as keyof typeof l.nav;
              return (
                <a
                  href={item.href}
                  data-nav-key={item.key}
                  aria-current="false"
                  class="sidebar-nav-link group relative font-sans text-[11px] uppercase tracking-wider py-2 block font-medium transition-all duration-400 text-[#555]/70 hover:text-[#111]"
                >
                  <span class="sidebar-nav-label">{l.nav[navKey]}</span>
                  <span
                    class="nav-underline absolute bottom-0 left-0 w-full h-[1px] bg-neutral-400 origin-left transition-transform duration-500 ease-out scale-x-0 group-hover:scale-x-100"
                  />
                </a>
              );
            })}
          </nav>
        </div>
        <div class="desktop-sidebar__footer px-5 py-8 mt-auto">
          <span class="desktop-sidebar__footer-label font-sans text-[8px] uppercase tracking-[0.25em] text-[#555]/50 block mb-1">{l.basedIn}</span>
          <span class="desktop-sidebar__footer-text font-sans text-[11px] text-[#555]/80 font-medium tracking-wide">{l.location}</span>
        </div>
      </div>
    </aside>

    <div class="site-shell min-h-screen">
      <div class="site-main-column min-w-0 pt-16 lg:pt-0 lg:pl-[4.5rem]">
        <main transition:animate="fade" class="motion-main bg-[#F0EEE9]">
          <slot name="content" />
        </main>
        <SiteFooter locale={locale} />
      </div>
    </div>
  </body>
</html>

<script>
  import { initMotion } from "../scripts/motion/init";
  import { initLangSwitch, restoreLangScroll, syncLangHrefs, syncLangToggle } from "../scripts/lang-switch";
  import { updateScrollSpy } from "../scripts/motion/scroll-spy";

  function initDrawer() {
    const hamburgerBtn = document.getElementById("hamburger-btn");
    const drawer = document.getElementById("mobile-drawer");
    const backdrop = document.getElementById("drawer-backdrop");
    const hamOpen = hamburgerBtn?.querySelector(".ham-open");
    const hamClose = hamburgerBtn?.querySelector(".ham-close");
    let isOpen = false;

    const toggleDrawer = (forceClose = false) => {
      if (forceClose && !isOpen) return;
      isOpen = forceClose ? false : !isOpen;

      if (isOpen) {
        drawer?.classList.remove("translate-x-full");
        drawer?.classList.add("translate-x-0");
        backdrop?.classList.remove("bg-black/0", "pointer-events-none");
        backdrop?.classList.add("bg-black/60", "pointer-events-auto");
        hamOpen?.classList.add("hidden");
        hamClose?.classList.remove("hidden");
        hamburgerBtn?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
      } else {
        drawer?.classList.remove("translate-x-0");
        drawer?.classList.add("translate-x-full");
        backdrop?.classList.remove("bg-black/60", "pointer-events-auto");
        backdrop?.classList.add("bg-black/0", "pointer-events-none");
        hamOpen?.classList.remove("hidden");
        hamClose?.classList.add("hidden");
        hamburgerBtn?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      }
    };

    // Close drawer on navigation link click
    const navLinks = drawer?.querySelectorAll("a");
    navLinks?.forEach(link => {
      link.addEventListener("click", () => {
        setTimeout(() => toggleDrawer(true), 150);
      });
    });

    hamburgerBtn?.addEventListener("click", () => toggleDrawer());
    backdrop?.addEventListener("click", () => toggleDrawer());
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) toggleDrawer();
    });
  }

  function bootPageScripts() {
    initDrawer();
    syncLangHrefs();
    syncLangToggle();
    initLangSwitch();
    initMotion();
    restoreLangScroll();
  }

  document.addEventListener("lang-scroll-restored", () => {
    updateScrollSpy();
  });

  document.addEventListener("astro:after-swap", () => {
    restoreLangScroll();
  });

  document.addEventListener("DOMContentLoaded", bootPageScripts);

  document.addEventListener("astro:page-load", bootPageScripts);

  if (document.readyState !== "loading") {
    bootPageScripts();
  }
</script>
