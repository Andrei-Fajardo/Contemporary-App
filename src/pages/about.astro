---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="About" activeSection="About">
  <div class="px-8 py-10">
    <span class="text-[11px] font-mono tracking-wider text-neutral-500 mb-6 block">(ABOUT)</span>

    <div class="grid grid-cols-2 gap-12">
      <div>
        <div class="aspect-[4/3] bg-neutral-200 border border-black/[0.15] flex items-center justify-center">
          <span class="text-neutral-400 text-[11px] font-mono">Portrait</span>
        </div>
      </div>
      <div>
        <p class="font-serif italic text-xl text-neutral-800 leading-snug mb-6">Multidisciplinary artist exploring the threshold between material and memory.</p>
        <div class="text-sm text-neutral-600 leading-relaxed space-y-3 max-w-[55ch]">
          <p>Anna Dauyl Rockswell is a New York-based visual artist, researcher, and educator. Her practice spans installation, digital media, and public intervention — often drawing on archival materials and site-specific research to examine how spaces carry collective memory.</p>
          <p>She holds an MFA from Columbia University and has exhibited at the Museum of Contemporary Art Chicago, the New Museum, and the Barbican Centre.</p>
        </div>
        <div class="flex gap-12 mt-6 text-sm">
          <div>
            <p class="font-medium text-neutral-800">Education</p>
            <p class="text-neutral-500 text-[12px] mt-1">MFA, Columbia University<br />BA, Yale University</p>
          </div>
          <div>
            <p class="font-medium text-neutral-800">Grants</p>
            <p class="text-neutral-500 text-[12px] mt-1">Andy Warhol Foundation<br />NEA Fellowship</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
