---
import PageLayout from '../../layouts/PageLayout.astro';
import ComingSoon from '../../components/ComingSoon.astro';
import { t } from '../../data/translations';
const l = t.kr;
---

<PageLayout title="출판 및 저술" activeSection="publications" locale="kr">
  <div slot="content">
    <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20 max-w-4xl">
      <ComingSoon
        label="(출판 및 저술)"
        heading="출판 및 저술"
        message={l.comingSoonMessage}
        note={l.comingSoonNote}
      />
    </div>
  </div>
</PageLayout>
