---
import PageLayout from '../../layouts/PageLayout.astro';
import { t } from '../../data/translations';

const l = t.kr;
---

<PageLayout title="연락처" activeSection="contact" locale="kr">
  <div slot="content">
    <div class="px-8 py-16 md:py-24">
      <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">{l.contactTag}</span>
      <div class="w-full md:w-3/4 lg:w-1/2">
        <h1 class="font-sans font-black tracking-tighter uppercase text-6xl md:text-8xl lg:text-[9rem] leading-[0.85] text-neutral-900 mb-16" set:html={l.contactHeading}></h1>
        <form class="space-y-0" onsubmit="event.preventDefault(); alert('전송되었습니다 (데모)');">
          <div class="border-b-2 border-neutral-900 py-5">
            <span class="font-mono text-[10px] tracking-widest text-neutral-500 block mb-2">{l.nameLabel}</span>
            <input type="text" placeholder={l.namePlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-xl md:text-2xl text-neutral-400 placeholder:text-neutral-300 py-1" />
          </div>
          <div class="border-b-2 border-neutral-900 py-5">
            <span class="font-mono text-[10px] tracking-widest text-neutral-500 block mb-2">{l.emailLabel}</span>
            <input type="email" placeholder={l.emailPlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-xl md:text-2xl text-neutral-400 placeholder:text-neutral-300 py-1" />
          </div>
          <div class="border-b-2 border-neutral-900 py-5">
            <span class="font-mono text-[10px] tracking-widest text-neutral-500 block mb-2">{l.messageLabel}</span>
            <textarea rows="2" placeholder={l.messagePlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-xl md:text-2xl text-neutral-400 placeholder:text-neutral-300 py-1 resize-none"></textarea>
          </div>
          <div class="pt-6 text-right">
            <button type="submit" class="font-mono text-xs uppercase tracking-widest text-neutral-900 hover:text-neutral-500 font-bold transition-colors cursor-pointer border-none bg-transparent">{l.sendMessage}</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</PageLayout>
