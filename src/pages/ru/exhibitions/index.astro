---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../data/translations';

const l = t.ru;

const exhibitions = [
  { image: "/media/exhibitions/senses-main.jpg", title: "센시스 국제 아트 페어", year: "2025", location: "무스트 박물관, 레체, 이탈리아", subtitle: "제3회 국제 아트 페어" },
  { image: "/media/exhibitions/venice-1.jpg", title: "컨템포러리 베니스", year: "2026", location: "베니스, 이탈리아", subtitle: "컨템포러리 베니스 2026" },
  { image: "/media/exhibitions/hechyeomoyeo-nyc.png", title: "헤쳐모여 12 & 13", year: "2024–2025", location: "뉴욕, 미국", subtitle: "그룹 전시" },
  { image: "/media/exhibitions/kinship-main.png", title: "KINSHIP × 헤쳐모여", year: "2025", location: "서울, 한국", subtitle: "협업 전시" },
  { image: "/media/exhibitions/dimo-main.jpg", title: "DIMO × Verger Gallery", year: "2025", location: "제5회 전시", subtitle: "베르제 갤러리 협업" },
  { image: "/media/exhibitions/holy-london-1.jpg", title: "더 홀리 아트 – 런던", year: "2025", location: "런던, 영국", subtitle: "국제 그룹 전시" },
  { image: "/media/exhibitions/holy-paris-main.jpg", title: "더 홀리 아트 – 파리", year: "2025", location: "파리, 프랑스", subtitle: "국제 그룹 전시" },
  { image: "/media/exhibitions/luna-main.jpg", title: "루나 그란데 아트", year: "2025", location: "온라인", subtitle: "피처드 아티스트 쇼케이스" },
  { image: "/media/exhibitions/im-insa.jpg", title: "IM INSA", year: "2025", location: "인사동, 서울", subtitle: "개인전" },
];
---

<PageLayout title="전시" activeSection="exhibitions" locale="ru">
  <div slot="content">
    <div class="px-8 py-16 md:py-24">
      <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">{l.exhibitionsTag}</span>
      <h1 class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-16" set:html={l.exhibitionHistory}></h1>
      <div class="flex items-center gap-3 mb-12 flex-wrap">
        <span class="bg-[#111111] text-white text-[11px] font-mono px-4 py-1.5 font-medium">{l.all}</span>
        <span class="border border-neutral-400 text-neutral-600 text-[11px] font-mono px-4 py-1.5 hover:bg-neutral-900 hover:text-white transition-colors cursor-pointer">{l.physical}</span>
        <span class="border border-neutral-400 text-neutral-600 text-[11px] font-mono px-4 py-1.5 hover:bg-neutral-900 hover:text-white transition-colors cursor-pointer">{l.virtualFilter}</span>
        <span class="border border-neutral-400 text-neutral-600 text-[11px] font-mono px-4 py-1.5 hover:bg-neutral-900 hover:text-white transition-colors cursor-pointer">{l.featureFilter}</span>
      </div>
      {exhibitions.map((ex, i) => (
        <div class={`flex flex-col md:flex-row border-t border-neutral-900/20 py-8 md:py-10 ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="w-full md:w-2/3 pr-0 md:pr-8">
            <div class="relative overflow-hidden group">
              <img src={ex.image} alt={ex.title} class="w-full h-[40vh] md:h-[50vh] object-cover" loading="lazy" />
              <div class="afterimage-trail absolute inset-0 w-full h-full bg-cover bg-center pointer-events-none" style={`background-image: url(${ex.image})`} />
            </div>
          </div>
          <div class="w-full md:w-1/3 flex flex-col justify-center mt-4 md:mt-0">
            <div class="flex items-center justify-between mb-3">
              <span class="font-mono text-[10px] tracking-widest text-neutral-400">[{String(i + 1).padStart(3, '0')} // 전시]</span>
              <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500">{ex.year}</span>
            </div>
            <h2 class="font-sans font-black tracking-tighter uppercase text-2xl md:text-3xl leading-[0.9] text-neutral-900">{ex.title}</h2>
            <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 uppercase mt-2">{ex.location}</span>
            <span class="font-sans text-xs uppercase tracking-wider font-semibold text-neutral-700 mt-4">{ex.subtitle}</span>
            <a href="#" class="font-mono text-[10px] tracking-widest text-neutral-900 underline underline-offset-4 mt-4 hover:text-neutral-500 transition-colors">{l.viewMore}</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</PageLayout>
