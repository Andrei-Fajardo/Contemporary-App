---
import PageLayout from '../layouts/PageLayout.astro';
import { t } from '../data/translations';
---

<PageLayout title="404" activeSection="">
  <div slot="content">
    <section class="overload-404">
      <div class="overload-404__inner">
        <p class="overload-404__eyebrow">{t.en.notFoundEyebrow}</p>
        <h1 class="overload-404__code" aria-label="404">
          4<span class="overload-404__code-accent">0</span>4
        </h1>
        <p class="overload-404__body">{t.en.notFoundBody}</p>
        <div class="overload-404__actions">
          <a href="/" class="overload-btn overload-btn--primary">{t.en.notFoundCta}</a>
          <a href="/#art" class="overload-btn overload-btn--ghost">{t.en.notFoundAlt}</a>
        </div>
      </div>
    </section>
  </div>
</PageLayout>
