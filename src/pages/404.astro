---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Not Found">
  <main class="flex flex-col items-center justify-center min-h-[60vh] px-8">
    <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(ERROR)</span>
    <h1 class="font-sans font-black tracking-tighter uppercase text-7xl md:text-9xl leading-[0.85] text-neutral-900 mb-4">404</h1>
    <p class="font-serif italic text-xl text-neutral-600 max-w-[40ch] text-center">The requested page could not be found.</p>
    <a href="/" class="mt-10 font-sans text-[11px] uppercase tracking-widest text-neutral-900 underline underline-offset-4 hover:text-neutral-500 transition-colors">
      Return Home
    </a>
  </main>
</Layout>
