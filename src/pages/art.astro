---
import PageLayout from '../layouts/PageLayout.astro';
import StickySection from '../components/StickySection.astro';
import MediaPopup from '../components/MediaPopup.astro';
import { t, type LocaleKey } from '../data/translations';

export interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const paintings = [
  {
    image: "/media/the-fish.png",
    title: "The Fish",
    medium: "90CM X 80CM, OIL ON CANVAS",
    year: "2024",
    description:
      "She floats in a half-life, caught between Piscean intuition and the weight of funeral black. The fur is not warmth — it is the silence before the burial. The fish totem carries her through waters both amniotic and grave-cold.",
    contain: true,
  },
  {
    image: "/media/souls-and-leavings.jpg",
    title: "The Souls of Leavings",
    medium: "120CM X 100CM, MIXED MEDIA ON CANVAS",
    year: "2025",
    description:
      "This painting emerged from witnessing the devastation of abandonment and the quiet violence of loss. The female figure appears caught between states — as though waiting for something to leave her, or return. In Kazakh tradition, the departing soul lingers for forty days.",
    contain: true,
  },
];
---

<PageLayout title="Art" activeSection="art" locale={locale}>
  <div slot="content">
    <StickySection>
      <div slot="pin" class="px-4 sm:px-6 md:px-8 py-12 md:py-20 border-b border-neutral-900/20">
        <span class="scroll-reveal font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(ARTWORK)</span>
        <h1 class="scroll-reveal font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-4">
          Paintings
        </h1>
        <p class="scroll-reveal font-serif italic text-xl text-neutral-600 max-w-[45ch]">{l.heroDesc}</p>
      </div>

      <section>
        {paintings.map((p, i) => (
          <div class="border-b border-neutral-900/20">
            <div class="flex flex-col md:flex-row">
              <div class={`w-full md:w-2/3 ${i % 2 === 1 ? 'md:order-2' : ''}`}>
                <MediaPopup
                  imageSrc={p.image}
                  imageAlt={p.title}
                  title={p.title}
                  subtitle={`${p.medium} // ${p.year}`}
                  aspectRatio={p.contain ? "4 / 5" : "3 / 2"}
                  parallaxSpeed={0.5}
                  contain={p.contain}
                  imageClass={p.contain ? "w-full h-full max-h-[80vh] object-contain" : "w-full h-[50vh] md:h-[65vh] object-cover"}
                />
              </div>
              <div class={`scroll-reveal w-full md:w-1/3 ${i % 2 === 1 ? 'md:order-1' : ''} flex flex-col justify-between p-8 md:p-10`}>
                <div>
                  <div class="flex items-center justify-between mb-6">
                    <span class="font-mono text-[10px] tracking-widest text-neutral-400">{String(i + 1).padStart(3, '0')}</span>
                    <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500">{p.year}</span>
                  </div>
                  <h2 class="font-sans font-black tracking-tighter uppercase text-3xl md:text-4xl leading-[0.9] text-neutral-900">{p.title}</h2>
                  <span class="font-mono text-[9px] tracking-[0.3em] uppercase text-neutral-500 block mt-3">{p.medium}</span>
                </div>
                <p class="font-mono text-xs tracking-wider leading-relaxed text-neutral-600 max-w-[45ch] mt-6">{p.description}</p>
              </div>
            </div>
          </div>
        ))}
      </section>
    </StickySection>
  </div>
</PageLayout>
