  { src: "/media/exhibitions/luna/luna-main.jpg", title: "Luna Grande Art", year: "2025", medium: "ISTANBUL, TURKEY", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/luna/luna-1.jpg", title: "Luna Grande — Detail", year: "2025", medium: "ISTANBUL", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/luna/luna-2.jpg", title: "Luna Grande — Showcase", year: "2025", medium: "ISTANBUL", dimensions: "", group: "Exhibitions" },
  { src: exhibitionPoster('Ahmad Shariff.jpg'), title: "Ahmad Shariff Gallery — Poster", year: "2025", medium: "CLAREMONT, CALIFORNIA", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/ahmad-shariff/ahmad-shariff-placeholder-1.jpg", title: "Ahmad Shariff Gallery", year: "2025", medium: "CLAREMONT, CALIFORNIA", dimensions: "", group: "Exhibitions" },
  { src: exhibitionPoster('im insa.jpg'), title: "IM INSA — Poster", year: "2025", medium: "INSADONG, SEOUL", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/im-insa/im-insa.jpg", title: "IM INSA", year: "2025", medium: "INSADONG, SEOUL", dimensions: "", group: "Exhibitions" },

  // Feature
  { src: "/media/feature/itaewon-film-fest.jpg", title: "Itaewon Film Festival", year: "2025", medium: "ITAEWON, SEOUL", dimensions: "", group: "Feature" },
  { src: "/media/feature/itaewon-1.jpg", title: "Film Festival — Scene", year: "2025", medium: "ITAEWON", dimensions: "", group: "Feature" },
  { src: "/media/feature/itaewon-2.jpg", title: "Film Festival — Installation", year: "2025", medium: "ITAEWON", dimensions: "", group: "Feature" },

  // Virtual
  { src: "/media/virtual/clover-anna.jpg", title: "Soul Gift — Clover Gallery", year: "2026", medium: "VIRTUAL EXHIBITION", dimensions: "", group: "Virtual" },
  { src: "/media/virtual/soul-gift.jpg", title: "Soul Gift — Interior", year: "2026", medium: "CLOVER GALLERY", dimensions: "", group: "Virtual" },
  { src: "/media/virtual/soul-gift-poster.png", title: "Soul Gift — Poster", year: "2026", medium: "CLOVER GALLERY", dimensions: "", group: "Virtual" },
  { src: "/media/virtual/the-atrium.jpg", title: "The Atrium", year: "2026", medium: "VIRTUAL EXHIBITION", dimensions: "", group: "Virtual" },
];
---

<PageLayout title="Gallery" activeSection="art" locale={locale}>
  <div slot="content">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-12 md:py-20">
      <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">GALLERY</span>
      <h1 class="type-heading text-5xl md:text-7xl lg:text-[8rem] leading-[0.9] text-neutral-900 mb-16">
        Gallery
      </h1>

      <!-- Filter tabs -->
      <div id="gallery-filters" class="flex flex-wrap gap-4 mb-12 border-b border-neutral-900/10 pb-6">
        <button data-group="all" class="gallery-filter active font-mono text-[11px] uppercase tracking-[0.2em] text-neutral-900 border-b-2 border-neutral-900 pb-1 transition-colors duration-300 hover:text-neutral-500 cursor-pointer">All</button>
        <button data-group="Artwork" class="gallery-filter font-mono text-[11px] uppercase tracking-[0.2em] text-neutral-400 border-b-2 border-transparent pb-1 transition-colors duration-300 hover:text-neutral-900 cursor-pointer">Artwork</button>
        <button data-group="Exhibitions" class="gallery-filter font-mono text-[11px] uppercase tracking-[0.2em] text-neutral-400 border-b-2 border-transparent pb-1 transition-colors duration-300 hover:text-neutral-900 cursor-pointer">Exhibitions</button>
        <button data-group="Feature" class="gallery-filter font-mono text-[11px] uppercase tracking-[0.2em] text-neutral-400 border-b-2 border-transparent pb-1 transition-colors duration-300 hover:text-neutral-900 cursor-pointer">Feature</button>
        <button data-group="Virtual" class="gallery-filter font-mono text-[11px] uppercase tracking-[0.2em] text-neutral-400 border-b-2 border-transparent pb-1 transition-colors duration-300 hover:text-neutral-900 cursor-pointer">Virtual</button>
      </div>

      <!-- Gallery grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-neutral-900/10 border border-neutral-900/10">
        {galleryImages.map((img, i) => (
          <div class="gallery-item interactive-image-container aspect-[4/3]" data-group={img.group}>
            <img
              src={img.src}
              alt={img.title}
              loading="lazy"
              class="opacity-0 translate-y-4 animate-fade-up"
              style={`animation-delay: ${(i % 12) * 60}ms`}
            />
            <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/50 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300 pointer-events-none">
              <p class="type-subheading text-white text-xs truncate">{img.title}</p>
              <p class="type-body text-[10px] text-white/70">{img.medium} {img.year ? `// ${img.year}` : ''}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</PageLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filters = document.querySelectorAll(".gallery-filter");
    const items = document.querySelectorAll(".gallery-item");

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const group = btn.dataset.group;

        filters.forEach((f) => {
          f.classList.remove("active", "text-neutral-900", "border-neutral-900");
          f.classList.add("text-neutral-400", "border-transparent");
        });
        btn.classList.add("active", "text-neutral-900", "border-neutral-900");
        btn.classList.remove("text-neutral-400", "border-transparent");

        items.forEach((item) => {
          if (group === "all" || item.dataset.group === group) {
            item.style.display = "block";
          } else {
            item.style.display = "none";
          }
        });
      });
    });
  });
</script>
