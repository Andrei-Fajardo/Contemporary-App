---
import PageLayout from '../layouts/PageLayout.astro';
import { t, type LocaleKey } from '../data/translations';
import { artworks } from '../data/artworks';
import { holyParisJournal, exhibitionPoster } from '../data/content';

export interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const artworkGalleryEntries = artworks.map((art) => ({
  src: art.image,
  title: art.title,
  year: art.year,
  medium: art.medium,
  dimensions: art.dimensions,
  group: "Artwork" as const,
}));

const galleryImages = [
  ...artworkGalleryEntries,

  // Exhibition shots
  { src: "/media/exhibitions/senses/senses-main.jpg", title: "Senses International Art Fair", year: "2025", medium: "MUST MUSEUM, LECCE", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/senses/senses-1.jpg", title: "Senses — Installation View", year: "2025", medium: "MUST MUSEUM, LECCE", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/senses/senses-2.jpg", title: "Senses — Detail", year: "2025", medium: "MUST MUSEUM, LECCE", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/venice/venice-1.jpg", title: "Contemporary Venice", year: "2026", medium: "VENICE, ITALY", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/venice/venice-2.jpg", title: "Venice — Installation View", year: "2026", medium: "VENICE, ITALY", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/venice/venice-3.jpg", title: "Venice — Detail", year: "2026", medium: "VENICE, ITALY", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/venice/venice-5.jpg", title: "Venice — Installation", year: "2026", medium: "VENICE, ITALY", dimensions: "", group: "Exhibitions" },
  { src: exhibitionPoster('HCMY 12.jpg'), title: "HCMY 12 — Poster", year: "2025", medium: "LIVING GALLERY, BROOKLYN", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/hechyeomoyeo-12/hechyeomoyeo-nyc.JPG", title: "HCMY 12", year: "2025", medium: "LIVING GALLERY, BROOKLYN", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/hechyeomoyeo-12/hech-1.jpg", title: "HCMY 12 — Installation", year: "2025", medium: "LIVING GALLERY, BROOKLYN", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/hechyeomoyeo-12/hech-2.jpg", title: "HCMY 12 — Detail", year: "2025", medium: "LIVING GALLERY, BROOKLYN", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/hechyeomoyeo-13/hech-3.jpg", title: "HCMY 13 — View", year: "2025", medium: "NEW YORK", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/hechyeomoyeo-13/hech-4.jpg", title: "HCMY 13 — Space", year: "2025", medium: "NEW YORK", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/kinship/kinship-main.png", title: "KINSHIP × HCMY", year: "2025", medium: "SEOUL, SOUTH KOREA", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/kinship/kinship-1.jpg", title: "KINSHIP — View", year: "2025", medium: "SEOUL", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/kinship/kinship-2.jpg", title: "KINSHIP — Installation", year: "2025", medium: "SEOUL", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/kinship/kinship-3.jpg", title: "KINSHIP — Detail", year: "2025", medium: "SEOUL", dimensions: "", group: "Exhibitions" },
  { src: exhibitionPoster('Vergr Gallery.jpg'), title: "DIMO × Verger Gallery — Poster", year: "2025", medium: "VERGER GALLERY", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/dimo/dimo-main.jpg", title: "DIMO × Verger Gallery", year: "2025", medium: "5TH EXHIBITION", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/dimo/dimo-1.jpg", title: "DIMO — Installation", year: "2025", medium: "VERGER GALLERY", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/dimo/dimo-2.jpg", title: "DIMO — Detail", year: "2025", medium: "VERGER GALLERY", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/holy-london/holy-london-1.jpg", title: "The Holy Art — London", year: "2026", medium: "LONDON, UK", dimensions: "", group: "Exhibitions" },
  { src: "/media/exhibitions/holy-london/holy-london-2.jpg", title: "Holy Art London — Detail", year: "2026", medium: "LONDON", dimensions: "", group: "Exhibitions" },
  { src: holyParisJournal(1), title: "The Holy Art — Paris", year: "2026", medium: "PARIS, FRANCE", dimensions: "", group: "Exhibitions" },
  { src: holyParisJournal(3), title: "Holy Art Paris — Detail", year: "2026", medium: "PARIS", dimensions: "", group: "Exhibitions" },
