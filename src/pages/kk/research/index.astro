---
import PageLayout from '../../../layouts/PageLayout.astro';
import ComingSoon from '../../../components/ComingSoon.astro';
import { t } from '../../../data/translations';
const l = t.kk;
---

<PageLayout title="Академиялық зерттеу" activeSection="research" locale="kk">
  <div slot="content">
    <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20 max-w-4xl">
      <ComingSoon
        label="(АКАДЕМИЯЛЫҚ ЗЕРТТЕУ)"
        heading="Академиялық зерттеу"
        message={l.comingSoonMessage}
        note={l.comingSoonNote}
      />
    </div>
  </div>
</PageLayout>
