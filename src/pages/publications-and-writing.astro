---
import PageLayout from '../layouts/PageLayout.astro';
import { publications } from '../data/content';
---

<PageLayout title="Publications" activeSection="publications">
  <div slot="content">
    <div class="px-8 py-16 md:py-24">
      <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(PUBLICATIONS &amp; WRITING)</span>
      <h1 class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-16">
        Publications<br />&amp; Writing
      </h1>

      <div class="grid md:grid-cols-2 gap-px bg-neutral-900/20">
        {publications.map((pub) => (
          <div class="bg-[#E3E2DA] p-8 border border-neutral-900/20">
            <span class="font-mono text-[9px] tracking-widest text-neutral-500 uppercase block mb-3">{pub.type}</span>
            <h2 class="font-sans font-black tracking-tighter uppercase text-xl text-neutral-900">{pub.title}</h2>
            <span class="font-mono text-[10px] text-neutral-500 mt-2 block">{pub.issue}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</PageLayout>
