---
import PageLayout from '../layouts/PageLayout.astro';
import { publications } from '../data/content';
---

<PageLayout title="Publications &amp; Writing" activeSection="Publications &amp; Writing">
  <div class="px-8 py-10">
    <span class="text-[11px] font-mono tracking-wider text-neutral-500 mb-6 block">(PUBLICATIONS &amp; WRITING)</span>

    <div class="grid grid-cols-2 gap-6">
      {publications.map((pub) => (
        <div class="border border-black/[0.15] p-5">
          <span class="text-[10px] font-mono tracking-widest text-neutral-400 uppercase">{pub.type}</span>
          <h3 class="font-sans text-sm font-semibold text-neutral-800 mt-2">{pub.title}</h3>
          <span class="text-[11px] font-mono text-neutral-500 mt-1 block">{pub.issue}</span>
        </div>
      ))}
    </div>
  </div>
</PageLayout>
