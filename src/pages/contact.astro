---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Contact" activeSection="Contact">
  <div class="px-8 py-10">
    <span class="text-[11px] font-mono tracking-wider text-neutral-500 mb-6 block">(CONTACT)</span>

    <h2 class="font-serif italic text-6xl md:text-7xl text-neutral-800 tracking-tight mb-16 mt-4 block">Contact Me</h2>

    <form class="max-w-3xl" onsubmit="event.preventDefault(); alert('Message sent (demo)');">
      <div class="border-b border-black/[0.15] py-6 flex items-center">
        <span class="font-serif italic text-2xl text-neutral-700 min-w-[120px] inline-block">Name:</span>
        <input type="text" placeholder="Your name" class="font-sans text-sm text-neutral-400 italic pl-4 w-full bg-transparent focus:outline-none border-none" />
      </div>
      <div class="border-b border-black/[0.15] py-6 flex items-center">
        <span class="font-serif italic text-2xl text-neutral-700 min-w-[120px] inline-block">Email:</span>
        <input type="email" placeholder="Your email" class="font-sans text-sm text-neutral-400 italic pl-4 w-full bg-transparent focus:outline-none border-none" />
      </div>
      <div class="border-b border-black/[0.15] py-6 flex items-start">
        <span class="font-serif italic text-2xl text-neutral-700 min-w-[120px] inline-block pt-1">Message:</span>
        <textarea rows="2" placeholder="Write your message here" class="font-sans text-sm text-neutral-400 italic pl-4 w-full bg-transparent focus:outline-none border-none resize-none"></textarea>
      </div>
      <span class="font-mono text-xs uppercase tracking-widest text-neutral-800 hover:text-neutral-500 font-bold transition-colors cursor-pointer text-right block w-full pt-4" onclick="this.closest('form').requestSubmit()">Send message</span>
    </form>
  </div>
</PageLayout>
