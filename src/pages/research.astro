---
import PageLayout from '../layouts/PageLayout.astro';
import { researchPapers } from '../data/content';
---

<PageLayout title="Academic Research" activeSection="research" locale="en">
  <div slot="content">
    <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
      <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(ACADEMIC RESEARCH)</span>
      <h1 class="font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-12 md:mb-16">
        Academic<br />Research
      </h1>

      <div class="space-y-3 md:space-y-4">
        {researchPapers.map((paper) => (
          <div class="border border-neutral-900/20 p-5 md:p-6 flex flex-col sm:flex-row justify-between items-start gap-3 sm:gap-4 rounded">
            <div>
              <h2 class="font-sans font-black tracking-tighter uppercase text-sm text-neutral-900">{paper.title}</h2>
              <span class="font-mono text-[10px] text-neutral-500 italic block mt-2">{paper.journal}</span>
            </div>
            <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500 flex-shrink-0">{paper.year}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</PageLayout>
