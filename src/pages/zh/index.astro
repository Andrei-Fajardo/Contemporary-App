---
import PageLayout from '../../layouts/PageLayout.astro';
import { t } from '../../data/translations';

const l = t.zh;

const paintings = [
  {
    image: "/media/the-fish.png",
    title: "The Fish",
    medium: "90CM X 60CM, OIL ON CANVAS",
    year: "2024",
    description: "관능과 상징 사이에 매달린 여성의 우울한 묘사. 물고기자리의 요소는 직관과 유동적 정체성을 암시하며, 검은 털 — 카자흐 문화에서 죽음의 상징 — 은 그녀를 고요하고 피할 수 없는 정적으로 감쌉니다.",
    contain: true,
  },
  {
    image: "/media/souls-and-leavings.jpg",
    title: "Souls of Leavings",
    medium: "90CM X 60CM, OIL ON CANVAS",
    year: "2024",
    description: "버려짐의 참상과 상실의 조용한 폭력을 목격한 작가의 경험에서 탄생한 작품. 여성 형상은 떠나거나 돌아오기를 기다리는 듯한 상태 사이에 갇혀 있습니다.",
    contain: true,
  },
  {
    image: "/media/exhibitions/venice-4.jpg",
    title: "헤쳐모여 시리즈",
    medium: "MIXED MEDIA, INSTALLATION",
    year: "2024–2025",
    description: "여성 경험, 정신 건강의 내면, 그리고 내장적 이미지와 다크 표현주의를 통한 사회적 논평을 탐구하는 연속 시리즈.",
    contain: false,
  },
];
---

<PageLayout title="작품" activeSection="art" locale="zh">
  <div slot="content">
    <section class="border-b border-neutral-900/20">
      <div class="py-20 md:py-32 px-8">
        <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">{l.artTag}</span>
        <div class="space-y-0">
          <h1 class="font-sans font-black tracking-tighter uppercase text-6xl md:text-8xl lg:text-[9rem] leading-[0.85] text-neutral-900">
            {l.selected}
          </h1>
          <div class="flex items-center gap-4 md:gap-8 my-2">
            <div class="h-px flex-1 bg-neutral-900/20" />
            <span class="font-mono text-[10px] tracking-widest text-neutral-500">[001]</span>
          </div>
          <div class="flex">
            <h1 class="font-sans font-black tracking-tighter uppercase text-6xl md:text-8xl lg:text-[9rem] leading-[0.85] text-neutral-900">
              {l.works}
            </h1>
            <span class="font-sans font-black tracking-tighter uppercase text-6xl md:text-8xl lg:text-[9rem] leading-[0.85] text-outline ml-4">2026</span>
          </div>
        </div>
        <p class="font-serif italic text-xl md:text-2xl text-neutral-800 leading-relaxed max-w-[55ch] mt-10">{l.intro}</p>
        <p class="font-mono text-xs uppercase tracking-widest leading-relaxed text-neutral-600 max-w-[45ch] mt-6">{l.heroDesc}</p>
      </div>
    </section>

    <section>
      {paintings.map((p, i) => (
        <div class="border-b border-neutral-900/20">
          <div class="flex flex-col md:flex-row">
            <div class={`w-full md:w-2/3 ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              <div class="relative overflow-hidden group flex items-center justify-center bg-[#E3E2DA]">
                <img src={p.image} alt={p.title} class={`w-full ${p.contain ? 'h-auto max-h-[80vh] object-contain' : 'h-[50vh] md:h-[65vh] object-cover'}`} loading="lazy" />
                <div class="afterimage-trail absolute inset-0 w-full h-full bg-contain bg-center bg-no-repeat pointer-events-none" style={`background-image: url(${p.image})`} />
              </div>
            </div>
            <div class={`w-full md:w-1/3 ${i % 2 === 1 ? 'md:order-1' : ''} flex flex-col justify-between p-8 md:p-10`}>
              <div>
                <div class="flex items-center justify-between mb-6">
                  <span class="font-mono text-[10px] tracking-widest text-neutral-400">{String(i + 1).padStart(3, '0')}</span>
                  <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500">{p.year}</span>
                </div>
                <h2 class="font-sans font-black tracking-tighter uppercase text-3xl md:text-4xl leading-[0.9] text-neutral-900">{p.title}</h2>
                <span class="font-mono text-[9px] tracking-[0.3em] uppercase text-neutral-500 block mt-3">{p.medium}</span>
              </div>
              <p class="font-mono text-xs tracking-wider leading-relaxed text-neutral-600 max-w-[45ch] mt-6">{p.description}</p>
            </div>
          </div>
        </div>
      ))}
    </section>
  </div>
</PageLayout>
