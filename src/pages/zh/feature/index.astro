---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../data/translations';
const l = t.zh;
---

<PageLayout title="특집" activeSection="feature" locale="zh">
  <div slot="content">
    <div class="px-8 py-16 md:py-24">
      <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">{l.featureTag}</span>
      <h1 class="font-heading font-bold tracking-tight text-5xl md:text-7xl lg:text-[8rem] leading-[0.9] text-neutral-900 mb-8">{l.featured}</h1>
      <div class="flex flex-col md:flex-row border-t border-neutral-900/20 py-10">
        <div class="w-full md:w-2/3 pr-0 md:pr-8">
          <div class="relative overflow-hidden group">
            <img src="/media/feature/itaewon-film-fest.jpg" alt="Itaewon Film Festival" class="w-full h-[50vh] md:h-[60vh] object-cover" loading="lazy" />
            <div class="afterimage-trail absolute inset-0 w-full h-full bg-cover bg-center pointer-events-none" style="background-image: url('/media/feature/itaewon-film-fest.jpg')" />
          </div>
        </div>
        <div class="w-full md:w-1/3 flex flex-col justify-center mt-4 md:mt-0">
          <div class="flex items-center justify-between mb-3">
            <span class="font-mono text-[10px] tracking-widest text-neutral-400">[001 // 특집]</span>
            <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500">2025</span>
          </div>
          <h2 class="font-subheading font-bold tracking-tight uppercase text-2xl md:text-3xl leading-[0.95] text-neutral-900">이태원 영화제</h2>
          <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 uppercase mt-2">이태원, 서울</span>
          <p class="font-mono text-[11px] tracking-wider text-neutral-600 mt-4 max-w-[45ch]">영화와 시각 예술의 경계에서 작업하는 작가로서 이태원 영화제에 참여했습니다.</p>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-px bg-neutral-900/20 mt-8">
        {["itaewon-1.jpg", "itaewon-2.jpg"].map((img) => (
          <div class="bg-transparent border border-neutral-900/20 overflow-hidden">
            <img src={`/media/feature/${img}`} alt="Itaewon Film Festival" class="w-full aspect-[4/3] object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </div>
</PageLayout>
