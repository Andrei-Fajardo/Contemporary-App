---
import PageLayout from '../layouts/PageLayout.astro';
import { researchPapers } from '../data/content';
---

<PageLayout title="Academic Research" activeSection="Academic Research">
  <div class="px-8 py-10">
    <span class="text-[11px] font-mono tracking-wider text-neutral-500 mb-6 block">(ACADEMIC RESEARCH)</span>

    <div class="space-y-4">
      {researchPapers.map((paper) => (
        <div class="border border-black/[0.15] p-5 flex justify-between items-start">
          <div>
            <h3 class="font-sans text-[13px] font-semibold text-neutral-800">{paper.title}</h3>
            <span class="text-[11px] font-mono text-neutral-500 italic block mt-1">{paper.journal}</span>
          </div>
          <span class="border border-neutral-400 px-2 py-0.5 text-[10px] font-mono rounded-full text-neutral-600 flex-shrink-0">{paper.year}</span>
        </div>
      ))}
    </div>
  </div>
</PageLayout>
