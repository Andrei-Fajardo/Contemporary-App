---
import PageLayout from '../layouts/PageLayout.astro';
import { exhibitions } from '../data/content';
---

<PageLayout title="Exhibitions" activeSection="Exhibitions">
  <div class="px-8 py-10">
    <span class="text-[11px] font-mono tracking-wider text-neutral-500 mb-6 block">(EXHIBITIONS)</span>

    <!-- Filter Pills -->
    <div class="flex items-center gap-2 mb-8">
      <span class="bg-[#2B2B26] text-white text-[12px] font-sans px-4 py-1 rounded-full font-medium">All</span>
      <span class="border border-neutral-400/40 text-neutral-700 text-[12px] font-sans px-4 py-1 rounded-full hover:bg-neutral-200/30 transition-all cursor-pointer">Featured</span>
      <span class="border border-neutral-400/40 text-neutral-700 text-[12px] font-sans px-4 py-1 rounded-full hover:bg-neutral-200/30 transition-all cursor-pointer">Virtual Exhibit</span>
      <span class="border border-neutral-400/40 text-neutral-700 text-[12px] font-sans px-4 py-1 rounded-full hover:bg-neutral-200/30 transition-all cursor-pointer">Physical Exhibit</span>
    </div>

    <!-- 2-Column Grid -->
    <div class="grid grid-cols-2 border-l border-black/[0.15]">
      {exhibitions.map((ex) => (
        <div class="border-r border-b border-black/[0.15] p-6 flex flex-col">
          <div class="aspect-[4/3] bg-neutral-200 overflow-hidden">
            <img src={ex.image} alt={ex.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="mt-4 flex items-center justify-between">
            <h3 class="font-sans text-sm font-semibold tracking-tight text-neutral-800">{ex.title}</h3>
            <span class="border border-neutral-400 px-2.5 py-0.5 text-[10px] font-mono rounded-full text-neutral-600">{ex.year}</span>
          </div>
          <span class="text-[11px] font-mono tracking-widest text-neutral-400 uppercase mt-0.5 block">{ex.location}</span>
          <span class="text-[13px] font-sans uppercase tracking-wider font-semibold text-neutral-700 mt-4 block">{ex.subtitle}</span>
          <p class="text-sm text-neutral-600 leading-relaxed max-w-[55ch] mt-2">{ex.description}</p>
          <a href="#" class="text-[11px] font-sans font-semibold underline underline-offset-4 tracking-wider text-neutral-800 hover:text-black mt-4 block text-right">View More</a>
        </div>
      ))}
    </div>
  </div>
</PageLayout>
