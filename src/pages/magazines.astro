---
import PageLayout from '../layouts/PageLayout.astro';
import { t } from '../data/translations';
const l = t.en;

const magazines = [
  { title: "Astraea Zine", issue: "Issue Eight — Dreamscape", type: "FEATURED: The Fish & Souls of Leavings" },
  { title: "Hush Magazine", issue: "Issue 001 — LOST//FOUND", type: "FEATURED: Souls of Leavings" },
  { title: "Spellbinder Magazine", issue: "Spring 2026", type: "FEATURED: Souls of Leavings" },
  { title: "The Knot Spectrum", issue: "Glimpse 01", type: "FEATURED: Souls of Leavings" },
  { title: "Wildsape Literary Journal", issue: "Ongoing", type: "FEATURED: The Fish" },
  { title: "Onart Magazine", issue: "TBD", type: "FEATURED" },
];
---

<PageLayout title="Magazines" activeSection="magazines" locale="en">
  <div slot="content">
    <div class="px-8 py-16 md:py-24">
      <span class="font-sans text-[10px] tracking-[0.3em] text-[#111111]/50 block mb-6">{l.magazinesTag}</span>
      <h1 class="font-forum text-5xl md:text-7xl lg:text-8xl leading-[0.9] text-[#111111] mb-16">{l.magazineHeading}</h1>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-px bg-black/10">
        {magazines.map((mag) => (
          <div class="bg-[#E3E2DA] p-8 border border-black/10 flex flex-col items-center justify-center min-h-[220px]">
            <span class="font-sans text-[9px] tracking-widest text-[#111111]/40 uppercase text-center">{mag.issue}</span>
            <h2 class="font-forum text-base text-[#111111] mt-4 text-center">{mag.title}</h2>
            <span class="font-sans text-[10px] text-[#111111]/50 mt-2 text-center">{mag.type}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</PageLayout>
