---
import PageLayout from '../layouts/PageLayout.astro';
import { t } from '../data/translations';
const l = t.en;

const magazines = [
  { title: "Astraea Zine", issue: "Issue Eight — Dreamscape", type: "FEATURED: The Fish & Souls of Leavings" },
  { title: "Hush Magazine", issue: "Issue 001 — LOST//FOUND", type: "FEATURED: Souls of Leavings" },
  { title: "Spellbinder Magazine", issue: "Spring 2026", type: "FEATURED: Souls of Leavings" },
  { title: "The Knot Spectrum", issue: "Glimpse 01", type: "FEATURED: Souls of Leavings" },
  { title: "Wildsape Literary Journal", issue: "Ongoing", type: "FEATURED: The Fish" },
  { title: "Onart Magazine", issue: "TBD", type: "FEATURED" },
];
---

<PageLayout title="Magazines" activeSection="publications" locale="en">
  <div slot="content">
    <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
      <span class="type-heading text-[10px] text-[#F0EEE9]/50 block mb-6">{l.magazinesTag}</span>
      <h1 class="type-heading text-4xl md:text-6xl lg:text-8xl leading-[0.9] text-[#F0EEE9] mb-12 md:mb-16">{l.magazineHeading}</h1>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-px md:bg-black/10">
        {magazines.map((mag) => (
          <div class="bg-[#141414] p-6 md:p-8 border border-black/10 flex flex-col items-center justify-center min-h-[200px] md:min-h-[220px] rounded md:rounded-none">
            <span class="type-heading text-[9px] text-[#F0EEE9]/40 text-center">{mag.issue}</span>
            <h2 class="type-subheading text-base text-[#F0EEE9] mt-4 text-center">{mag.title}</h2>
            <span class="type-body text-[10px] text-[#F0EEE9]/50 mt-2 text-center">{mag.type}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</PageLayout>
