---
import PageLayout from '../layouts/PageLayout.astro';
import { t, type LocaleKey } from '../data/translations';

export interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<PageLayout title={locale === "en" ? "Art" : l.siteTitle} activeSection="home" locale={locale}>
  <div slot="content">
    <section class="border-b border-neutral-900/20">
      <div class="py-16 md:py-24 lg:py-32 px-4 sm:px-6 md:px-8">
        <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">{l.artTag}</span>
        <div class="space-y-0">
          <h1 class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-neutral-900">
            {l.selected}
          </h1>
          <div class="flex items-center gap-4 md:gap-8 my-2">
            <div class="h-px flex-1 bg-neutral-900/20" />
            <span class="font-mono text-[10px] tracking-widest text-neutral-500">[001]</span>
          </div>
          <div class="flex">
            <h1 class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-neutral-900">
              {l.works}
            </h1>
            <span class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-outline ml-2 md:ml-4">2026</span>
          </div>
        </div>
        <p class="font-serif italic text-lg md:text-xl lg:text-2xl text-neutral-800 leading-relaxed max-w-[55ch] mt-8 md:mt-10">{l.intro}</p>
        <p class="font-mono text-xs uppercase tracking-widest leading-relaxed text-neutral-600 max-w-[45ch] mt-4 md:mt-6">{l.heroDesc}</p>
      </div>
    </section>
  </div>
</PageLayout>
