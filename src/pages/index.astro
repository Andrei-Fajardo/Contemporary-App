---
import PageLayout from '../layouts/PageLayout.astro';
import ComingSoon from '../components/ComingSoon.astro';
import { t, type LocaleKey } from '../data/translations';
import { soloExhibitions, groupExhibitions, exhibitions, pressItems } from '../data/content';

export interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const pressImages: Record<string, string> = {
  'Astraea Zine': '/media/posters/poster-1.jpg',
  'Hush Magazine': '/media/posters/nana-nyc.jpg',
  'Spellbinder Magazine': '/media/posters/paris-poster.png',
  'Wildsape Literary Journal': '/media/the-fish.png',
  'Itaewon Film Festival': '/media/feature/itaewon-film-fest.jpg',
};

const paintings = [
  {
    image: "/media/the-fish.png",
    title: "The Fish",
    medium: "90CM X 80CM, OIL ON CANVAS",
    year: "2024",
    description:
      "She floats in a half-life, caught between Piscean intuition and the weight of funeral black. The fur is not warmth — it is the silence before the burial. The fish totem carries her through waters both amniotic and grave-cold.",
    contain: true,
  },
  {
    image: "/media/souls-and-leavings.jpg",
    title: "The Souls of Leavings",
    medium: "120CM X 100CM, MIXED MEDIA ON CANVAS",
    year: "2025",
    description:
      "This painting emerged from witnessing the devastation of abandonment and the quiet violence of loss. The female figure appears caught between states — as though waiting for something to leave her, or return. In Kazakh tradition, the departing soul lingers for forty days.",
    contain: true,
  },
];
---

<PageLayout title={locale === "en" ? "Art" : l.siteTitle} activeSection="home" locale={locale}>
  <div slot="content">
    <!-- HOME -->
    <section id="home" class="scroll-mt-24 border-b border-neutral-900/20 min-h-screen hero-parallax">
      <div class="py-16 md:py-24 lg:py-32 px-4 sm:px-6 md:px-8">
        <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">{l.artTag}</span>
        <div class="space-y-0">
          <h1 class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-neutral-900">
            {l.selected}
          </h1>
          <div class="flex items-center gap-4 md:gap-8 my-2">
            <div class="h-px flex-1 bg-neutral-900/20" />
            <span class="font-mono text-[10px] tracking-widest text-neutral-500">[001]</span>
          </div>
          <div class="flex">
            <h1 class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-neutral-900">
              {l.works}
            </h1>
            <span class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-outline ml-2 md:ml-4">2026</span>
          </div>
        </div>
        <p class="font-serif italic text-lg md:text-xl lg:text-2xl text-neutral-800 leading-relaxed max-w-[55ch] mt-8 md:mt-10">{l.intro}</p>
        <p class="font-mono text-xs uppercase tracking-widest leading-relaxed text-neutral-600 max-w-[45ch] mt-4 md:mt-6">{l.heroDesc}</p>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="scroll-mt-24 border-b border-neutral-900/20 min-h-screen">
      <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
        <span class="font-sans text-[10px] tracking-[0.3em] text-[#111111]/50 block mb-6">{l.aboutTag}</span>
        <div class="flex flex-col md:flex-row gap-10 md:gap-12 lg:gap-16">
          <div class="w-full md:w-[45%]">
            <div class="aspect-[3/4] bg-neutral-200 border border-black/10 overflow-clip rounded art-parallax-container">
              <img src="/media/exhibitions/luna-1.jpg" alt="Anna Dauyl Rockswell" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <div class="w-full md:w-[45%] md:ml-auto flex flex-col justify-center">
            <div class="flex items-center gap-4 mb-6 md:mb-8">
              <div class="h-px flex-1 bg-black/10" />
              <span class="font-mono text-[10px] tracking-widest text-[#111111]/40">{l.biography}</span>
            </div>
            <h1 class="font-forum text-3xl md:text-4xl lg:text-5xl leading-[1.1] text-[#111111] mb-6 md:mb-8">NANA (Anna Dauyl Rockswell) — Kazakh multidisciplinary artist based in Seoul.</h1>
            <div class="font-serif text-sm md:text-base text-[#111111]/70 leading-relaxed max-w-[55ch] space-y-4">
              <p>Heavily influenced by a background in writing, dark expressionism, transgressive literature, counterculture movements, and Jungian psychoanalysis, her themes often circle the edges of contrarian art, visceral imagery, feminine experience, mental health interiority, and raw political &amp; social commentary.</p>
              <p>Her works have been exhibited at Senses International Art Fair (Must Museum, Lecce), Contemporary Venice 2026, Hechyeomoyeo Art Festival (New York), KINSHIP × Hechyeomoyeo (Seoul), The Holy Art (London &amp; Paris), DIMO × Verger Gallery, Luna Grande Art, and featured in Astraea Zine, Hush Magazine, Spellbinder Magazine, and Wildsape Literary Journal.</p>
            </div>

            <!-- Artist Statement -->
            <div class="mt-8 pt-6 border-t border-black/10">
              <div class="flex items-center gap-4 mb-4">
                <div class="h-px flex-1 bg-black/10" />
                <span class="font-mono text-[10px] tracking-widest text-[#111111]/40">{l.artistStatement}</span>
              </div>
              <p class="font-serif italic text-sm md:text-base text-[#111111]/70 leading-relaxed max-w-[55ch]">
                My work occupies the threshold between the visceral and the conceptual — where the body becomes a site of memory, loss, and transformation. Drawing from Jungian archetypes and the raw materiality of dark expressionism, I explore how feminine experience is inscribed, erased, and reinscribed across personal and collective histories.
              </p>
            </div>

            <div class="flex gap-12 mt-8 border-t border-black/10 pt-6">
              <div>
                <span class="font-sans text-[9px] tracking-widest text-[#111111]/50 block mb-1">{l.education}</span>
                <p class="font-sans text-[11px] text-[#111111]/70">MFA, Columbia University<br />BA, Yale University</p>
              </div>
              <div>
                <span class="font-sans text-[9px] tracking-widest text-[#111111]/50 block mb-1">{l.grants}</span>
                <p class="font-sans text-[11px] text-[#111111]/70">Andy Warhol Foundation<br />NEA Fellowship</p>
              </div>
            </div>

            <!-- CV Download -->
            <div class="mt-8 pt-6 border-t border-black/10">
              <a href="#" class="group font-sans text-[11px] tracking-widest text-[#111111] underline underline-offset-4 decoration-black/40 hover:decoration-black transition-all w-max">
                <span class="block transition-transform duration-300 ease-out group-hover:translate-x-px">{l.downloadCV}</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ART -->
    <section id="art" class="scroll-mt-24 border-b border-neutral-900/20 min-h-screen">
      <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
        <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(ARTWORK)</span>
        <h1 class="font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-4">
          Paintings
        </h1>
        <p class="font-serif italic text-xl text-neutral-600 max-w-[45ch]">{l.heroDesc}</p>
      </div>

      {paintings.map((p, i) => (
        <div class="border-b border-neutral-900/20 my-32 md:my-64">
          <div class="flex flex-col md:flex-row">
            <div class={`w-full md:w-2/3 ${i % 2 === 1 ? 'md:order-2' : ''} overflow-clip`}>
              <div class="relative group flex items-center justify-center bg-transparent art-parallax-container">
                <img src={p.image} alt={p.title} class={`w-full ${p.contain ? 'h-auto max-h-[80vh] object-contain' : 'h-[50vh] md:h-[65vh] object-cover'}`} loading="lazy" />
              </div>
            </div>
            <div class={`w-full md:w-1/3 ${i % 2 === 1 ? 'md:order-1' : ''} flex flex-col justify-between p-8 md:p-10 art-parallax-text`}>
              <div>
                <div class="flex items-center justify-between mb-6">
                  <span class="font-mono text-[10px] tracking-widest text-neutral-400">{String(i + 1).padStart(3, '0')}</span>
                  <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500">{p.year}</span>
                </div>
                <h2 class="font-sans font-black tracking-tighter uppercase text-3xl md:text-4xl leading-[0.9] text-neutral-900">{p.title}</h2>
                <span class="font-mono text-[9px] tracking-[0.3em] uppercase text-neutral-500 block mt-3">{p.medium}</span>
              </div>
              <p class="font-mono text-xs tracking-wider leading-relaxed text-neutral-600 max-w-[45ch] mt-6">{p.description}</p>
            </div>
          </div>
        </div>
      ))}
    </section>

    <!-- EXHIBITIONS -->
    <section id="exhibitions" class="scroll-mt-24 border-b border-neutral-900/20 min-h-screen">
      <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
        <span class="font-sans text-[10px] tracking-[0.3em] text-[#111111]/50 block mb-6">{l.exhibitionsTag}</span>
        <h1 class="font-forum text-4xl md:text-6xl lg:text-8xl leading-[0.9] text-[#111111] mb-16" set:html={l.exhibitionHistory}></h1>

        <!-- Featured exhibition imagery -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-px bg-black/10 mb-20">
          {exhibitions.slice(0, 6).map((ex, i) => (
            <div class={`overflow-clip art-parallax-container ${i === 0 ? 'col-span-2 row-span-2' : ''}`}>
              <div class={`interactive-image-container ${i === 0 ? 'aspect-[16/10]' : 'aspect-square'}`}>
                <img src={ex.image} alt={ex.title} loading="lazy" class="grayscale hover:grayscale-0 transition-all duration-700" />
              </div>
            </div>
          ))}
        </div>

        <div class="max-w-4xl">
        <!-- Solo Exhibitions -->
        <div class="mb-16">
          <div class="flex items-center gap-4 mb-8">
            <span class="font-sans text-[9px] tracking-widest text-[#111111]/50">{l.soloExhibitions}</span>
            <div class="h-px flex-1 bg-black/10" />
          </div>
          <div class="space-y-6">
            {soloExhibitions.map((ex) => (
              <div class="flex items-baseline gap-4 font-serif text-sm md:text-base text-[#111111]/70">
                <span class="font-mono text-[10px] tracking-wider text-[#111111]/40 shrink-0 w-14">{ex.year}</span>
                <span class="font-serif">—</span>
                <span>
                  <em>{ex.title}</em>, {ex.venue}, {ex.city}{ex.city && ex.country ? ', ' : ''}{ex.country}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Group Exhibitions -->
        <div>
          <div class="flex items-center gap-4 mb-8">
            <span class="font-sans text-[9px] tracking-widest text-[#111111]/50">{l.groupExhibitions}</span>
            <div class="h-px flex-1 bg-black/10" />
          </div>
          <div class="space-y-6">
            {groupExhibitions.map((ex) => (
              <div class="flex items-baseline gap-4 font-serif text-sm md:text-base text-[#111111]/70">
                <span class="font-mono text-[10px] tracking-wider text-[#111111]/40 shrink-0 w-14">{ex.year}</span>
                <span class="font-serif">—</span>
                <span>
                  <em>{ex.title}</em>, {ex.venue}{ex.venue && (ex.city || ex.country) ? ', ' : ''}{ex.city}{ex.city && ex.country ? ', ' : ''}{ex.country}
                </span>
              </div>
            ))}
          </div>
        </div>
        </div>
      </div>
    </section>

    <!-- PUBLICATIONS -->
    <section id="publications" class="scroll-mt-24 border-b border-neutral-900/20 min-h-screen">
      <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20 max-w-4xl">
        <ComingSoon
          label="(PUBLICATIONS &amp; WRITING)"
          heading="Publications &amp; Writing"
          message={l.comingSoonMessage}
          note={l.comingSoonNote}
        />
      </div>
    </section>

    <!-- RESEARCH -->
    <section id="research" class="scroll-mt-24 border-b border-neutral-900/20 min-h-screen">
      <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20 max-w-4xl">
        <ComingSoon
          label="(ACADEMIC RESEARCH)"
          heading="Academic Research"
          message={l.comingSoonMessage}
          note={l.comingSoonNote}
        />
      </div>
    </section>

    <!-- PRESS -->
    <section id="press" class="scroll-mt-24 border-b border-neutral-900/20 min-h-screen">
      <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
        <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(PRESS)</span>
        <h1 class="font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-16">
          Press
        </h1>
        <div class="space-y-16 max-w-5xl">
          {pressItems.map((item, i) => (
            <div class={`flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-8 md:gap-12 items-center border-b border-black/10 pb-16 last:border-b-0`}>
              {pressImages[item.outlet] && (
                <div class="w-full md:w-[40%] overflow-clip art-parallax-container">
                  <div class="interactive-image-container aspect-[3/4]">
                    <img src={pressImages[item.outlet]} alt={item.outlet} loading="lazy" class="grayscale hover:grayscale-0 transition-all duration-700" />
                  </div>
                </div>
              )}
              <div class="w-full md:w-[55%] art-parallax-text">
                <span class="font-mono text-[9px] tracking-widest text-neutral-400 uppercase block mb-3">{item.outlet}</span>
                <p class="font-serif text-base md:text-lg text-neutral-700 leading-relaxed">
                  {item.author}, &ldquo;{item.title},&rdquo; <em>{item.outlet}</em>, {item.date}.
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACTS -->
    <section id="contacts" class="scroll-mt-24 border-b border-neutral-900/20 min-h-screen">
      <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
        <span class="font-sans text-[10px] tracking-[0.3em] text-[#111111]/50 block mb-6">{l.contactTag}</span>
        <h1 class="font-forum text-4xl md:text-6xl lg:text-[9rem] leading-[0.9] text-[#111111] mb-10 md:mb-16">{l.contactHeading}</h1>

        <div class="flex flex-col md:flex-row gap-12 md:gap-16 lg:gap-24">
          <!-- Left Column: Info -->
          <div class="w-full md:w-[35%] space-y-8">
            <div>
              <span class="font-sans text-[9px] tracking-widest text-[#111111]/50 block mb-2">{l.email}</span>
              <a href="mailto:contact@annadauylrockswell.com" class="font-serif text-base md:text-lg text-[#111111] underline underline-offset-4 decoration-black/30 hover:decoration-black transition-all">
                contact@annadauylrockswell.com
              </a>
            </div>
            <div>
              <span class="font-sans text-[9px] tracking-widest text-[#111111]/50 block mb-2">{l.basedIn}</span>
              <p class="font-serif text-base md:text-lg text-[#111111]/70">{l.location}</p>
            </div>
            <div>
              <span class="font-sans text-[9px] tracking-widest text-[#111111]/50 block mb-2">{l.galleryRep}</span>
              <p class="font-serif text-base md:text-lg text-[#111111]/70">Verger Gallery, Seoul<br />Hechyeomoyeo Collective, New York</p>
            </div>
          </div>

          <!-- Right Column: Form -->
          <div class="w-full md:w-[55%]">
            <form class="space-y-0" onsubmit="event.preventDefault(); alert('Sent (demo)');">
              <div class="border-b-2 border-[#111111] py-4 md:py-5">
                <span class="font-sans text-[10px] tracking-widest text-[#111111]/50 block mb-2">{l.nameLabel}</span>
                <input type="text" placeholder={l.namePlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-lg md:text-xl lg:text-2xl text-[#111111]/40 placeholder:text-[#111111]/20 py-1" />
              </div>
              <div class="border-b-2 border-[#111111] py-4 md:py-5">
                <span class="font-sans text-[10px] tracking-widest text-[#111111]/50 block mb-2">{l.emailLabel}</span>
                <input type="email" placeholder={l.emailPlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-lg md:text-xl lg:text-2xl text-[#111111]/40 placeholder:text-[#111111]/20 py-1" />
              </div>
              <div class="border-b-2 border-[#111111] py-4 md:py-5">
                <span class="font-sans text-[10px] tracking-widest text-[#111111]/50 block mb-2">{l.messageLabel}</span>
                <textarea rows="3" placeholder={l.messagePlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-lg md:text-xl lg:text-2xl text-[#111111]/40 placeholder:text-[#111111]/20 py-1 resize-none"></textarea>
              </div>
              <div class="pt-6 text-right">
                <button type="submit" class="group font-sans text-xs uppercase tracking-widest text-[#111111] hover:text-[#111111]/50 font-bold transition-colors cursor-pointer border-none bg-transparent px-4 py-2">
                  <span class="block transition-transform duration-300 ease-out group-hover:translate-x-px">{l.sendMessage}</span>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </div>
</PageLayout>
