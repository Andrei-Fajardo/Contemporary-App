---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import { t, type LocaleKey } from '../data/translations';

export interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<PageLayout title={locale === "en" ? "Art" : l.siteTitle} activeSection="home" locale={locale}>
  <div slot="content">
    <Hero
      artTag={l.artTag}
      selected={l.selected}
      works={l.works}
      intro={l.intro}
      heroDesc={l.heroDesc}
      heroImage="/media/souls-and-leavings.jpg"
      heroImageAlt="The Souls of Leavings — Anna Dauyl Rockswell"
    />
  </div>
</PageLayout>
