---
import PageLayout from '../layouts/PageLayout.astro';
import ArtCard from '../components/ArtCard.astro';
import { t, type LocaleKey } from '../data/translations';

export interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const paintings = [
  {
    slug: "the-fish",
    title: "The Fish",
    year: "2024",
    medium: "OIL ON CANVAS",
    dimensions: "90CM X 80CM",
    imageUrl: "/media/the-fish.png",
    description:
      "She floats in a half-life, caught between Piscean intuition and the weight of funeral black. The fur is not warmth — it is the silence before the burial. The fish totem carries her through waters both amniotic and grave-cold.",
  },
  {
    slug: "the-souls-of-leavings",
    title: "The Souls of Leavings",
    year: "2025",
    medium: "MIXED MEDIA ON CANVAS",
    dimensions: "120CM X 100CM",
    imageUrl: "/media/souls-and-leavings.jpg",
    description:
      "This painting emerged from witnessing the devastation of abandonment and the quiet violence of loss. The female figure appears caught between states — as though waiting for something to leave her, or return. In Kazakh tradition, the departing soul lingers for forty days.",
  },
];
---

<PageLayout title={locale === "en" ? "Art" : l.siteTitle} activeSection="art" locale={locale}>
  <div slot="content">
    <div class="max-w-7xl mx-auto px-6 sm:px-12 pt-16 md:pt-24 pb-4">
      <span class="font-sans text-[10px] tracking-[0.3em] text-[#111111]/50">{l.artTag}</span>
    </div>

    {paintings.map((painting) => (
      <ArtCard
        title={painting.title}
        year={painting.year}
        medium={painting.medium}
        dimensions={painting.dimensions}
        slug={painting.slug}
        imageUrl={painting.imageUrl}
      >
        {painting.description}
      </ArtCard>
    ))}
  </div>
</PageLayout>
