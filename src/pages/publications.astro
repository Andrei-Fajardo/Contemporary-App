---
import PageLayout from '../layouts/PageLayout.astro';
import { publications } from '../data/content';
---

<PageLayout title="Publications" activeSection="publications" locale="en">
  <div slot="content">
    <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
      <span class="font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(PUBLICATIONS &amp; WRITING)</span>
      <h1 class="font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-12 md:mb-16">
        Publications<br />&amp; Writing
      </h1>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-px md:bg-neutral-900/20">
        {publications.map((pub) => (
          <div class="bg-[#F0EEE9] p-6 md:p-8 border border-neutral-900/20 rounded md:rounded-none">
            <span class="font-mono text-[9px] tracking-widest text-neutral-500 uppercase block mb-3">{pub.type}</span>
            <h2 class="font-sans font-black tracking-tighter uppercase text-xl text-neutral-900">{pub.title}</h2>
            <span class="font-mono text-[10px] text-neutral-500 mt-2 block">{pub.issue}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</PageLayout>
