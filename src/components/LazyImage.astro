---
interface Props {
  src: string;
  alt: string;
  class?: string;
  aspectRatio?: string;
  parallaxSpeed?: number;
  contain?: boolean;
  eager?: boolean;
  depthTarget?: boolean;
}

const {
  src,
  alt,
  class: className = "",
  aspectRatio = "4 / 5",
  parallaxSpeed,
  contain = false,
  eager = false,
  depthTarget = true,
} = Astro.props;
---

<div
  class:list={[
    "lazy-media",
    depthTarget && "depth-target",
    contain && "lazy-media--contain lazy-media--fit",
    eager && "is-loaded",
  ]}
  style={contain ? undefined : `--lazy-aspect: ${aspectRatio}`}
>
  {eager ? (
    <img
      src={src}
      alt={alt}
      class={className}
      data-parallax-speed={parallaxSpeed}
      decoding="async"
      fetchpriority="high"
    />
  ) : (
    <img
      data-src={src}
      alt={alt}
      class={className}
      data-parallax-speed={parallaxSpeed}
      decoding="async"
      loading="lazy"
    />
  )}
</div>
