---
import ExhibitionCarousel from './ExhibitionCarousel.astro';
import type { ExhibitionEntry } from '../data/content';

interface Props {
  entries: ExhibitionEntry[];
  expandLabel?: string;
}

const { entries, expandLabel = 'View materials' } = Astro.props;
---

<div class="exhibition-accordion editorial-divider-list">
  {entries.map((entry) => (
    <details class="exhibition-accordion__item scroll-reveal group" data-category={entry.category}>
      <summary class="exhibition-accordion__summary" aria-label={`${entry.title} — ${expandLabel}`}>
        <span class="exhibition-accordion__year">{entry.year}</span>
        <span class="exhibition-accordion__title">{entry.title}</span>
        <span class="exhibition-accordion__meta">{entry.gallery} · {entry.place}</span>
        {entry.kind === 'museum' && (
          <span class="exhibition-accordion__badge">Museum</span>
        )}
        <span class="exhibition-accordion__action" aria-hidden="true">
          <span class="exhibition-accordion__action-label">{expandLabel}</span>
          <span class="exhibition-accordion__chevron">+</span>
        </span>
      </summary>
      <div class="exhibition-accordion__panel">
        {entry.note && (
          <p class="content-prose text-ink-60 mb-6">{entry.note}</p>
        )}
        {entry.links && (
          <dl class="exhibition-accordion__links">
            {entry.links.website && (
              <div class="exhibition-accordion__link-row">
                <dt>Website</dt>
                <dd>
                  <a href={entry.links.website} target="_blank" rel="noopener noreferrer" class="exhibition-accordion__link">
                    {entry.links.website.replace(/^https?:\/\/(www\.)?/, "").replace(/\/$/, "")}
                  </a>
                </dd>
              </div>
            )}
            {(entry.links.magazine || entry.links.magazineLabel) && (
              <div class="exhibition-accordion__link-row">
                <dt>Magazine</dt>
                <dd>
                  {entry.links.magazine ? (
                    <a href={entry.links.magazine} target="_blank" rel="noopener noreferrer" class="exhibition-accordion__link">
                      {entry.links.magazineLabel ?? entry.links.magazine.replace(/^https?:\/\/(www\.)?/, "").replace(/\/$/, "")}
                    </a>
                  ) : (
                    <span class="content-prose text-ink-75">{entry.links.magazineLabel}</span>
                  )}
                </dd>
              </div>
            )}
            {entry.links.issue && (
              <div class="exhibition-accordion__link-row">
                <dt>Issue</dt>
                <dd><span class="content-prose text-ink-75">{entry.links.issue}</span></dd>
              </div>
            )}
            {entry.links.artwork && (
              <div class="exhibition-accordion__link-row">
                <dt>Artwork</dt>
                <dd><span class="content-prose text-ink-75">{entry.links.artwork}</span></dd>
              </div>
            )}
          </dl>
        )}
        {entry.images.length > 0 && (
          <ExhibitionCarousel
            id={entry.id}
            images={entry.images}
            alt={entry.title}
          />
        )}
        {entry.kind && entry.category !== 'magazine' && (
          <span class="exhibition-accordion__kind">{entry.kind}</span>
        )}
      </div>
    </details>
  ))}
</div>

<style>
  .exhibition-accordion__item {
    background: transparent;
    overflow: visible;
  }

  .exhibition-accordion__panel {
    padding: 0 0 1.5rem 4.5rem;
    overflow: hidden;
    height: 0;
    opacity: 0;
    will-change: height, opacity;
  }

  .exhibition-accordion__summary {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.2rem 1.25rem;
    align-items: center;
    margin-inline: -0.75rem;
    padding: 1.25rem 0.75rem;
    border: 1px solid transparent;
    border-radius: var(--radius-default);
    cursor: pointer;
    list-style: none;
    background: transparent;
    transition:
      box-shadow 0.35s var(--ease-editorial),
      border-color 0.35s var(--ease-editorial);
  }

  .exhibition-accordion__summary:hover {
    box-shadow: inset 3px 0 0 var(--ink-35);
  }

  .exhibition-accordion__summary:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  .exhibition-accordion__item.is-expanded .exhibition-accordion__summary {
    box-shadow: inset 3px 0 0 var(--ink);
  }

  .exhibition-accordion__item.is-expanded .exhibition-accordion__summary:hover {
    box-shadow: inset 3px 0 0 var(--ink);
  }

  .exhibition-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .exhibition-accordion__year {
    grid-row: 1 / 3;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--ink-45);
    transition: color 0.3s var(--ease-editorial);
  }

  .exhibition-accordion__summary:hover .exhibition-accordion__year,
  .exhibition-accordion__item.is-expanded .exhibition-accordion__year {
    color: var(--ink-70);
  }

  .exhibition-accordion__title {
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 1.5vw, 1.375rem);
    color: var(--ink);
    line-height: 1.2;
    transition: color 0.3s var(--ease-editorial);
  }

  .exhibition-accordion__summary:hover .exhibition-accordion__title {
    color: var(--ink);
  }

  .exhibition-accordion__meta {
    grid-column: 2;
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 1vw, 1.0625rem);
    color: var(--ink-55);
    font-style: italic;
    transition: color 0.3s var(--ease-editorial);
  }

  .exhibition-accordion__summary:hover .exhibition-accordion__meta {
    color: var(--ink-65);
  }

  .exhibition-accordion__action {
    grid-row: 1 / 3;
    grid-column: 3;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    justify-self: end;
    flex-shrink: 0;
  }

  .exhibition-accordion__action-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-45);
    white-space: nowrap;
    transition: color 0.3s var(--ease-editorial);
  }

  .exhibition-accordion__summary:hover .exhibition-accordion__action-label,
  .exhibition-accordion__item.is-expanded .exhibition-accordion__action-label {
    color: var(--ink-75);
  }

  .exhibition-accordion__chevron {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    line-height: 1;
    color: var(--ink-35);
    display: inline-block;
    transform-origin: center;
    flex-shrink: 0;
  }

  .exhibition-accordion__summary:hover .exhibition-accordion__chevron {
    color: var(--ink);
  }

  .exhibition-accordion__item.is-expanded .exhibition-accordion__chevron {
    color: var(--ink);
  }

  .exhibition-accordion__kind {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-45);
  }

  .exhibition-accordion__badge {
    grid-column: 2;
    justify-self: start;
    font-size: 0.5625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-55);
    border: 1px solid var(--border-subtle);
    padding: 0.15rem 0.45rem;
    border-radius: var(--radius-lang-btn);
    transition:
      border-color 0.3s var(--ease-editorial),
      background 0.3s var(--ease-editorial);
  }

  .exhibition-accordion__summary:hover .exhibition-accordion__badge {
    border-color: var(--border-section);
  }

  .exhibition-accordion__item.is-filtered-out {
    display: none;
  }

  .exhibition-accordion__links {
    display: grid;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .exhibition-accordion__link-row {
    display: grid;
    grid-template-columns: minmax(5rem, 7rem) 1fr;
    gap: 0.75rem 1.25rem;
    align-items: baseline;
  }

  .exhibition-accordion__link-row dt {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-45);
  }

  .exhibition-accordion__link {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 1vw, 1.0625rem);
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s ease, color 0.25s ease;
    word-break: break-word;
  }

  .exhibition-accordion__link:hover {
    border-bottom-color: var(--ink-45);
    color: var(--ink-75);
  }

  @media (max-width: 1023px) {
    .exhibition-accordion__panel {
      padding: 0 0 0.875rem 0;
    }

    .exhibition-accordion__summary {
      grid-template-columns: 2.75rem 1fr auto;
      gap: 0.15rem 0.75rem;
      margin-inline: 0;
      padding: 0.875rem 0.25rem;
    }

    .exhibition-accordion__year {
      font-size: 0.6875rem;
    }

    .exhibition-accordion__title {
      font-size: 1.0625rem;
    }

    .exhibition-accordion__meta {
      font-size: 0.875rem;
    }

    .exhibition-accordion__action-label {
      font-size: 0.625rem;
      letter-spacing: 0.1em;
    }

    .exhibition-accordion__chevron {
      font-size: 1.125rem;
    }
  }
</style>

<script>
  import { initExhibitionAccordion } from "../scripts/motion/exhibition-accordion";
  initExhibitionAccordion();
  document.addEventListener("astro:page-load", initExhibitionAccordion);
</script>
