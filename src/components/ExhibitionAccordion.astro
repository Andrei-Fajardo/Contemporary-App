---
import LazyImage from './LazyImage.astro';
import type { ExhibitionEntry } from '../data/content';

interface Props {
  entries: ExhibitionEntry[];
  expandLabel?: string;
}

const { entries, expandLabel = 'View materials' } = Astro.props;
---

<div class="exhibition-accordion space-y-2">
  {entries.map((entry, i) => (
    <details class="exhibition-accordion__item scroll-reveal group">
      <summary class="exhibition-accordion__summary">
        <span class="exhibition-accordion__year">{entry.year}</span>
        <span class="exhibition-accordion__title">{entry.title}</span>
        <span class="exhibition-accordion__meta">{entry.gallery} · {entry.place}</span>
        {entry.kind === 'museum' && (
          <span class="exhibition-accordion__badge">Museum</span>
        )}
        <span class="exhibition-accordion__chevron" aria-hidden="true">+</span>
      </summary>
      <div class="exhibition-accordion__panel">
        {entry.note && (
          <p class="content-prose text-[#111]/60 mb-4">{entry.note}</p>
        )}
        {entry.images.length > 0 && (
          <div class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-3">
            {entry.images.map((src) => (
              <div class="overflow-clip rounded-sm">
                <LazyImage
                  src={src}
                  alt={entry.title}
                  aspectRatio="4 / 3"
                  parallaxSpeed={0}
                  depthTarget={false}
                  class="grayscale hover:grayscale-0 transition-[filter] duration-500"
                />
              </div>
            ))}
          </div>
        )}
        <span class="exhibition-accordion__kind">{entry.kind}</span>
      </div>
    </details>
  ))}
</div>

<style>
  .exhibition-accordion__item {
    border: 1px solid rgba(17, 17, 17, 0.1);
    border-radius: 0.25rem;
    background: rgba(255, 255, 255, 0.35);
    overflow: clip;
  }

  .exhibition-accordion__summary {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.15rem 1rem;
    align-items: center;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
  }

  .exhibition-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .exhibition-accordion__year {
    grid-row: 1 / 3;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(17, 17, 17, 0.45);
  }

  .exhibition-accordion__title {
    font-family: var(--font-forum);
    font-size: clamp(1.125rem, 1.5vw, 1.375rem);
    color: #111;
    line-height: 1.2;
  }

  .exhibition-accordion__meta {
    grid-column: 2;
    font-family: var(--font-serif);
    font-size: clamp(0.9375rem, 1vw, 1.0625rem);
    color: rgba(17, 17, 17, 0.55);
    font-style: italic;
  }

  .exhibition-accordion__chevron {
    grid-row: 1 / 3;
    grid-column: 3;
    font-family: var(--font-forum);
    font-size: 1.25rem;
    line-height: 1;
    color: rgba(17, 17, 17, 0.35);
    transition: transform 0.25s ease;
  }

  .exhibition-accordion__item[open] .exhibition-accordion__chevron {
    transform: rotate(45deg);
  }

  .exhibition-accordion__panel {
    padding: 0 1.25rem 1.25rem;
    border-top: 1px solid rgba(17, 17, 17, 0.06);
  }

  .exhibition-accordion__kind {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(17, 17, 17, 0.4);
  }

  .exhibition-accordion__badge {
    grid-column: 2;
    justify-self: start;
    font-size: 0.5625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(17, 17, 17, 0.55);
    border: 1px solid rgba(17, 17, 17, 0.15);
    padding: 0.15rem 0.45rem;
    border-radius: 0.15rem;
  }
</style>
