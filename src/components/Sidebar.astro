---
import { t, type LocaleKey } from '../data/translations';

export interface Props {
  activeSection: string;
  locale?: LocaleKey;
}

const { activeSection, locale = 'en' } = Astro.props;
const l = t[locale];

const menuItems: { key: string; href: string }[] = [
  { key: "home", href: locale === 'en' ? '/' : `/${locale}` },
  { key: "about", href: `${locale === 'en' ? '' : '/' + locale}/about` },
  { key: "art", href: `${locale === 'en' ? '' : '/' + locale}/art` },
  { key: "exhibitions", href: `${locale === 'en' ? '' : '/' + locale}/exhibitions` },
  { key: "publications", href: `${locale === 'en' ? '' : '/' + locale}/publications` },
  { key: "research", href: `${locale === 'en' ? '' : '/' + locale}/research` },
  { key: "press", href: `${locale === 'en' ? '' : '/' + locale}/press` },
  { key: "contacts", href: `${locale === 'en' ? '' : '/' + locale}/contacts` },
];
---

<aside class="w-[18vw] min-w-[200px] h-screen fixed left-0 top-0 border-r border-black/10 bg-[#F0EEE9] z-40 flex-col px-6 hidden lg:flex">
  <div class="pt-12" transition:persist="sidebar-brand">
    <h1 class="font-forum text-2xl text-[#111] leading-none tracking-wide" transition:persist="sidebar-name">Anna Dauyl<br />Rockswell</h1>
    <span class="font-sans text-[9px] uppercase tracking-[0.25em] text-[#555]/70 mt-2 block" transition:persist="sidebar-subtitle">{l.subtitle}</span>
  </div>

  <nav class="mt-10">
    {menuItems.map((item) => {
      const isActive = activeSection === item.key;
      const navKey = item.key as keyof typeof l.nav;
      return (
        <a
            href={item.href}
            class={`group relative font-sans text-[11px] uppercase tracking-wider py-2 block font-medium transition-colors duration-300 ${
              isActive ? 'text-[#111]' : 'text-[#555]/70 hover:text-[#111]'
            }`}
          >
            {l.nav[navKey]}
          <!-- Underline glide — left-origin scale line -->
          <span
            class={`absolute bottom-0 left-0 w-full h-[1px] bg-neutral-400 origin-left transition-transform duration-500 ease-out ${
              isActive ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'
            }`}
          />
        </a>
      );
    })}
  </nav>

  <div class="mt-auto pb-12">
    <span class="font-sans text-[8px] uppercase tracking-[0.25em] text-[#555]/50 block mb-1">{l.basedIn}</span>
    <span class="font-sans text-[11px] text-[#555]/80 font-medium tracking-wide">{l.location}</span>
  </div>
</aside>
