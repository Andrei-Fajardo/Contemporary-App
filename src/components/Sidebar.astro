---
import { t, type LocaleKey } from '../data/translations';

export interface Props {
  activeSection: string;
  locale?: LocaleKey;
}

const { activeSection, locale = 'en' } = Astro.props;
const l = t[locale];

const menuItems: { key: string; href: string }[] = [
  { key: "art", href: locale === 'en' ? '/' : `/${locale}` },
  { key: "exhibitions", href: `${locale === 'en' ? '' : '/' + locale}/exhibitions` },
  { key: "feature", href: `${locale === 'en' ? '' : '/' + locale}/feature` },
  { key: "virtual", href: `${locale === 'en' ? '' : '/' + locale}/virtual-exhibitions` },
  { key: "publications", href: `${locale === 'en' ? '' : '/' + locale}/publications-and-writing` },
  { key: "magazines", href: `${locale === 'en' ? '' : '/' + locale}/magazines` },
  { key: "academic", href: `${locale === 'en' ? '' : '/' + locale}/academic-research` },
  { key: "press", href: `${locale === 'en' ? '' : '/' + locale}/press` },
  { key: "contact", href: `${locale === 'en' ? '' : '/' + locale}/contact` },
  { key: "about", href: `${locale === 'en' ? '' : '/' + locale}/about` },
];
---

<aside class="w-[18vw] min-w-[200px] h-screen fixed left-0 top-0 border-r border-black/10 bg-[#E3E2DA] z-40 flex flex-col px-6">
  <div class="pt-12">
    <h1 class="font-forum text-2xl text-[#111111] leading-none tracking-wide">Anna Dauyl<br />Rockswell</h1>
    <span class="font-sans text-[9px] uppercase tracking-[0.25em] text-[#111111]/50 mt-2 block">{l.subtitle}</span>
  </div>

  <nav class="mt-10">
    {menuItems.map((item) => {
      const isActive = activeSection === item.key;
      const navKey = item.key as keyof typeof l.nav;
      return (
        <a
          href={item.href}
          class={`group relative font-sans text-[11px] uppercase tracking-wider py-2 block font-medium transition-colors duration-300 ${
            isActive ? 'text-[#111111]' : 'text-[#111111]/50 hover:text-[#111111]'
          }`}
        >
          {l.nav[navKey]}
          <!-- Underline glide — left-origin scale line -->
          <span
            class={`absolute bottom-0 left-0 w-full h-[1px] bg-neutral-900 origin-left transition-transform duration-500 ease-out ${
              isActive ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'
            }`}
          />
        </a>
      );
    })}
  </nav>

  <div class="mt-auto pb-12">
    <span class="font-sans text-[8px] uppercase tracking-[0.25em] text-[#111111]/40 block mb-1">{l.basedIn}</span>
    <span class="font-sans text-[11px] text-[#111111]/70 font-medium tracking-wide">{l.location}</span>
  </div>
</aside>
