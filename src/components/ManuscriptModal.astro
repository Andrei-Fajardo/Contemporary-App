---
import { manuscriptPages, manuscriptMeta } from '../data/manuscript';
import { t, type LocaleKey } from '../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
const pageCount = manuscriptPages.length;
---

<div
  class="manuscript-modal"
  id="manuscript-modal"
  role="presentation"
  hidden
  aria-hidden="true"
>
  <div class="manuscript-modal__backdrop" data-manuscript-close tabindex="-1"></div>

  <div
    class="manuscript-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="manuscript-modal-title"
  >
    <header class="manuscript-modal__header">
      <p class="manuscript-modal__eyebrow" id="manuscript-modal-title">{l.manuscriptHeading}</p>
    </header>

    <div
      class="manuscript-book manuscript-book--modal"
      data-manuscript-book
      data-page-count={pageCount}
      data-manuscript-layout="double"
    >
      <div class="manuscript-modal__stage" data-manuscript-stage>
        <button
          type="button"
          class="manuscript-book__nav manuscript-book__nav--side manuscript-book__nav--prev"
          data-manuscript-prev
          aria-label={l.manuscriptPrev}
        >
          <svg class="manuscript-book__nav-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>

        <div class="manuscript-book__stage-body">
          <div class="manuscript-book__viewport" data-manuscript-viewport>
            <div class="manuscript-book__drag-hints" aria-hidden="true">
              <span class="manuscript-book__drag-hint manuscript-book__drag-hint--tr"></span>
              <span class="manuscript-book__drag-hint manuscript-book__drag-hint--br"></span>
            </div>
            <div class="manuscript-flipbook flipbook" data-manuscript-flipbook>
              <div class="hard manuscript-book__cover manuscript-book__cover--blank" aria-hidden="true"></div>
              {manuscriptPages.flatMap((src, index) => [
                <div
                  class="manuscript-book__page manuscript-book__page--half manuscript-book__page--left"
                  data-spread-index={index}
                >
                  <img
                    src={src}
                    alt={`${manuscriptMeta.title} — spread ${index + 1}`}
                    class="manuscript-book__spread-img manuscript-book__spread-img--left"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    fetchpriority={index === 0 ? 'high' : 'auto'}
                    decoding="async"
                    draggable="false"
                    data-lightbox-ignore
                  />
                </div>,
                <div
                  class="manuscript-book__page manuscript-book__page--half manuscript-book__page--right"
                  aria-hidden="true"
                >
                  <img
                    src={src}
                    alt=""
                    class="manuscript-book__spread-img manuscript-book__spread-img--right"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                    draggable="false"
                    data-lightbox-ignore
                  />
                </div>,
              ])}
            </div>
          </div>
        </div>

        <button
          type="button"
          class="manuscript-book__nav manuscript-book__nav--side manuscript-book__nav--next"
          data-manuscript-next
          aria-label={l.manuscriptNext}
        >
          <svg class="manuscript-book__nav-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>

        <div class="manuscript-book__chrome" aria-live="polite">
          <span class="manuscript-book__indicator" data-manuscript-indicator>
            1 / {pageCount}
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="manuscript-modal__chrome" aria-hidden="false">
    <button
      type="button"
      class="manuscript-modal__close-viewport"
      data-manuscript-close
      aria-label="Close"
    >
      <svg class="manuscript-modal__close-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</div>

<script>
  import { initManuscriptModal } from '../scripts/manuscript-modal';

  initManuscriptModal();
  document.addEventListener('astro:page-load', initManuscriptModal);
</script>
