---
import { t, type LocaleKey } from '../data/translations';
import { siteCopy } from '../data/site-copy';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
const homePath = locale === 'en' ? '/' : `/${locale}`;

const navLinks = [
  { key: 'about', label: l.nav.about },
  { key: 'art', label: l.nav.art },
  { key: 'exhibitions', label: l.nav.exhibitions },
  { key: 'contacts', label: l.nav.contacts },
] as const;
---

<footer class="mag-footer mag-shell">
  <div class="mag-footer__grid">
    <div>
      <p class="mag-footer__brand">{l.heroFirstName} {l.heroLastName}</p>
      <p class="mag-footer__tagline">{l.heroMotto}</p>
    </div>

    <nav aria-label={l.footerNavigate}>
      <p class="mag-footer__col-title">{l.footerNavigate}</p>
      <ul class="mag-footer__links">
        {navLinks.map((item) => (
          <li>
            <a href={`${homePath}#${item.key}`} data-nav-key={item.key}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div>
      <p class="mag-footer__col-title">{l.footerConnect}</p>
      <ul class="mag-footer__links">
        <li><a href="mailto:contact@annadauylrockswell.com">contact@annadauylrockswell.com</a></li>
        <li><a href="https://instagram.com/rockswellnana" target="_blank" rel="noopener noreferrer">@rockswellnana</a></li>
        {siteCopy.licenses.map((license) => (
          <li><a href={license.href} target="_blank" rel="noopener noreferrer">{license.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="mag-footer__bottom">
    <a href={`${homePath}#about`} class="mag-section-header__eyebrow" data-nav-key="about" style="text-decoration: none;">{l.footerBackToTop}</a>
    <p class="mag-footer__copy">{l.copyright}</p>
  </div>
</footer>
