---
import { t, type LocaleKey } from '../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<footer class="site-footer section-shell py-12 md:py-14 border-t border-subtle">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5 text-sm font-body text-ink-55">
    <a href="mailto:contact@annadauylrockswell.com" class="hover:text-ink transition-colors underline underline-offset-4 decoration-black/20">
      contact@annadauylrockswell.com
    </a>
    <a href="https://instagram.com/annadauylrockswell" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors underline underline-offset-4 decoration-black/20">
      @annadauylrockswell
    </a>
  </div>
  <p class="text-[10px] font-mono text-ink-35 mt-10 tracking-wider">{l.copyright}</p>
</footer>
