---
import { t, type LocaleKey } from '../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<footer class="section-shell py-10 md:py-12">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-sm font-sans text-[#111]/55">
    <a href="mailto:contact@annadauylrockswell.com" class="hover:text-[#111] transition-colors underline underline-offset-4 decoration-black/20">
      contact@annadauylrockswell.com
    </a>
    <a href="https://instagram.com/annadauylrockswell" target="_blank" rel="noopener noreferrer" class="hover:text-[#111] transition-colors underline underline-offset-4 decoration-black/20">
      @annadauylrockswell
    </a>
  </div>
  <p class="text-[10px] font-sans text-[#111]/35 mt-8 tracking-wider">{l.copyright}</p>
</footer>
