---
import { t, type LocaleKey } from '../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="home" class="hero-section hero-about-layer scroll-section">
  <div class="hero-about-layer__inner section-shell section-shell--wide">
    <div class="hero-editorial__copy hero-about-layer__name">
      <div class="scroll-reveal hero-editorial__name-block">
        <h1 class="hero-editorial__name hero-editorial__name--cursive">
          <span class="hero-editorial__name-line">{l.heroFirstName}</span>
          <span class="hero-editorial__surname">{l.heroLastName}</span>
        </h1>
      </div>

      <p class="scroll-reveal hero-editorial__roles editorial-meta">{l.heroRoles}</p>
    </div>
  </div>
  <hr class="hero-about-layer__rule scroll-reveal" />
</section>
