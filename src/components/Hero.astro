---
import { t, type LocaleKey } from '../data/translations';
import { exhibitionEntries } from '../data/content';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
const homePath = locale === 'en' ? '/' : `/${locale}`;
const exhibitionCount = exhibitionEntries.length;
---

<section id="home" class="hero-section overload-hero scroll-section visceral-hero">
  <div class="section-shell section-shell--wide">
    <div class="overload-hero__grid">
      <div class="overload-hero__copy">
        <p class="overload-hero__tagline section-eyebrow section-eyebrow--blood">{l.heroTagline}</p>

        <h1 class="overload-hero__title">
          <span class="overload-hero__title-script font-handwriting">{l.heroFirstName}</span>
          <span class="overload-hero__title-serif">{l.heroLastName}</span>
        </h1>

        <p class="overload-hero__roles">{l.heroRoles}</p>

        <p class="overload-hero__motto">
          {l.heroMottoLead}<em>{l.heroMottoEmphasis}</em>
        </p>

        <div class="overload-hero__actions">
          <a href={`${homePath}#art`} data-nav-key="art" class="overload-btn overload-btn--primary">
            {l.heroCtaArt}
          </a>
          <a href={`${homePath}#contacts`} data-nav-key="contacts" class="overload-btn overload-btn--ghost">
            {l.heroCtaContact}
          </a>
        </div>

        <dl class="overload-hero__stats">
          <div class="overload-hero__stat">
            <dt>{l.heroStatExhibitions}</dt>
            <dd>{exhibitionCount}+</dd>
          </div>
          <div class="overload-hero__stat">
            <dt>{l.heroStatLocations}</dt>
            <dd>{l.location}</dd>
          </div>
          <div class="overload-hero__stat">
            <dt>{l.heroStatDisciplines}</dt>
            <dd>{l.heroStatDisciplinesValue}</dd>
          </div>
        </dl>
      </div>

      <div class="overload-hero__visual scroll-reveal">
        <figure class="overload-hero__frame">
          <img
            src="/media/souls-and-leavings.jpg"
            alt="Souls & Leavings — mixed media on canvas"
            width="600"
            height="750"
            fetchpriority="high"
            decoding="async"
          />
          <figcaption>{l.heroFeaturedCaption}</figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>
