---
import { t, type LocaleKey } from '../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="home" class="hero-section hero-chaos scroll-section">
  <div class="hero-editorial hero-chaos__inner">
    <figure class="hero-chaos__visual scroll-reveal" aria-label="Anna Dauyl Rockswell — visceral artwork">
      <img
        src="/media/from-utero-body.png"
        alt="Visceral body horror artwork — hands and anatomical fibers"
        class="gothic-hero-art"
        loading="eager"
        decoding="async"
        draggable="false"
      />
    </figure>

    <div class="hero-editorial__copy">
      <div class="scroll-reveal hero-editorial__name-block">
        <h1 class="hero-editorial__name hero-editorial__name--cursive">
          <span class="hero-editorial__name-line">{l.heroFirstName}</span>
          <span class="hero-editorial__surname">{l.heroLastName}</span>
        </h1>
      </div>

      <p class="scroll-reveal hero-editorial__roles">{l.heroRoles}</p>
    </div>
  </div>
</section>
