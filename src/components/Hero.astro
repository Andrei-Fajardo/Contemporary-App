---
import { t, type LocaleKey } from '../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
const heroNameParts = l.heroFirstName.trim().split(/\s+/);
const heroGivenName = heroNameParts[0] ?? l.heroFirstName;
const heroMiddleName = heroNameParts.slice(1).join(' ');
---

<section id="home" class="hero-section hero-about-layer magazine-cover scroll-section">
  <div class="hero-about-layer__inner section-shell section-shell--wide">
    <div class="hero-about-layer__cluster">
      <div class="hero-about-layer__art" data-headshot aria-hidden="true">
        <img
          src="/media/anna header 2.png"
          alt="Anna Dauyl Rockswell"
          class="hero-about-layer__art-img"
          loading="eager"
          decoding="async"
          draggable="false"
          data-lightbox-ignore
        />
      </div>

      <div
        class="hero-editorial__copy hero-about-layer__name hero-name-group group relative cursor-pointer"
        tabindex="0"
      >
        <div class="magazine-masthead hero-name-hover-pill" aria-hidden="true">
          <span class="magazine-masthead__issue">Portfolio · 2026</span>
          <span class="type-magazine-masthead">{l.heroTagline}</span>
          <span class="magazine-star" aria-hidden="true"></span>
        </div>

        <h1 class="hero-about-layer__heading scroll-reveal">
          <span class="hero-name__first">
            <span class="hero-name__line">{heroGivenName}</span>
            {heroMiddleName && <span class="hero-name__line">{heroMiddleName}</span>}
          </span>
          <span class="hero-name__last">{l.heroLastName}</span>
        </h1>

        <p class="hero-about-layer__roles scroll-reveal">{l.heroRoles}</p>
        <p class="magazine-cover__motto scroll-reveal hero-editorial-only">{l.heroMotto}</p>
      </div>

      <div class="hero-name__last-mobile" aria-hidden="true">{l.heroLastName}</div>
    </div>
  </div>

  <hr class="magazine-rule-crimson magazine-rule-crimson--short scroll-reveal hero-editorial-only" />
  <hr class="hero-about-layer__rule scroll-reveal" />
</section>
