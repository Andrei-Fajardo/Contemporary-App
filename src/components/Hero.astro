---
import { t, type LocaleKey } from '../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const [anna, ...restFirst] = l.heroFirstName.split(" ");
const restOfFirst = restFirst.join(" ");
---

<section id="home" class="hero-section hero-chaos scroll-section">
  <div class="chaos-splashes" aria-hidden="true">
    <span class="chaos-splash chaos-splash--1" data-petal="1"></span>
    <span class="chaos-splash chaos-splash--2" data-petal="2"></span>
    <span class="chaos-splash chaos-splash--3" data-petal="3"></span>
    <span class="chaos-splash chaos-splash--4" data-petal="4"></span>
    <span class="chaos-splash chaos-splash--5" data-petal="5"></span>
    <span class="chaos-splash chaos-splash--6" data-petal="6"></span>
    <span class="chaos-splash chaos-splash--7" data-petal="7"></span>
  </div>

  <div class="hero-editorial hero-chaos__inner">
    <div class="hero-editorial__copy">
      <p class="scroll-reveal hero-editorial__tagline section-eyebrow--blood">{l.heroTagline}</p>

      <div class="scroll-reveal hero-editorial__name-block">
        <h1 class="hero-editorial__name">
          <span class="hero-editorial__anna">{anna}</span>{restOfFirst ? ` ${restOfFirst}` : ""}
        </h1>
        <p class="hero-editorial__surname">{l.heroLastName}</p>
      </div>

      <p class="scroll-reveal hero-editorial__roles">{l.heroRoles}</p>

      <p class="scroll-reveal hero-editorial__motto">
        <span class="hero-editorial__pipe" aria-hidden="true">|</span>
        <span class="chaos-strike">{l.heroMotto}</span>
      </p>

      <p class="scroll-reveal hero-editorial__based">{l.heroBasedIn}</p>

      <p class="scroll-reveal hero-editorial__desc content-prose text-ink-45 text-sm">{l.heroDesc}</p>
    </div>

    <aside class="hero-chaos__aside scroll-reveal" aria-label="Artist motto">
      <blockquote class="hero-chaos__aside-quote">
        "Live or die, but don't poison everything."
      </blockquote>
      <cite class="hero-chaos__aside-cite">— Anne Sexton</cite>
    </aside>
  </div>
</section>

<script is:inline>
  (function () {
    var PETALS = [
      /* Left cluster */
      { sel: ".chaos-splash--1", ox: 0.04, oy: 0.12, ax: 120, ay: 70, rot: -18, rs: 10, sp: 0.42, ph: 0 },
      { sel: ".chaos-splash--2", ox: 0.08, oy: 0.28, ax: 95, ay: 55, rot: 32, rs: 14, sp: 0.35, ph: 1.4 },
      { sel: ".chaos-splash--3", ox: 0.32, oy: 0.44, ax: 75, ay: 90, rot: -42, rs: 18, sp: 0.55, ph: 2.8 },
      /* Right cluster — around quote box */
      { sel: ".chaos-splash--4", ox: 0.68, oy: 0.05, ax: 85, ay: 60, rot: -12, rs: 12, sp: 0.38, ph: 0.6 },
      { sel: ".chaos-splash--5", ox: 0.82, oy: 0.22, ax: 70, ay: 50, rot: 24, rs: 16, sp: 0.48, ph: 2.1 },
      { sel: ".chaos-splash--6", ox: 0.72, oy: 0.48, ax: 90, ay: 65, rot: -28, rs: 11, sp: 0.33, ph: 3.5 },
      { sel: ".chaos-splash--7", ox: 0.86, oy: 0.62, ax: 55, ay: 45, rot: 18, rs: 9, sp: 0.52, ph: 4.2 },
    ];

    var rafId = 0;
    var running = false;

    function isAboutVisible() {
      var hero = document.querySelector(".hero-chaos");
      if (!hero) return false;
      var panel = hero.closest("[data-tab-panel]");
      if (!panel) return true;
      return panel.classList.contains("is-active") && !panel.hidden;
    }

    function tick(now) {
      if (!running) return;
      var t = now / 1000;
      var slow = window.matchMedia("(prefers-reduced-motion: reduce)").matches ? 0.35 : 1;
      var hero = document.querySelector(".hero-chaos");
      if (!hero || !isAboutVisible()) {
        rafId = requestAnimationFrame(tick);
        return;
      }

      var w = hero.clientWidth || window.innerWidth;
      var h = hero.clientHeight || window.innerHeight;

      PETALS.forEach(function (p) {
        var el = hero.querySelector(p.sel);
        if (!el) return;
        var phase = t * p.sp * slow + p.ph;
        var x = p.ox * w + Math.sin(phase) * p.ax * slow;
        var y = p.oy * h + Math.cos(phase * 0.85 + p.ph) * p.ay * slow;
        var rot = p.rot + Math.sin(phase * 1.1) * p.rs * slow;
        var scale = 1 + Math.sin(phase * 0.7) * 0.06 * slow;
        el.style.transform = "translate3d(" + x + "px," + y + "px,0) rotate(" + rot + "deg) scale(" + scale + ")";
      });

      rafId = requestAnimationFrame(tick);
    }

    function start() {
      if (running) return;
      running = true;
      document.documentElement.classList.add("petals-live");
      document.querySelectorAll(".hero-chaos .chaos-splash").forEach(function (el) {
        el.style.animation = "none";
        el.dataset.drift = "true";
      });
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(tick);
    }

    function stop() {
      running = false;
      cancelAnimationFrame(rafId);
    }

    function boot() {
      if (document.querySelector(".hero-chaos")) start();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", boot);
    } else {
      boot();
    }

    document.addEventListener("tabular:change", function (e) {
      if (e.detail && e.detail.tab === "about") start();
      else stop();
    });

    document.addEventListener("astro:page-load", boot);
    document.addEventListener("astro:after-swap", boot);
  })();
</script>
