---
import { t, type LocaleKey } from '../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="home" class="hero-section hero-chaos scroll-section visceral-hero">
  <div class="visceral-hero__frame">
    <div class="hero-editorial hero-chaos__inner">
      <div class="hero-editorial__copy">
        <p class="scroll-reveal hero-editorial__tagline section-eyebrow--blood">{l.heroTagline}</p>

        <div class="scroll-reveal hero-editorial__name-block">
          <h1 class="hero-editorial__name font-handwriting">
            {l.heroFirstName} {l.heroLastName}
          </h1>
        </div>

        <hr class="brutal-rule brutal-rule--short scroll-reveal" />

        <p class="scroll-reveal hero-editorial__roles">{l.heroRoles}</p>

        <p class="scroll-reveal hero-editorial__motto type-editorial">
          {l.heroMottoLead}
          <span class="hero-editorial__motto-emphasis">{l.heroMottoEmphasis}</span>
        </p>

        <p class="scroll-reveal hero-editorial__based">{l.heroBasedIn}</p>

        <p class="scroll-reveal hero-editorial__desc content-prose text-ink-45 text-sm">{l.heroDesc}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-editorial__name {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 0.35em;
    text-shadow: none;
  }

  .hero-editorial__motto-emphasis {
    color: var(--ink-75);
  }
</style>
