---
import LazyImage from "./LazyImage.astro";

interface Props {
  artTag: string;
  selected: string;
  works: string;
  year?: string;
  intro: string;
  heroDesc: string;
  heroImage?: string;
  heroImageAlt?: string;
}

const {
  artTag,
  selected,
  works,
  year = "2026",
  intro,
  heroDesc,
  heroImage = "/media/souls-and-leavings.jpg",
  heroImageAlt = "Anna Dauyl Rockswell — selected work",
} = Astro.props;
---

<section id="home" class="hero-section scroll-section border-b border-neutral-900/20">
  <div class="hero-sticky">
    <div class="hero-parallax-layer space-y-0">
      <span class="scroll-reveal font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">{artTag}</span>
      <div class="space-y-0">
        <h1 class="scroll-reveal font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-neutral-900">
          {selected}
        </h1>
        <div class="scroll-reveal flex items-center gap-4 md:gap-8 my-2">
          <div class="h-px flex-1 bg-neutral-900/20" />
          <span class="font-mono text-[10px] tracking-widest text-neutral-500">[001]</span>
        </div>
        <div class="scroll-reveal flex">
          <h1 class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-neutral-900">
            {works}
          </h1>
          <span class="font-sans font-black tracking-tighter uppercase text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] text-outline ml-2 md:ml-4">{year}</span>
        </div>
      </div>
      <p class="scroll-reveal content-prose italic text-neutral-800 mt-8 md:mt-10 max-w-[62ch]">{intro}</p>
      <p class="scroll-reveal content-prose--mono uppercase tracking-widest text-neutral-600 mt-4 md:mt-6 max-w-[58ch]">{heroDesc}</p>
    </div>

    <div class="hero-media-frame scroll-reveal">
      <LazyImage
        src={heroImage}
        alt={heroImageAlt}
        aspectRatio="4 / 5"
        parallaxSpeed={0.55}
        depthTarget={false}
        eager={true}
        class="w-full h-full object-cover"
      />
    </div>
  </div>
</section>
