---
import LazyImage from "./LazyImage.astro";

interface Props {
  imageSrc: string;
  imageAlt: string;
  title: string;
  subtitle?: string;
  aspectRatio?: string;
  parallaxSpeed?: number;
  contain?: boolean;
  imageClass?: string;
}

const {
  imageSrc,
  imageAlt,
  title,
  subtitle = "",
  aspectRatio = "4 / 5",
  parallaxSpeed = 0.45,
  contain = false,
  imageClass = "",
} = Astro.props;
---

<div class="media-popup-host" data-popup-title={title}>
  <div class="interactive-image-container">
    <slot name="media">
      <LazyImage
        src={imageSrc}
        alt={imageAlt}
        aspectRatio={aspectRatio}
        parallaxSpeed={parallaxSpeed}
        contain={contain}
        class={imageClass}
      />
    </slot>
  </div>
  <div class="media-popup-overlay" aria-hidden="true">
    <div class="media-popup-panel">
      <p class="media-popup-title">{title}</p>
      {subtitle && <p class="media-popup-subtitle">{subtitle}</p>}
    </div>
  </div>
</div>
