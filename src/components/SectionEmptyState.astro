---
interface Props {
  message: string;
  note?: string;
}

const { message, note } = Astro.props;
---

<div class="section-empty scroll-reveal">
  <p class="section-empty__message">{message}</p>
  {note && <p class="section-empty__note">{note}</p>}
</div>

<style>
  .section-empty {
    max-width: 42ch;
    padding: clamp(1rem, 2.5vw, 1.5rem) 0;
  }

  .section-empty__message {
    margin: 0;
    font-family: var(--font-editorial);
    font-style: italic;
    font-size: clamp(1rem, 0.55vw + 0.65rem, 1.125rem);
    line-height: 1.55;
    color: var(--ink-55);
  }

  .section-empty__note {
    margin: 0.75rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-45);
  }
</style>
