---
/**
 * ExhibitionGalleryOverlay
 * Full-screen photo grid overlay (Google Photos / iOS style).
 * Rendered once in the DOM, populated dynamically via JS.
 * Activated by exhibition-gallery.ts when user clicks "View All".
 */
---

<div
  id="exhibition-gallery-overlay"
  class="exg-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Exhibition gallery"
  aria-hidden="true"
  hidden
>
  <!-- Backdrop -->
  <div class="exg-overlay__backdrop" id="exg-backdrop"></div>

  <!-- Panel -->
  <div class="exg-overlay__panel">
    <!-- Header -->
    <header class="exg-overlay__header">
      <div class="exg-overlay__header-text">
        <p class="exg-overlay__eyebrow" id="exg-eyebrow"></p>
        <h2 class="exg-overlay__title" id="exg-title"></h2>
      </div>
      <div class="exg-overlay__header-meta">
        <span class="exg-overlay__count" id="exg-count"></span>
        <button
          type="button"
          class="exg-overlay__close"
          id="exg-close"
          aria-label="Close gallery"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line x1="4" y1="4" x2="16" y2="16"/>
            <line x1="16" y1="4" x2="4" y2="16"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- Masonry/grid body -->
    <div class="exg-overlay__body" id="exg-body">
      <!-- Skeleton shown before images arrive -->
      <div class="exg-skeleton" id="exg-skeleton" aria-hidden="true">
        {Array.from({ length: 8 }).map((_, i) => (
          <div class:list={["exg-skeleton__cell", `exg-skeleton__cell--${(i % 3) + 1}`]}>
            <div class="exg-skeleton__shimmer"></div>
          </div>
        ))}
      </div>

      <!-- Grid populated by JS -->
      <div class="exg-grid" id="exg-grid" role="list"></div>
    </div>
  </div>

  <!-- Lightbox (single image zoom) -->
  <div class="exg-lightbox" id="exg-lightbox" aria-hidden="true" hidden>
    <div class="exg-lightbox__backdrop" id="exg-lightbox-backdrop"></div>
    <div class="exg-lightbox__stage">
      <button type="button" class="exg-lightbox__nav exg-lightbox__nav--prev" id="exg-lb-prev" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="13 4 7 10 13 16"/>
        </svg>
      </button>
      <div class="exg-lightbox__media">
        <img class="exg-lightbox__img" id="exg-lb-img" src="" alt="" hidden />
        <video
          id="exg-lb-video"
          class="exg-lightbox__video"
          controls
          playsinline
          muted
          hidden
        ></video>
      </div>
      <button type="button" class="exg-lightbox__nav exg-lightbox__nav--next" id="exg-lb-next" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="7 4 13 10 7 16"/>
        </svg>
      </button>
      <button type="button" class="exg-lightbox__close" id="exg-lb-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="3" x2="15" y2="15"/><line x1="15" y1="3" x2="3" y2="15"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
/* ===== Overlay shell ===== */
.exg-overlay {
  position: fixed;
  inset: 0;
  z-index: 10100;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

.exg-overlay[hidden] {
  display: none;
}

/* Backdrop covers the full viewport including the sidebar */
.exg-overlay__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(17, 17, 17, 0.72);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  cursor: zoom-out;
}

/* ===== Panel =====
   On desktop (≥1024px) the sidebar is 15rem wide on the left.
   The panel must never overlap it — start from the sidebar's right edge.
   On mobile the panel is full-width (sidebar is hidden).
*/
.exg-overlay__panel {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 97dvh;
  max-height: 97dvh;
  background: var(--canvas, #F0EEE9);
  border-radius: 0.75rem 0.75rem 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  will-change: transform;
  box-sizing: border-box;
}

/* Desktop: panel occupies only the main content column */
@media (min-width: 1024px) {
  .exg-overlay__panel {
    width: calc(100vw - 15rem);
    border-radius: 0.75rem 0 0 0;
  }

  .exg-overlay__header {
    padding-top: 1.25rem;
  }
}

.exg-overlay.is-open .exg-overlay__panel {
  transform: translateY(0);
}

/* Preview-only: lightbox without the grid panel */
.exg-overlay--preview-only .exg-overlay__panel {
  display: none;
}

.exg-overlay--preview-only .exg-overlay__backdrop {
  background: rgba(17, 17, 17, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

/* Lock page scroll while gallery is open; hide site chrome for View All */
:global(html.exg-scroll-lock),
:global(html.exg-scroll-lock body) {
  overflow: hidden !important;
  overscroll-behavior: none;
}

:global(html.exg-gallery-open .site-topbar),
:global(html.exg-gallery-open body > header.lg\:hidden) {
  display: none !important;
}

:global(html.exg-gallery-open) .exg-overlay__header {
  padding-top: 1.25rem;
}

/* ===== Header — pinned above scrollable grid ===== */
.exg-overlay__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 1.25rem 1.5rem 0.875rem;
  border-bottom: 1px solid rgba(17,17,17,0.08);
  flex-shrink: 0;
  gap: 1rem;
  position: sticky;
  top: 0;
  z-index: 5;
  background: var(--canvas, #F0EEE9);
}

.exg-overlay__eyebrow {
  font-family: var(--font-heading, "Forum", serif);
  font-size: 0.5625rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--ink-45, rgba(17,17,17,0.45));
  margin: 0 0 0.25rem;
}

.exg-overlay__title {
  font-family: var(--font-heading, "Forum", serif);
  font-size: clamp(1rem, 2vw, 1.375rem);
  font-weight: 400;
  color: var(--ink, #111);
  margin: 0;
  line-height: 1.2;
}

.exg-overlay__header-meta {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  flex-shrink: 0;
  margin-top: 0.125rem;
}

.exg-overlay__count {
  font-family: var(--font-mono, monospace);
  font-size: 0.6875rem;
  letter-spacing: 0.1em;
  color: var(--ink-45, rgba(17,17,17,0.45));
  white-space: nowrap;
}

.exg-overlay__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.25rem;
  height: 2.25rem;
  border: 1px solid rgba(17,17,17,0.14);
  border-radius: 50%;
  background: transparent;
  color: var(--ink-55, #555);
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  flex-shrink: 0;
}

.exg-overlay__close:hover {
  background: var(--ink, #111);
  color: var(--canvas, #F0EEE9);
  border-color: var(--ink, #111);
}

/* ===== Body / scroll area ===== */
.exg-overlay__body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  overscroll-behavior: contain;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: rgba(17,17,17,0.2) transparent;
  padding: 0.75rem clamp(1.25rem, 4vw, 2.5rem) 2rem;
  position: relative;
}

.exg-overlay__body::-webkit-scrollbar { width: 4px; }
.exg-overlay__body::-webkit-scrollbar-thumb { background: rgba(17,17,17,0.2); border-radius: 2px; }

/* ===== Skeleton ===== */
.exg-skeleton {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
  animation: exg-skeleton-pulse 1.6s ease-in-out infinite;
}

.exg-skeleton.is-hidden {
  display: none;
}

.exg-skeleton__cell {
  border-radius: 0.375rem;
  overflow: hidden;
  background: rgba(17,17,17,0.06);
}

/* Vary heights for organic feel */
.exg-skeleton__cell--1 { aspect-ratio: 3/4; }
.exg-skeleton__cell--2 { aspect-ratio: 4/3; }
.exg-skeleton__cell--3 { aspect-ratio: 1/1; }

.exg-skeleton__shimmer {
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    rgba(17,17,17,0.04) 0%,
    rgba(17,17,17,0.10) 50%,
    rgba(17,17,17,0.04) 100%
  );
  background-size: 200% 100%;
  animation: exg-shimmer 1.6s ease-in-out infinite;
}

@keyframes exg-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

@keyframes exg-skeleton-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* ===== Photo grid ===== */
.exg-grid {
  column-count: 3;
  gap: 0.75rem;
  display: block;
  max-width: min(88rem, 96%);
  margin-inline: auto;
}

.exg-grid.is-hidden {
  display: none;
}

@media (max-width: 767px) {
  .exg-grid { column-count: 2; }
  .exg-skeleton { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1280px) {
  .exg-grid { column-count: 4; }
  .exg-skeleton { grid-template-columns: repeat(4, 1fr); }
}

/* Each grid item */
.exg-grid__item {
  break-inside: avoid;
  position: relative;
  cursor: zoom-in;
  border-radius: 0.375rem;
  overflow: hidden;
  background: rgba(17,17,17,0.05);
  display: block;
  margin-bottom: 0.75rem;
  /* Fade-in on load */
  opacity: 0;
  transform: translateY(0.5rem);
  transition:
    opacity 0.4s cubic-bezier(0.16,1,0.3,1),
    transform 0.4s cubic-bezier(0.16,1,0.3,1);
}

.exg-grid__item.is-loaded {
  opacity: 1;
  transform: translateY(0);
}

.exg-grid__item img,
.exg-grid__item video {
  display: block;
  width: 100%;
  height: auto;
  object-fit: cover;
  filter: grayscale(0.12);
  transition: filter 0.3s ease, transform 0.35s cubic-bezier(0.16,1,0.3,1);
}

.exg-grid__item--video::after {
  content: "▶";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 2.25rem;
  height: 2.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(17, 17, 17, 0.55);
  color: rgba(240, 238, 233, 0.92);
  font-size: 0.75rem;
  pointer-events: none;
  backdrop-filter: blur(2px);
}

@media (hover: hover) {
  .exg-grid__item:hover img,
  .exg-grid__item:hover video {
    filter: grayscale(0);
    transform: scale(1.025);
  }
}

/* Removed numbered hover overlay — gallery is unnumbered */

/* ===== In-grid skeleton cell (individual image loading) ===== */
.exg-grid__skeleton {
  break-inside: avoid;
  border-radius: 0.375rem;
  overflow: hidden;
  background: rgba(17,17,17,0.06);
  aspect-ratio: 4/3;
}

/* ===== Lightbox =====
   On mobile the fixed header is 3.5rem (56px) tall.
   On desktop the topbar is ~3rem. We push inset-top accordingly
   so the close button and counter never sit behind those bars.
*/
.exg-lightbox {
  position: fixed;
  inset: 0;
  padding-top: 3.5rem;
  z-index: 10200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-inline: 1.5rem;
  padding-bottom: 1.5rem;
  overflow: hidden;
  overscroll-behavior: none;
}

@media (min-width: 1024px) {
  .exg-lightbox {
    /* desktop topbar ~3rem + breathing room */
    padding-top: 4rem;
  }
}

.exg-lightbox[hidden] {
  display: none;
}

.exg-lightbox__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(17,17,17,0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  cursor: zoom-out;
}

.exg-lightbox__stage {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: clamp(0.75rem, 2vw, 1.5rem);
  width: 100%;
  height: 100%;
  max-width: min(96vw, 1600px);
}

.exg-lightbox__media {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  min-height: 0;
}

.exg-lightbox__img,
.exg-lightbox__video {
  display: block;
  max-width: min(92vw, 1400px);
  max-height: min(90dvh, 900px);
  width: auto;
  height: auto;
  object-fit: contain;
  border-radius: 0.25rem;
  box-shadow: 0 32px 96px rgba(0,0,0,0.6);
  animation: exg-lb-in 0.3s cubic-bezier(0.16,1,0.3,1);
}

.exg-lightbox__img[hidden],
.exg-lightbox__video[hidden] {
  display: none;
}

@keyframes exg-lb-in {
  from { opacity: 0; transform: scale(0.93); }
  to   { opacity: 1; transform: scale(1); }
}

.exg-lightbox__nav {
  position: static;
  transform: none;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 3rem;
  height: 3rem;
  border-radius: 50%;
  border: 1px solid rgba(240,238,233,0.22);
  background: rgba(240,238,233,0.08);
  color: rgba(240,238,233,0.85);
  cursor: pointer;
  flex-shrink: 0;
  transition: background 0.2s ease, color 0.2s ease;
}

.exg-lightbox__nav:hover:not(:disabled) {
  background: rgba(240,238,233,0.18);
  color: #fff;
}

.exg-lightbox__nav:disabled {
  opacity: 0.25;
  cursor: not-allowed;
}

.exg-lightbox__close {
  position: absolute;
  top: -3rem;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  border: 1px solid rgba(240,238,233,0.2);
  background: transparent;
  color: rgba(240,238,233,0.7);
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease;
}

.exg-lightbox__close:hover {
  background: rgba(240,238,233,0.12);
  color: #fff;
}

@media (max-width: 639px) {
  .exg-overlay__header { padding: 1rem 1rem 0.75rem; }
  .exg-overlay__body { padding: 0.75rem 0.75rem 1.5rem; }
  .exg-lightbox__nav { width: 2.5rem; height: 2.5rem; }
}

@media (prefers-reduced-motion: reduce) {
  .exg-overlay__panel {
    transition: none;
    transform: none;
  }
  .exg-grid__item {
    transition: none;
    opacity: 1;
    transform: none;
  }
  .exg-lightbox__img {
    animation: none;
  }
}
</style>
