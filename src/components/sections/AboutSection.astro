---
import LazyImage from '../LazyImage.astro';
import { t, type LocaleKey } from '../../data/translations';
import { siteCopy } from '../../data/site-copy';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="about" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide">
    <p class="scroll-reveal section-eyebrow">{l.aboutTag}</p>

    <div class="about-editorial">
      <div class="about-editorial__portrait scroll-reveal">
        <LazyImage
          src="/media/the-fish.png"
          alt="The Fish — selected painting"
          aspectRatio="3 / 4"
          parallaxSpeed={0.15}
          depthTarget={false}
          contain={true}
          class="w-full h-auto max-h-[68vh] object-contain"
        />
      </div>

      <div class="about-editorial__content">
        <div class="scroll-reveal">
          <h2 class="font-forum text-3xl md:text-4xl lg:text-[2.75rem] leading-[1.08] text-ink mb-8">
            NANA (Anna Dauyl Rockswell)
          </h2>
          <p class="content-prose--sans text-ink-55 mb-6">{l.intro}</p>
          <div class="content-prose space-y-5">
            <p>{l.bio}</p>
          </div>
        </div>

        <div class="scroll-reveal about-editorial__meta">
          <div>
            <p class="section-eyebrow mb-4">{l.interestsLabel}</p>
            <ul class="about-editorial__list">
              {siteCopy.about.interests.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div>
            <p class="section-eyebrow mb-4">{l.influencesLabel}</p>
            <ul class="about-editorial__list">
              {siteCopy.about.influences.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>

        <div class="scroll-reveal pt-6 border-t border-subtle">
          <p class="section-eyebrow mb-5">{l.artistStatement}</p>
          <p class="content-prose italic text-ink-70 max-w-[58ch]">
            {siteCopy.about.statement}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-editorial {
    display: grid;
    gap: clamp(3rem, 8vw, 7rem);
    align-items: start;
  }

  @media (min-width: 900px) {
    .about-editorial {
      grid-template-columns: minmax(14rem, 0.75fr) minmax(0, 1.25fr);
      gap: clamp(4rem, 10vw, 9rem);
    }

    .about-editorial__portrait {
      padding-top: 2rem;
    }
  }

  .about-editorial__meta {
    display: grid;
    gap: 2rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-subtle);
  }

  @media (min-width: 640px) {
    .about-editorial__meta {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .about-editorial__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .about-editorial__list li {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--ink-60);
    border: 1px solid var(--border-subtle);
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-lang-btn);
    line-height: 1.3;
  }
</style>
