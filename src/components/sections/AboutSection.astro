---
import LazyImage from '../LazyImage.astro';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="about" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide">
    <p class="scroll-reveal section-eyebrow">{l.aboutTag}</p>
    <div class="grid md:grid-cols-2 gap-10 md:gap-14 lg:gap-20 items-start">
      <div class="scroll-reveal">
        <LazyImage
          src="/media/the-fish.png"
          alt="The Fish — selected painting"
          aspectRatio="3 / 4"
          parallaxSpeed={0}
          depthTarget={false}
          contain={true}
          class="w-full h-auto max-h-[70vh] object-contain"
        />
      </div>
      <div class="scroll-reveal flex flex-col justify-center gap-8">
        <div>
          <h2 class="font-forum text-3xl md:text-4xl lg:text-5xl leading-[1.1] text-[#111] mb-6">
            NANA (Anna Dauyl Rockswell)
          </h2>
          <p class="content-prose--sans text-[#111]/55 mb-6">{l.intro}</p>
          <div class="content-prose space-y-5">
            <p>{l.bio}</p>
          </div>
        </div>
        <div>
          <p class="section-eyebrow mb-4">{l.artistStatement}</p>
          <p class="content-prose italic text-[#111]/75">
            My work occupies the threshold between the visceral and the conceptual — where the body becomes a site of memory, loss, and transformation. Drawing from Jungian archetypes and the raw materiality of dark expressionism, I explore how feminine experience is inscribed, erased, and reinscribed across personal and collective histories.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
