---
import { t, type LocaleKey } from '../../data/translations';
import { siteCopy } from '../../data/site-copy';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="about" class="scroll-section about-chaos about-panel-stack__content">
  <div class="section-shell section-shell--wide about-panel-stack__content-inner">
    <p class="scroll-reveal section-eyebrow">{l.aboutTag}</p>

    <div class="about-chaos__body">
      <div class="scroll-reveal about-chaos__intro">
        <p class="content-prose text-ink-60 mb-2">{l.heroBasedIn}</p>
        <h2 class="type-subheading text-2xl md:text-3xl lg:text-[2rem] text-ink mb-3">
          {l.heroIntro}
        </h2>
        <div class="space-y-4">
          <p class="content-prose text-ink-75">{l.heroDesc}</p>
          <p class="content-prose text-ink-75">{l.bio}</p>
        </div>
      </div>

      <div class="scroll-reveal about-chaos__meta">
        <div>
          <p class="section-eyebrow mb-3">{l.interestsLabel}</p>
          <ul class="about-chaos__list">
            {siteCopy.about.interests.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
