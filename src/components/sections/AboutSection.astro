---
import { t, type LocaleKey } from '../../data/translations';
import { siteCopy } from '../../data/site-copy';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="about" class="scroll-section about-chaos about-panel-stack__content magazine-torn">
  <div class="section-shell section-shell--wide about-panel-stack__content-inner">
    <div class="magazine-chapter scroll-reveal">
      <span class="magazine-giant-type magazine-chapter__giant" aria-hidden="true">A</span>
      <p class="section-eyebrow">{l.aboutTag}</p>
    </div>

    <div class="magazine-spread about-chaos__body">
      <div class="magazine-spread__page scroll-reveal about-chaos__intro">
        <p class="content-prose text-ink-60 mb-2">{l.heroBasedIn}</p>
        <h2 class="type-magazine-display text-2xl md:text-4xl lg:text-[2.75rem] text-ink mb-4 leading-[1.05]">
          {l.heroIntroBefore}<span class="about-chaos__city" tabindex="0">{l.heroIntroCity}</span>{l.heroIntroAfter}
        </h2>
        <p class="content-prose text-ink-75 magazine-dropcap max-w-[62ch]">{l.bio}</p>
      </div>

      <div class="magazine-spread__page scroll-reveal about-chaos__meta magazine-meta-grid">
        <div class="about-chaos__meta-block">
          <p class="section-eyebrow mb-3">{l.interestsLabel}</p>
          <ul class="about-chaos__list magazine-columns">
            {siteCopy.about.interests.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="about-chaos__meta-block">
          <p class="section-eyebrow mb-3">{l.influencesLabel}</p>
          <ul class="about-chaos__list">
            {siteCopy.about.mentalCatharsis.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
