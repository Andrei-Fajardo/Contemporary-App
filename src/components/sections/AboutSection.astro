---
import { t, type LocaleKey } from '../../data/translations';
import { siteCopy } from '../../data/site-copy';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const heroIntroHtml = l.heroIntro.replace(
  /Anna Dauyl Rockswell/g,
  '<span class="font-name-cursive">Anna Dauyl Rockswell</span>',
);
---

<section id="about" class="scroll-section section-gap about-chaos">
  <div class="section-shell section-shell--wide">
    <p class="scroll-reveal section-eyebrow">{l.aboutTag}</p>

    <div class="about-chaos__body">
      <div class="scroll-reveal about-chaos__intro">
        <p class="content-prose--sans text-ink-55 mb-3">{l.heroBasedIn}</p>
        <p class="content-prose text-ink-55 mb-3" set:html={heroIntroHtml} />
        <p class="content-prose text-ink-45 text-sm mb-4">{l.heroDesc}</p>
        <div class="content-prose space-y-3">
          <p>{l.bio}</p>
        </div>
      </div>

      <div class="scroll-reveal about-chaos__meta">
        <div>
          <p class="section-eyebrow mb-3">{l.interestsLabel}</p>
          <ul class="about-chaos__list">
            {siteCopy.about.interests.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
