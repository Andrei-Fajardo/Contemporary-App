---
import EditorialLinkList from '../EditorialLinkList.astro';
import ManuscriptSectionHeader from '../ManuscriptSectionHeader.astro';
import { t, type LocaleKey } from '../../data/translations';
import { publicationsList } from '../../data/content';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="publications" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide">
    <ManuscriptSectionHeader num="IV" eyebrow={l.publicationsTag} title={l.publicationsHeading} />
    <EditorialLinkList items={publicationsList} emptyMessage={l.listForthcoming} emptyNote={l.comingSoonNote} />
  </div>
</section>
