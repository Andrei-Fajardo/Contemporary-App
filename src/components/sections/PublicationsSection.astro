---
import EditorialLinkList from '../EditorialLinkList.astro';
import ManuscriptModal from '../ManuscriptModal.astro';
import { publicationLinks } from '../../data/content';
import { siteCopy } from '../../data/site-copy';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
const novels = siteCopy.publications.novels;
---

<section id="publications" class="scroll-section section-gap pubs-overlap magazine-torn">

  <div class="pubs-overlap__frame" aria-hidden="true">
    <img
      src="/media/anan sample 2.png"
      alt=""
      class="pubs-overlap__img"
      loading="lazy"
      decoding="async"
      draggable="false"
      data-lightbox-ignore
      data-artwork-parallax
      data-artwork-strength="0.035"
      data-artwork-max="18"
    />
  </div>

  <div class="pubs-overlap__content section-shell section-shell--wide">
    <div class="magazine-chapter">
      <p class="scroll-reveal section-eyebrow">{l.publicationsTag}</p>
      <h2 class="scroll-reveal magazine-chapter__title pubs-overlap__heading">
        {l.publicationsHeading}
      </h2>
    </div>

    <p class="scroll-reveal content-prose text-ink-60 pubs-section__intro">
      {l.publicationsIntro}
    </p>

    <EditorialLinkList items={publicationLinks} showYear={false} />

    {novels.length > 0 && (
      <div class="pubs-section__novels scroll-reveal">
        <p class="section-eyebrow pubs-section__novels-label">{l.novelsLabel}</p>
        <ul class="pubs-novel-list">
          {novels.map((novel) => (
            <li class="pubs-novel-list__item">
              <span class="editorial-row-list__title">{novel.title}</span>
              {novel.status === 'coming-soon' && (
                <span class="pubs-novel-list__status">{l.comingSoon}</span>
              )}
            </li>
          ))}
        </ul>

        <div class="exhibition-filters pubs-section__manuscript-actions" role="group" aria-label={l.manuscriptHeading}>
          <button type="button" class="exhibition-filter pubs-manuscript-btn" data-manuscript-open>
            {l.manuscriptReadBtn}
          </button>
        </div>
      </div>
    )}
  </div>

</section>

<ManuscriptModal locale={locale} />
