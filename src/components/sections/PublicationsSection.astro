---
import ComingSoon from '../ComingSoon.astro';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="publications" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide">
    <p class="scroll-reveal section-eyebrow section-eyebrow--blood">{l.publicationsTag}</p>
    <ComingSoon
      message="Published studies and scientific essays will appear here as they become available."
      note={l.comingSoonNote}
    />
  </div>
</section>
