---
import EditorialLinkList from '../EditorialLinkList.astro';
import ManuscriptModal from '../ManuscriptModal.astro';
import { publicationLinks } from '../../data/content';
import { siteCopy } from '../../data/site-copy';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
const novels = siteCopy.publications.novels;
---

<section id="publications" class="scroll-section section-gap pubs-overlap magazine-torn">

  <div class="pubs-overlap__frame" aria-hidden="true">
    <img
      src="/media/anan sample 2.png"
      alt=""
      class="pubs-overlap__img"
      loading="lazy"
      decoding="async"
      draggable="false"
      data-lightbox-ignore
      data-artwork-parallax
      data-artwork-strength="0.035"
      data-artwork-max="18"
    />
  </div>

  <div class="pubs-overlap__content section-shell section-shell--wide">
    <header class="pubs-editorial__masthead scroll-reveal">
      <div class="magazine-chapter">
        <p class="section-eyebrow">{l.publicationsTag}</p>
        <h2 class="magazine-chapter__title pubs-overlap__heading">
          {l.publicationsHeading}
        </h2>
      </div>
      <p class="content-prose text-ink-60 pubs-section__intro">
        {l.publicationsIntro}
      </p>
    </header>

    <div
      class="pubs-editorial__grid scroll-reveal flex min-w-0 flex-col gap-6 lg:grid lg:grid-cols-[minmax(0,1.12fr)_minmax(0,0.88fr)] lg:items-stretch lg:gap-[clamp(1rem,2.5vw,1.75rem)]"
    >
      <div class="pubs-editorial__col pubs-editorial__col--links min-w-0 max-lg:contents">
        <div class="pubs-editorial__panel h-auto min-h-0 order-2 lg:order-none">
          <p class="pubs-editorial__label">{l.publicationsFeaturedLabel}</p>
          <EditorialLinkList items={publicationLinks} showYear={false} />
        </div>
      </div>

      <div class="pubs-editorial__col pubs-editorial__col--stack flex min-w-0 flex-col gap-6 max-lg:contents lg:flex">
        {novels.length > 0 && (
          <div class="pubs-editorial__panel pubs-editorial__panel--accent pubs-editorial__panel--novels h-auto min-h-0 order-3 lg:order-none">
            <p class="pubs-editorial__label">{l.novelsLabel}</p>
            <ul class="pubs-novel-list">
              {novels.map((novel) => (
                <li class="pubs-novel-list__item">
                  <span class="editorial-row-list__title">{novel.title}</span>
                  {novel.status === 'coming-soon' && (
                    <span class="pubs-novel-list__status">{l.comingSoon}</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="pubs-editorial__panel pubs-editorial__panel--accent pubs-editorial__panel--chapbook h-auto min-h-0 order-first lg:order-none">
          <p class="pubs-editorial__label">{l.chapbookLabel}</p>
          <div class="pubs-section__manuscript-actions" role="group" aria-label={l.manuscriptHeading}>
            <button type="button" class="pubs-manuscript-btn" data-manuscript-open>
              {l.manuscriptReadBtn}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

</section>

<ManuscriptModal locale={locale} />
