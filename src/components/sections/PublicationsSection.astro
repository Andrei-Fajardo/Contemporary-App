---
import { t, type LocaleKey } from '../../data/translations';
import { publications } from '../../data/content';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const books = publications.filter((p) => p.type === 'book');
const essays = publications.filter((p) => p.type === 'essay');
---

<section id="publications" class="scroll-section border-b border-neutral-900/20">
  <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20 max-w-4xl">
    <span class="scroll-reveal font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(PUBLICATIONS &amp; WRITING)</span>
    <h2 class="scroll-reveal font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-16">
      Publications<br />&amp; Writing
    </h2>

    <div class="scroll-reveal mb-16">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-mono text-[9px] tracking-widest text-neutral-500">{l.booksMonographs}</span>
        <div class="h-px flex-1 bg-black/10" />
      </div>
      <div class="space-y-6">
        {books.map((pub) => (
          <div class="font-serif text-sm md:text-base text-neutral-700 leading-relaxed">
            {pub.author}, <em>{pub.title}</em>, {pub.publisher}, {pub.year}.
          </div>
        ))}
      </div>
    </div>

    <div class="scroll-reveal">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-mono text-[9px] tracking-widest text-neutral-500">{l.essaysWriting}</span>
        <div class="h-px flex-1 bg-black/10" />
      </div>
      <div class="space-y-6">
        {essays.map((pub) => (
          <div class="font-serif text-sm md:text-base text-neutral-700 leading-relaxed">
            {pub.author}, &ldquo;{pub.title},&rdquo; <em>{pub.publisher}</em>, {pub.year}.
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
