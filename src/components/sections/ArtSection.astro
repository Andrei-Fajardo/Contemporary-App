---
import MediaPopup from '../MediaPopup.astro';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const paintings = [
  {
    image: "/media/the-fish.png",
    title: "The Fish",
    medium: "90CM X 80CM, OIL ON CANVAS",
    year: "2024",
    description:
      "She floats in a half-life, caught between Piscean intuition and the weight of funeral black. The fur is not warmth — it is the silence before the burial. The fish totem carries her through waters both amniotic and grave-cold.",
    contain: true,
  },
  {
    image: "/media/souls-and-leavings.jpg",
    title: "The Souls of Leavings",
    medium: "120CM X 100CM, MIXED MEDIA ON CANVAS",
    year: "2025",
    description:
      "This painting emerged from witnessing the devastation of abandonment and the quiet violence of loss. The female figure appears caught between states — as though waiting for something to leave her, or return. In Kazakh tradition, the departing soul lingers for forty days.",
    contain: true,
  },
];
---

<section id="art" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide mb-12 md:mb-16 lg:mb-20">
    <p class="scroll-reveal section-eyebrow">{l.artTag}</p>
    <h2 class="scroll-reveal font-forum text-4xl md:text-6xl lg:text-7xl leading-[0.95] text-ink mb-6">
      {l.nav.art}
    </h2>
    <p class="scroll-reveal content-prose italic text-ink-60 max-w-[65ch]">{l.heroDesc}</p>
  </div>

  {paintings.map((p, i) => (
    <article class="art-piece depth-target" data-popup-title={p.title}>
      <div class="section-shell section-shell--wide py-10 md:py-14 lg:py-16">
        <div class={`grid md:grid-cols-2 gap-10 lg:gap-16 xl:gap-24 items-center`}>
          <div class={`min-w-0 ${i % 2 === 1 ? 'md:col-start-2' : ''}`}>
            <MediaPopup
              imageSrc={p.image}
              imageAlt={p.title}
              title={p.title}
              subtitle={`${p.medium} // ${p.year}`}
              aspectRatio={p.contain ? "auto" : "3 / 2"}
              parallaxSpeed={0.18}
              contain={p.contain}
              imageClass={p.contain ? "w-full h-auto max-h-[72vh] object-contain mx-auto" : "w-full h-[50vh] md:h-[60vh] object-cover"}
            />
          </div>
          <div class={`scroll-reveal min-w-0 flex flex-col gap-6 ${i % 2 === 1 ? 'md:col-start-1 md:row-start-1' : ''}`}>
            <p class="section-eyebrow mb-0">{String(i + 1).padStart(2, '0')} · {p.year}</p>
            <h3 class="font-forum text-3xl md:text-4xl lg:text-[2.75rem] leading-[1.05] text-ink">{p.title}</h3>
            <p class="content-prose--sans text-ink-55">{p.medium}</p>
            <p class="content-prose text-ink-70 max-w-[58ch]">{p.description}</p>
          </div>
        </div>
      </div>
    </article>
  ))}
</section>
