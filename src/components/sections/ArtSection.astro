---
import MediaPopup from '../MediaPopup.astro';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const paintings = [
  {
    image: "/media/the-fish.png",
    title: "The Fish",
    medium: "90CM X 80CM, OIL ON CANVAS",
    year: "2024",
    description:
      "She floats in a half-life, caught between Piscean intuition and the weight of funeral black. The fur is not warmth — it is the silence before the burial. The fish totem carries her through waters both amniotic and grave-cold.",
    contain: true,
  },
  {
    image: "/media/souls-and-leavings.jpg",
    title: "The Souls of Leavings",
    medium: "120CM X 100CM, MIXED MEDIA ON CANVAS",
    year: "2025",
    description:
      "This painting emerged from witnessing the devastation of abandonment and the quiet violence of loss. The female figure appears caught between states — as though waiting for something to leave her, or return. In Kazakh tradition, the departing soul lingers for forty days.",
    contain: true,
  },
];
---

<section id="art" class="scroll-section border-b border-neutral-900/20">
  <div class="section-shell py-10 md:py-14 border-b border-neutral-900/20">
    <span class="scroll-reveal font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-4">(ARTWORK)</span>
    <h2 class="scroll-reveal font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-3">
      Paintings
    </h2>
    <p class="scroll-reveal content-prose italic text-neutral-600 max-w-[65ch]">{l.heroDesc}</p>
  </div>

  {paintings.map((p, i) => (
    <article class="art-piece depth-target border-b border-neutral-900/20" data-popup-title={p.title}>
      <div class="section-shell py-10 md:py-14 lg:py-16">
        <div class="grid md:grid-cols-2 gap-8 lg:gap-14 xl:gap-20 items-center">
          <div class={`min-w-0 ${i % 2 === 1 ? 'md:col-start-2' : ''}`}>
            <MediaPopup
              imageSrc={p.image}
              imageAlt={p.title}
              title={p.title}
              subtitle={`${p.medium} // ${p.year}`}
              aspectRatio={p.contain ? "auto" : "3 / 2"}
              parallaxSpeed={0}
              contain={p.contain}
              imageClass={p.contain ? "w-full h-auto max-h-[72vh] object-contain mx-auto" : "w-full h-[50vh] md:h-[60vh] object-cover"}
            />
          </div>
          <div class={`scroll-reveal min-w-0 flex flex-col gap-6 ${i % 2 === 1 ? 'md:col-start-1 md:row-start-1' : ''}`}>
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="font-mono text-[11px] tracking-widest text-neutral-400">{String(i + 1).padStart(3, '0')}</span>
                <span class="font-mono text-[10px] border border-neutral-400 px-2 py-0.5 text-neutral-500">{p.year}</span>
              </div>
              <h3 class="font-sans font-black tracking-tighter uppercase text-3xl md:text-4xl leading-[0.9] text-neutral-900">{p.title}</h3>
              <span class="section-divider-label font-mono text-neutral-500 block mt-3">{p.medium}</span>
            </div>
            <p class="content-prose--mono text-neutral-600 max-w-[58ch]">{p.description}</p>
          </div>
        </div>
      </div>
    </article>
  ))}
</section>
