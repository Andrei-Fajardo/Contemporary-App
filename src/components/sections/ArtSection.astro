---
import MediaPopup from '../MediaPopup.astro';
import ManuscriptSectionHeader from '../ManuscriptSectionHeader.astro';
import { t, type LocaleKey } from '../../data/translations';
import { artworks } from '../../data/artworks';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="art" class="scroll-section section-gap art-section--unified utero-layered">
  <div class="section-shell section-shell--wide mb-4 md:mb-5">
    <ManuscriptSectionHeader num="II" eyebrow={l.artTag} title={l.nav.art} />
  </div>

  {artworks.map((p, i) => (
    <article class="art-piece depth-target" data-popup-title={p.title}>
      <div class="section-shell section-shell--wide py-3 md:py-5 lg:py-6">
        <div class={`grid md:grid-cols-2 gap-6 lg:gap-10 xl:gap-12 items-start`}>
          <div class={`min-w-0 ${i % 2 === 1 ? 'md:col-start-2' : ''}`}>
            <MediaPopup
              imageSrc={p.image}
              imageAlt={p.title}
              title={p.title}
              subtitle={p.dimensions}
              aspectRatio={p.contain ? "auto" : "3 / 2"}
              parallaxSpeed={0.18}
              contain={p.contain}
              imageClass={p.contain ? "w-full h-auto max-h-[72vh] object-contain mx-auto" : "w-full h-[50vh] md:h-[60vh] object-cover"}
            />
          </div>

          <div class={`scroll-reveal min-w-0 art-wall-label ${i % 2 === 1 ? 'md:col-start-1 md:row-start-1' : ''}`}>
            <h3 class="type-display text-2xl md:text-3xl lg:text-[2rem] text-ink mb-2">{p.title}</h3>
            <p class="type-subheading text-lg md:text-xl text-ink-65 mb-1">{p.dimensions}</p>
            <p class="type-body text-ink-60 text-sm mb-5">{p.medium} · {p.year}</p>

            <div class="art-wall-label__block">
              <p class="type-heading text-[0.6875rem] text-ink-50 mb-3">About</p>
              <div class="space-y-3">
                {p.aboutParagraphs.map((para) => (
                  <p class="content-prose text-ink-75 max-w-[58ch]">{para}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>
  ))}
</section>

<style>
  .art-wall-label__block {
    margin-top: 0.25rem;
  }
</style>
