---
import MediaPopup from '../MediaPopup.astro';
import MagazineSectionHeader from '../MagazineSectionHeader.astro';
import { t, type LocaleKey } from '../../data/translations';
import { artworks } from '../../data/artworks';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="art" class="scroll-section">
  <div class="mag-shell">
    <MagazineSectionHeader num="II" eyebrow={l.artTag} title={l.nav.art} />
  </div>

  {artworks.map((p, i) => (
    <article class="mag-art-piece art-piece depth-target" data-popup-title={p.title}>
      <div class="mag-shell">
        <div class={`mag-art-piece__grid ${i % 2 === 1 ? 'mag-art-piece__grid--flip' : ''}`}>
          <div class="mag-art-piece__media min-w-0">
            <MediaPopup
              imageSrc={p.image}
              imageAlt={p.title}
              title={p.title}
              subtitle={p.dimensions}
              aspectRatio={p.contain ? "auto" : "3 / 2"}
              parallaxSpeed={0.18}
              contain={p.contain}
              imageClass={p.contain ? "w-full h-auto max-h-[72vh] object-contain mx-auto" : "w-full h-[50vh] md:h-[60vh] object-cover"}
            />
          </div>

          <div class="mag-art-piece__label scroll-reveal art-wall-label">
            <h3 class="type-subheading text-2xl md:text-3xl text-ink mb-2">{p.title}</h3>
            <p class="type-subheading text-lg text-ink-65 mb-1">{p.dimensions}</p>
            <p class="type-body text-ink-60 text-sm mb-6">{p.medium} · {p.year}</p>

            <div class="art-wall-label__block">
              <p class="mag-section-header__eyebrow mb-3">About</p>
              <div class="space-y-3">
                {p.aboutParagraphs.map((para) => (
                  <p class="content-prose text-ink-75 max-w-[58ch]">{para}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>
  ))}
</section>

<style>
  .mag-art-piece {
    padding-block: clamp(2rem, 5vw, 3rem);
  }
</style>
