---
import MediaPopup from '../MediaPopup.astro';
import { t, type LocaleKey } from '../../data/translations';
import { artworks } from '../../data/artworks';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="art" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide mb-12 md:mb-20 lg:mb-28">
    <p class="scroll-reveal section-eyebrow">{l.artTag}</p>
    <h2 class="scroll-reveal font-forum text-4xl md:text-6xl lg:text-7xl leading-[0.95] text-ink mb-6">
      {l.nav.art}
    </h2>
    <p class="scroll-reveal content-prose italic text-ink-60 max-w-[65ch]">{l.heroDesc}</p>
  </div>

  {artworks.map((p, i) => (
    <article class="art-piece depth-target" data-popup-title={p.title}>
      <div class="section-shell section-shell--wide py-10 md:py-16 lg:py-20">
        <div class={`grid md:grid-cols-2 gap-12 lg:gap-20 xl:gap-28 items-start`}>
          <div class={`min-w-0 ${i % 2 === 1 ? 'md:col-start-2' : ''}`}>
            <MediaPopup
              imageSrc={p.image}
              imageAlt={p.title}
              title={p.title}
              subtitle={`${p.dimensions} // ${p.medium} // ${p.year}`}
              aspectRatio={p.contain ? "auto" : "3 / 2"}
              parallaxSpeed={0.18}
              contain={p.contain}
              imageClass={p.contain ? "w-full h-auto max-h-[72vh] object-contain mx-auto" : "w-full h-[50vh] md:h-[60vh] object-cover"}
            />
          </div>
          <div class={`scroll-reveal min-w-0 flex flex-col gap-6 ${i % 2 === 1 ? 'md:col-start-1 md:row-start-1' : ''}`}>
            <p class="section-eyebrow mb-0">{String(i + 1).padStart(2, '0')} · {p.year}</p>
            <h3 class="font-forum text-3xl md:text-4xl lg:text-[2.75rem] leading-[1.05] text-ink">{p.title}</h3>
            <p class="content-prose--sans text-ink-55">{p.dimensions} · {p.medium}</p>
            <p class="content-prose text-ink-55 text-sm">By Artist NANA (Anna Dauyl Rockswell)</p>
            <div class="art-wall-label">
              <p class="section-eyebrow mb-3">About</p>
              <p class="content-prose text-ink-70 max-w-[58ch]">{p.about}</p>
            </div>
            <div class="art-wall-label pt-4 border-t border-subtle">
              <p class="section-eyebrow mb-3">Artist Bio</p>
              <p class="content-prose text-ink-65 max-w-[58ch] text-sm">{p.artistBio}</p>
            </div>
            <p class="content-prose--mono text-ink-45 text-xs tracking-wider">
              Contact: {p.contact}
            </p>
          </div>
        </div>
      </div>
    </article>
  ))}
</section>

<style>
  .art-wall-label {
    margin-top: 0.5rem;
  }
</style>
