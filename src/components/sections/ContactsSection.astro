---
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="contacts" class="scroll-section section-gap section-inverted">
  <div class="section-shell section-shell--wide py-12 md:py-16 lg:py-20">
    <p class="scroll-reveal section-eyebrow">{l.contactTag}</p>
    <h2 class="scroll-reveal font-forum text-4xl md:text-6xl lg:text-7xl leading-[0.95] mb-10 md:mb-14">
      {l.contactHeading}
    </h2>

    <div class="grid md:grid-cols-2 gap-12 md:gap-16 lg:gap-20">
      <div class="scroll-reveal space-y-8">
        <div>
          <span class="section-divider-label block mb-2">{l.email}</span>
          <a href="mailto:contact@annadauylrockswell.com" class="content-prose underline underline-offset-4 decoration-white/30 hover:decoration-white transition-all">
            contact@annadauylrockswell.com
          </a>
          <a href="mailto:support@annadauylrockswell.com" class="content-prose block mt-2 underline underline-offset-4 decoration-white/30 hover:decoration-white transition-all">
            support@annadauylrockswell.com
          </a>
        </div>
        <div>
          <span class="section-divider-label block mb-2">{l.basedIn}</span>
          <p class="content-prose">{l.location}</p>
        </div>
        <div>
          <span class="section-divider-label block mb-2">{l.socials}</span>
          <a href="https://instagram.com/annadauylrockswell" target="_blank" rel="noopener noreferrer" class="content-prose underline underline-offset-4 decoration-white/30 hover:decoration-white transition-all">
            @annadauylrockswell
          </a>
        </div>
        <div>
          <span class="section-divider-label block mb-2">{l.licenses}</span>
          <div class="flex flex-wrap gap-x-6 gap-y-2 content-prose--sans">
            <span>ARS</span>
            <span>ARKO</span>
            <span>DACS</span>
          </div>
        </div>
      </div>

      <div class="scroll-reveal">
        <form class="space-y-6" onsubmit="event.preventDefault(); alert('Sent (demo)');">
          <div>
            <span class="section-divider-label block mb-2">{l.nameLabel}</span>
            <input type="text" placeholder={l.namePlaceholder} class="w-full bg-transparent border-b border-white/25 focus:border-white/60 focus:outline-none font-sans text-lg md:text-xl text-white/90 placeholder:text-white/25 py-2 transition-colors" />
          </div>
          <div>
            <span class="section-divider-label block mb-2">{l.emailLabel}</span>
            <input type="email" placeholder={l.emailPlaceholder} class="w-full bg-transparent border-b border-white/25 focus:border-white/60 focus:outline-none font-sans text-lg md:text-xl text-white/90 placeholder:text-white/25 py-2 transition-colors" />
          </div>
          <div>
            <span class="section-divider-label block mb-2">{l.messageLabel}</span>
            <textarea rows="4" placeholder={l.messagePlaceholder} class="w-full bg-transparent border-b border-white/25 focus:border-white/60 focus:outline-none font-sans text-lg md:text-xl text-white/90 placeholder:text-white/25 py-2 resize-none transition-colors"></textarea>
          </div>
          <div class="pt-2">
            <button type="submit" class="font-sans text-sm uppercase tracking-[0.2em] text-white/90 hover:text-white border border-white/30 hover:border-white/60 px-6 py-3 transition-colors cursor-pointer bg-transparent">
              {l.sendMessage}
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
