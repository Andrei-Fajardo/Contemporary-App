---
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="contacts" class="scroll-section">
  <div class="section-shell section-shell--wide py-12 md:py-20 lg:py-24">
    <span class="scroll-reveal font-sans text-[10px] tracking-[0.3em] text-[#111111]/50 block mb-6">{l.contactTag}</span>
    <h2 class="scroll-reveal font-forum text-4xl md:text-6xl lg:text-[9rem] leading-[0.9] text-[#111111] mb-10 md:mb-16">{l.contactHeading}</h2>

    <div class="grid md:grid-cols-2 gap-12 md:gap-16 lg:gap-20 xl:gap-24">
      <div class="scroll-reveal space-y-8">
        <div>
          <span class="section-divider-label font-sans text-[#111111]/50 block mb-2">{l.email}</span>
          <a href="mailto:contact@annadauylrockswell.com" class="content-prose text-[#111111] underline underline-offset-4 decoration-black/30 hover:decoration-black transition-all">
            contact@annadauylrockswell.com
          </a>
        </div>
        <div>
          <span class="section-divider-label font-sans text-[#111111]/50 block mb-2">{l.basedIn}</span>
          <p class="content-prose text-[#111111]/75">{l.location}</p>
        </div>
        <div>
          <span class="section-divider-label font-sans text-[#111111]/50 block mb-2">{l.galleryRep}</span>
          <p class="content-prose text-[#111111]/75">Verger Gallery, Seoul<br />Hechyeomoyeo Collective, New York</p>
        </div>
      </div>

      <div class="scroll-reveal">
        <form class="space-y-0" onsubmit="event.preventDefault(); alert('Sent (demo)');">
          <div class="border-b-2 border-[#111111] py-4 md:py-5">
            <span class="font-sans text-[10px] tracking-widest text-[#111111]/50 block mb-2">{l.nameLabel}</span>
            <input type="text" placeholder={l.namePlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-lg md:text-xl lg:text-2xl text-[#111111]/40 placeholder:text-[#111111]/20 py-1" />
          </div>
          <div class="border-b-2 border-[#111111] py-4 md:py-5">
            <span class="font-sans text-[10px] tracking-widest text-[#111111]/50 block mb-2">{l.emailLabel}</span>
            <input type="email" placeholder={l.emailPlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-lg md:text-xl lg:text-2xl text-[#111111]/40 placeholder:text-[#111111]/20 py-1" />
          </div>
          <div class="border-b-2 border-[#111111] py-4 md:py-5">
            <span class="font-sans text-[10px] tracking-widest text-[#111111]/50 block mb-2">{l.messageLabel}</span>
            <textarea rows="3" placeholder={l.messagePlaceholder} class="w-full bg-transparent rounded-none border-none focus:outline-none font-sans text-lg md:text-xl lg:text-2xl text-[#111111]/40 placeholder:text-[#111111]/20 py-1 resize-none"></textarea>
          </div>
          <div class="pt-6 text-right">
            <button type="submit" class="group content-prose--mono uppercase tracking-widest text-[#111111] hover:text-[#111111]/50 font-bold transition-colors cursor-pointer border-none bg-transparent px-4 py-2">
              <span class="block transition-transform duration-300 ease-out group-hover:translate-x-px">{l.sendMessage}</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
