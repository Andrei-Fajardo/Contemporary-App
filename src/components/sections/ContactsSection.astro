---
import ManuscriptSectionHeader from '../ManuscriptSectionHeader.astro';
import { t, type LocaleKey } from '../../data/translations';
import { siteCopy } from '../../data/site-copy';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="contacts" class="scroll-section section-gap contacts-chaos section-inverted section-inverted--blood">
  <div class="section-shell section-shell--wide">
    <ManuscriptSectionHeader
      num="VII"
      eyebrow={l.contactTag}
      title={l.contactHeading}
      titleClass="type-heading text-2xl md:text-4xl lg:text-[2.75rem] text-[var(--canvas)] chaos-title-mark"
    />

    <div class="grid md:grid-cols-2 gap-8 md:gap-12 lg:gap-14">
      <div class="scroll-reveal space-y-10">
        <div>
          <span class="section-divider-label section-eyebrow--blood block mb-3">{l.email}</span>
          <a href="mailto:contact@annadauylrockswell.com" class="content-prose underline underline-offset-4 decoration-black/20 hover:decoration-[var(--accent-red)] transition-all">
            contact@annadauylrockswell.com
          </a>
          <a href="mailto:support@annadauylrockswell.com" class="content-prose block mt-3 underline underline-offset-4 decoration-black/20 hover:decoration-[var(--accent-red)] transition-all">
            support@annadauylrockswell.com
          </a>
        </div>
        <div>
          <span class="section-divider-label section-eyebrow--blood block mb-3">{l.basedIn}</span>
          <p class="content-prose text-ink-75">{l.location}</p>
        </div>
        <div>
          <span class="section-divider-label section-eyebrow--blood block mb-3">{l.socials}</span>
          <a href="https://instagram.com/rockswellnana" target="_blank" rel="noopener noreferrer" class="content-prose underline underline-offset-4 decoration-black/20 hover:decoration-[var(--accent-red)] transition-all">
            @rockswellnana
          </a>
        </div>
        <div>
          <span class="section-divider-label section-eyebrow--blood block mb-3">{l.licenses}</span>
          <div class="flex flex-col gap-3">
            {siteCopy.licenses.map((license) => (
              <a
                href={license.href}
                target="_blank"
                rel="noopener noreferrer"
                class="content-prose underline underline-offset-4 decoration-black/20 hover:decoration-[var(--accent-red)] transition-all"
              >
                {license.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="scroll-reveal">
        <form class="contacts-chaos__form space-y-8" onsubmit="event.preventDefault(); alert('Sent (demo)');">
          <div>
            <span class="section-divider-label section-eyebrow--blood block mb-3">{l.nameLabel}</span>
            <input type="text" placeholder={l.namePlaceholder} class="contacts-chaos__input" />
          </div>
          <div>
            <span class="section-divider-label section-eyebrow--blood block mb-3">{l.emailLabel}</span>
            <input type="email" placeholder={l.emailPlaceholder} class="contacts-chaos__input" />
          </div>
          <div>
            <span class="section-divider-label section-eyebrow--blood block mb-3">{l.messageLabel}</span>
            <textarea rows="4" placeholder={l.messagePlaceholder} class="contacts-chaos__input contacts-chaos__input--area resize-none"></textarea>
          </div>
          <div class="pt-2">
            <button type="submit" class="contacts-chaos__submit">
              {l.sendMessage}
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
