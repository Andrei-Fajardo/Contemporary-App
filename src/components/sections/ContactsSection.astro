---
import { t, type LocaleKey } from '../../data/translations';
import { siteCopy } from '../../data/site-copy';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="contacts" class="scroll-section section-gap section-inverted section-inverted--blood">
  <div class="section-shell section-shell--wide">
    <p class="scroll-reveal section-eyebrow">{l.contactTag}</p>
    <h2 class="scroll-reveal type-heading text-3xl md:text-5xl lg:text-6xl text-ink mb-12 md:mb-16 chaos-title-mark">
      {l.contactHeading}
    </h2>

    <div class="grid md:grid-cols-2 gap-14 md:gap-20 lg:gap-24">
      <div class="scroll-reveal space-y-10">
        <div>
          <span class="section-divider-label block mb-3">{l.email}</span>
          <a href="mailto:contact@annadauylrockswell.com" class="content-prose underline underline-offset-4 decoration-white/30 hover:decoration-white transition-all">
            contact@annadauylrockswell.com
          </a>
          <a href="mailto:support@annadauylrockswell.com" class="content-prose block mt-3 underline underline-offset-4 decoration-white/30 hover:decoration-white transition-all">
            support@annadauylrockswell.com
          </a>
        </div>
        <div>
          <span class="section-divider-label block mb-3">{l.basedIn}</span>
          <p class="content-prose">{l.location}</p>
        </div>
        <div>
          <span class="section-divider-label block mb-3">{l.socials}</span>
          <a href="https://instagram.com/rockswellnana" target="_blank" rel="noopener noreferrer" class="content-prose underline underline-offset-4 decoration-white/30 hover:decoration-white transition-all">
            @rockswellnana
          </a>
        </div>
        <div>
          <span class="section-divider-label block mb-3">{l.licenses}</span>
          <div class="flex flex-col gap-3">
            {siteCopy.licenses.map((license) => (
              <a
                href={license.href}
                target="_blank"
                rel="noopener noreferrer"
                class="content-prose underline underline-offset-4 decoration-white/30 hover:decoration-white transition-all"
              >
                {license.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="scroll-reveal">
        <form class="space-y-8" onsubmit="event.preventDefault(); alert('Sent (demo)');">
          <div>
            <span class="section-divider-label block mb-3">{l.nameLabel}</span>
            <input type="text" placeholder={l.namePlaceholder} class="w-full bg-transparent border-b border-white/25 focus:border-white/60 focus:outline-none font-body text-lg md:text-xl text-white/90 placeholder:text-white/25 py-2 transition-colors" />
          </div>
          <div>
            <span class="section-divider-label block mb-3">{l.emailLabel}</span>
            <input type="email" placeholder={l.emailPlaceholder} class="w-full bg-transparent border-b border-white/25 focus:border-white/60 focus:outline-none font-body text-lg md:text-xl text-white/90 placeholder:text-white/25 py-2 transition-colors" />
          </div>
          <div>
            <span class="section-divider-label block mb-3">{l.messageLabel}</span>
            <textarea rows="4" placeholder={l.messagePlaceholder} class="w-full bg-transparent border-b border-white/25 focus:border-white/60 focus:outline-none font-body text-lg md:text-xl text-white/90 placeholder:text-white/25 py-2 resize-none transition-colors"></textarea>
          </div>
          <div class="pt-2">
            <button type="submit" class="font-subheading text-sm uppercase tracking-[0.2em] text-white/90 hover:text-white border border-white/30 hover:border-white/60 px-8 py-3.5 transition-colors cursor-pointer bg-transparent">
              {l.sendMessage}
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
