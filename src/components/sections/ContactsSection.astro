---
import MagazineSectionHeader from '../MagazineSectionHeader.astro';
import { t, type LocaleKey } from '../../data/translations';
import { siteCopy } from '../../data/site-copy';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="contacts" class="scroll-section">
  <div class="mag-shell">
    <MagazineSectionHeader num="VII" eyebrow={l.contactTag} title={l.contactHeading} />

    <div class="mag-grid">
      <div class="mag-col-6 scroll-reveal space-y-8">
        <div>
          <span class="mag-section-header__eyebrow block mb-2">{l.email}</span>
          <a href="mailto:contact@annadauylrockswell.com" class="content-prose underline underline-offset-4 decoration-black/20 hover:decoration-[var(--accent-red)] transition-all">
            contact@annadauylrockswell.com
          </a>
          <a href="mailto:support@annadauylrockswell.com" class="content-prose block mt-2 underline underline-offset-4 decoration-black/20 hover:decoration-[var(--accent-red)] transition-all">
            support@annadauylrockswell.com
          </a>
        </div>
        <div>
          <span class="mag-section-header__eyebrow block mb-2">{l.basedIn}</span>
          <p class="content-prose text-ink-75">{l.location}</p>
        </div>
        <div>
          <span class="mag-section-header__eyebrow block mb-2">{l.socials}</span>
          <a href="https://instagram.com/rockswellnana" target="_blank" rel="noopener noreferrer" class="content-prose underline underline-offset-4 decoration-black/20 hover:decoration-[var(--accent-red)] transition-all">
            @rockswellnana
          </a>
        </div>
        <div>
          <span class="mag-section-header__eyebrow block mb-2">{l.licenses}</span>
          <div class="flex flex-col gap-2">
            {siteCopy.licenses.map((license) => (
              <a href={license.href} target="_blank" rel="noopener noreferrer" class="content-prose underline underline-offset-4 decoration-black/20 hover:decoration-[var(--accent-red)] transition-all">
                {license.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="mag-col-6 scroll-reveal">
        <form class="contacts-chaos__form space-y-6" onsubmit="event.preventDefault(); alert('Sent (demo)');">
          <div>
            <label class="mag-section-header__eyebrow block mb-2" for="contact-name">{l.nameLabel}</label>
            <input id="contact-name" type="text" placeholder={l.namePlaceholder} class="contacts-chaos__input" />
          </div>
          <div>
            <label class="mag-section-header__eyebrow block mb-2" for="contact-email">{l.emailLabel}</label>
            <input id="contact-email" type="email" placeholder={l.emailPlaceholder} class="contacts-chaos__input" />
          </div>
          <div>
            <label class="mag-section-header__eyebrow block mb-2" for="contact-message">{l.messageLabel}</label>
            <textarea id="contact-message" rows="5" placeholder={l.messagePlaceholder} class="contacts-chaos__input contacts-chaos__input--area resize-none"></textarea>
          </div>
          <button type="submit" class="mag-btn mag-btn--fill">{l.sendMessage}</button>
        </form>
      </div>
    </div>
  </div>
</section>
