---
import { t, type LocaleKey } from '../../data/translations';
import { researchPapers, grantsAndFellowships, residencies } from '../../data/content';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="research" class="scroll-section border-b border-neutral-900/20">
  <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20 max-w-4xl">
    <span class="scroll-reveal font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(ACADEMIC RESEARCH)</span>
    <h2 class="scroll-reveal font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-16">
      Academic<br />Research
    </h2>

    <div class="scroll-reveal mb-16">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-mono text-[9px] tracking-widest text-neutral-500">{l.academicPapers}</span>
        <div class="h-px flex-1 bg-black/10" />
      </div>
      <div class="space-y-4">
        {researchPapers.map((paper) => (
          <div class="border border-neutral-900/20 p-5 md:p-6 flex flex-col sm:flex-row justify-between items-start gap-3 sm:gap-4 rounded">
            <div>
              <h3 class="font-sans font-black tracking-tighter uppercase text-sm text-neutral-900">{paper.title}</h3>
              <span class="font-mono text-[10px] text-neutral-500 italic block mt-2">{paper.journal}</span>
            </div>
            <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500 flex-shrink-0">{paper.year}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="scroll-reveal mb-16">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-mono text-[9px] tracking-widest text-neutral-500">{l.grants}</span>
        <div class="h-px flex-1 bg-black/10" />
      </div>
      <div class="space-y-4">
        {grantsAndFellowships.map((grant) => (
          <div class="border border-neutral-900/20 p-5 md:p-6 flex flex-col sm:flex-row justify-between items-start gap-3 sm:gap-4 rounded">
            <div>
              <h3 class="font-sans font-black tracking-tighter uppercase text-sm text-neutral-900">{grant.title}</h3>
              <span class="font-mono text-[10px] text-neutral-500 italic block mt-2">{grant.description}</span>
            </div>
            <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500 flex-shrink-0">{grant.year}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="scroll-reveal">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-mono text-[9px] tracking-widest text-neutral-500">{l.residencies}</span>
        <div class="h-px flex-1 bg-black/10" />
      </div>
      <div class="space-y-4">
        {residencies.map((res) => (
          <div class="border border-neutral-900/20 p-5 md:p-6 flex flex-col sm:flex-row justify-between items-start gap-3 sm:gap-4 rounded">
            <div>
              <h3 class="font-sans font-black tracking-tighter uppercase text-sm text-neutral-900">{res.title}</h3>
              <span class="font-mono text-[10px] text-neutral-500 italic block mt-2">{res.location}</span>
            </div>
            <span class="font-mono text-[9px] border border-neutral-400 px-2 py-0.5 text-neutral-500 flex-shrink-0">{res.year}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
