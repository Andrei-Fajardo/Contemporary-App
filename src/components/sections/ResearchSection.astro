---
import ComingSoon from '../ComingSoon.astro';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="research" class="scroll-section border-b border-neutral-900/20">
  <div class="section-shell section-shell--wide py-12 md:py-20 lg:py-24">
    <ComingSoon
      label="(ACADEMIC RESEARCH)"
      heading="Academic Research"
      message={l.comingSoonMessage}
      note={l.comingSoonNote}
    />
  </div>
</section>
