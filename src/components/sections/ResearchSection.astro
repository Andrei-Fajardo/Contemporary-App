---
import ComingSoon from '../ComingSoon.astro';
import MagazineSectionHeader from '../MagazineSectionHeader.astro';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="research" class="scroll-section">
  <div class="mag-shell">
    <MagazineSectionHeader num="V" eyebrow={l.academicTag} title={l.academicHeading} />
    <ComingSoon message={l.comingSoonMessage} note={l.comingSoonNote} />
  </div>
</section>
