---
import EditorialLinkList from '../EditorialLinkList.astro';
import { t, type LocaleKey } from '../../data/translations';
import { pressLinks } from '../../data/content';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="press" class="scroll-section section-gap press-chaos utero-layered">
  <div class="section-shell section-shell--wide">
    <p class="scroll-reveal section-eyebrow section-eyebrow--blood">{l.pressTag}</p>
    <h2 class="scroll-reveal type-display text-3xl md:text-5xl lg:text-6xl text-ink mb-8">
      {l.nav.press}
    </h2>
    <p class="scroll-reveal content-prose text-ink-60 max-w-[58ch] mb-10">
      {l.pressIntro}
    </p>
    <EditorialLinkList items={pressLinks} emptyMessage={l.listForthcoming} />
  </div>
</section>
