---
import LazyImage from '../LazyImage.astro';
import { pressItems } from '../../data/content';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="press" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide">
    <p class="scroll-reveal section-eyebrow section-eyebrow--blood">{l.pressTag}</p>
    <h2 class="scroll-reveal font-forum text-4xl md:text-6xl lg:text-7xl leading-[0.95] text-ink mb-12 md:mb-16">
      {l.nav.press}
    </h2>

    <div class="editorial-divider-list space-y-0">
      {pressItems.map((item, i) => (
        <article class="scroll-reveal grid md:grid-cols-2 gap-10 lg:gap-16 xl:gap-20 items-center py-12 md:py-16 first:pt-0">
          <div class:list={["overflow-clip w-full max-w-md mx-auto md:mx-0 border border-subtle", i % 2 === 1 && "md:col-start-2"]}>
            <LazyImage
              src={item.image}
              alt={`${item.title} — ${item.venue}`}
              aspectRatio="3 / 4"
              parallaxSpeed={0}
              depthTarget={false}
              class="transition-[filter] duration-700 view-parallax-media"
            />
          </div>
          <div class:list={[i % 2 === 1 && "md:col-start-1 md:row-start-1"]}>
            <p class="section-eyebrow section-eyebrow--blood mb-4">{item.date}</p>
            <h3 class="font-forum text-2xl md:text-3xl text-ink mb-4">{item.title}</h3>
            <p class="content-prose text-ink-75 max-w-[58ch]">
              <span class="text-ink">{item.venue}</span>
              {item.place ? ` — ${item.place}` : ""}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
