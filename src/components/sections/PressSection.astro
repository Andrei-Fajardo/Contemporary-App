---
import LazyImage from '../LazyImage.astro';
import { pressItems } from '../../data/content';
import { t, type LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];

const pressImages: Record<string, string> = {
  'Astraea Zine': '/media/posters/poster-1.jpg',
  'Hush Magazine': '/media/posters/nana-nyc.jpg',
  'Spellbinder Magazine': '/media/posters/paris-poster.png',
  'Wildsape Literary Journal': '/media/the-fish.png',
  'Itaewon Film Festival': '/media/feature/itaewon-film-fest.jpg',
};

const pressGallery: Record<string, string[]> = {
  'Itaewon Film Festival': [
    '/media/feature/itaewon-film-fest.jpg',
    '/media/feature/itaewon-1.jpg',
    '/media/feature/itaewon-2.jpg',
    '/media/posters/itaewon-poster.png',
  ],
};
---

<section id="press" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide">
    <p class="scroll-reveal section-eyebrow">{l.pressTag}</p>
    <h2 class="scroll-reveal type-heading text-3xl md:text-5xl lg:text-6xl text-ink mb-12 md:mb-16">
      {l.nav.press}
    </h2>

    <div class="editorial-divider-list space-y-0">
      {pressItems.map((item, i) => (
        <div class="scroll-reveal grid md:grid-cols-2 gap-10 lg:gap-16 xl:gap-20 items-center py-12 md:py-16 first:pt-0">
          {pressImages[item.outlet] && (
            <div class={`overflow-clip w-full max-w-md mx-auto md:mx-0 border border-subtle ${i % 2 === 1 ? 'md:col-start-2' : ''}`}>
              {pressGallery[item.outlet] ? (
                <div class="grid grid-cols-2 gap-px bg-black/[0.06]">
                  {pressGallery[item.outlet].map((src) => (
                    <LazyImage
                      src={src}
                      alt={item.outlet}
                      aspectRatio="3 / 4"
                      parallaxSpeed={0}
                      depthTarget={false}
                      class="transition-[filter] duration-700 view-parallax-media"
                    />
                  ))}
                </div>
              ) : (
                <LazyImage
                  src={pressImages[item.outlet]}
                  alt={item.outlet}
                  aspectRatio="3 / 4"
                  parallaxSpeed={0}
                  depthTarget={false}
                  class="transition-[filter] duration-700 view-parallax-media"
                />
              )}
            </div>
          )}
          <div class={`${i % 2 === 1 ? 'md:col-start-1 md:row-start-1' : ''}`}>
            <p class="section-eyebrow mb-4">{item.outlet}</p>
            <p class="content-prose text-ink-75 max-w-[58ch]">
              {item.author}, &ldquo;{item.title},&rdquo; <em>{item.outlet}</em>, {item.date}.
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
