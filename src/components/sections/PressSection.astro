---
import LazyImage from '../LazyImage.astro';
import { pressItems } from '../../data/content';
import type { LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const {} = Astro.props;

const pressImages: Record<string, string> = {
  'Astraea Zine': '/media/posters/poster-1.jpg',
  'Hush Magazine': '/media/posters/nana-nyc.jpg',
  'Spellbinder Magazine': '/media/posters/paris-poster.png',
  'Wildsape Literary Journal': '/media/the-fish.png',
  'Itaewon Film Festival': '/media/feature/itaewon-film-fest.jpg',
};
---

<section id="press" class="scroll-section border-b border-neutral-900/20">
  <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20">
    <span class="scroll-reveal font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(PRESS)</span>
    <h2 class="scroll-reveal font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-16">
      Press
    </h2>

    <div class="space-y-16 max-w-5xl">
      {pressItems.map((item, i) => (
        <div class={`scroll-reveal flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-8 md:gap-12 items-center border-b border-black/10 pb-16 last:border-b-0`}>
          {pressImages[item.outlet] && (
            <div class="w-full md:w-[38%] overflow-clip">
              <LazyImage
                src={pressImages[item.outlet]}
                alt={item.outlet}
                aspectRatio="3 / 4"
                parallaxSpeed={0.15}
                depthTarget={false}
                class="grayscale hover:grayscale-0 transition-[filter] duration-700"
              />
            </div>
          )}
          <div class="w-full md:w-[55%]">
            <span class="font-mono text-[9px] tracking-widest text-neutral-400 uppercase block mb-3">{item.outlet}</span>
            <p class="font-serif text-base md:text-lg text-neutral-700 leading-relaxed">
              {item.author}, &ldquo;{item.title},&rdquo; <em>{item.outlet}</em>, {item.date}.
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
