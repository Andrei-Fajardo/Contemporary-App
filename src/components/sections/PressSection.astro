---
import LazyImage from '../LazyImage.astro';
import { pressItems } from '../../data/content';
import type { LocaleKey } from '../../data/translations';

interface Props {
  locale?: LocaleKey;
}

const {} = Astro.props;

const pressImages: Record<string, string> = {
  'Astraea Zine': '/media/posters/poster-1.jpg',
  'Hush Magazine': '/media/posters/nana-nyc.jpg',
  'Spellbinder Magazine': '/media/posters/paris-poster.png',
  'Wildsape Literary Journal': '/media/the-fish.png',
  'Itaewon Film Festival': '/media/feature/itaewon-film-fest.jpg',
};
---

<section id="press" class="scroll-section border-b border-neutral-900/20">
  <div class="section-shell section-shell--wide py-12 md:py-20 lg:py-24">
    <span class="scroll-reveal font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">(PRESS)</span>
    <h2 class="scroll-reveal font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-12 md:mb-16">
      Press
    </h2>

    <div class="space-y-14 md:space-y-20">
      {pressItems.map((item, i) => (
        <div class="scroll-reveal grid md:grid-cols-2 gap-8 lg:gap-14 xl:gap-20 items-center border-b border-black/10 pb-14 md:pb-20 last:border-b-0">
          {pressImages[item.outlet] && (
            <div class={`overflow-clip w-full max-w-lg mx-auto md:mx-0 ${i % 2 === 1 ? 'md:col-start-2' : ''}`}>
              <LazyImage
                src={pressImages[item.outlet]}
                alt={item.outlet}
                aspectRatio="3 / 4"
                parallaxSpeed={0.12}
                depthTarget={false}
                class="grayscale hover:grayscale-0 transition-[filter] duration-700"
              />
            </div>
          )}
          <div class={`${i % 2 === 1 ? 'md:col-start-1 md:row-start-1' : ''}`}>
            <span class="section-divider-label font-mono text-neutral-400 block mb-4">{item.outlet}</span>
            <p class="content-prose text-neutral-700">
              {item.author}, &ldquo;{item.title},&rdquo; <em>{item.outlet}</em>, {item.date}.
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
