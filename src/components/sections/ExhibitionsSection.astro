---
import ExhibitionAccordion from '../ExhibitionAccordion.astro';
import { t, type LocaleKey } from '../../data/translations';
import { exhibitionEntries } from '../../data/content';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="exhibitions" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide py-12 md:py-20 lg:py-24">
    <p class="scroll-reveal section-eyebrow">{l.exhibitionsTag}</p>
    <h2 class="scroll-reveal font-forum text-4xl md:text-6xl lg:text-7xl leading-[0.95] text-[#111] mb-4 md:mb-6" set:html={l.exhibitionHistory}></h2>
    <p class="scroll-reveal content-prose text-[#111]/60 max-w-[62ch] mb-10 md:mb-14">
      Chronological record of physical exhibitions — tap each entry to view posters and documentation.
    </p>

    <ExhibitionAccordion entries={exhibitionEntries} />
  </div>
</section>
