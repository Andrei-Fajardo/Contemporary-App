---
import { t, type LocaleKey } from '../../data/translations';
import { soloExhibitions, groupExhibitions } from '../../data/content';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
const routePrefix = locale === 'en' ? '' : `/${locale}`;

const exploreLinks = [
  { href: `${routePrefix}/gallery`, label: l.all, desc: "Full image archive" },
  { href: `${routePrefix}/feature`, label: l.featureFilter, desc: "Featured projects" },
  { href: `${routePrefix}/magazines`, label: l.magazinesTag.replace(/[()]/g, ''), desc: l.magazineHeading },
  { href: `${routePrefix}/virtual-exhibitions`, label: l.virtualFilter, desc: l.virtualHeading },
];
---

<section id="exhibitions" class="scroll-section border-b border-neutral-900/20">
  <div class="px-4 sm:px-6 md:px-8 py-12 md:py-20 max-w-4xl">
    <span class="scroll-reveal font-sans text-[10px] tracking-[0.3em] text-[#111111]/50 block mb-6">{l.exhibitionsTag}</span>
    <h2 class="scroll-reveal font-forum text-4xl md:text-6xl lg:text-8xl leading-[0.9] text-[#111111] mb-10 md:mb-16" set:html={l.exhibitionHistory}></h2>

    <!-- Optional deep-dive links (separate routes, not sticky nav) -->
    <div class="scroll-reveal exhibitions-explore mb-12 md:mb-16">
      <div class="flex items-center gap-4 mb-6">
        <span class="font-sans text-[9px] tracking-widest text-[#111111]/50 uppercase">{l.physical}</span>
        <div class="h-px flex-1 bg-black/10" />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {exploreLinks.map((link) => (
          <a
            href={link.href}
            class="group exhibitions-explore-link flex flex-col justify-between min-h-[88px] p-4 border border-black/10 rounded bg-white/30 hover:bg-white/60 hover:border-black/20 transition-all duration-400"
          >
            <span class="font-sans text-[10px] uppercase tracking-[0.2em] text-[#111111]/50">{link.desc}</span>
            <span class="font-mono text-xs uppercase tracking-widest text-[#111111] mt-3 flex items-center justify-between">
              {link.label}
              <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>

    <div class="scroll-reveal mb-16">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-sans text-[9px] tracking-widest text-[#111111]/50">{l.soloExhibitions}</span>
        <div class="h-px flex-1 bg-black/10" />
      </div>
      <div class="space-y-6">
        {soloExhibitions.map((ex) => (
          <div class="flex items-baseline gap-4 font-serif text-sm md:text-base text-[#111111]/70">
            <span class="font-mono text-[10px] tracking-wider text-[#111111]/40 shrink-0 w-14">{ex.year}</span>
            <span class="font-serif">—</span>
            <span>
              <em>{ex.title}</em>, {ex.venue}, {ex.city}{ex.city && ex.country ? ', ' : ''}{ex.country}
            </span>
          </div>
        ))}
      </div>
    </div>

    <div class="scroll-reveal">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-sans text-[9px] tracking-widest text-[#111111]/50">{l.groupExhibitions}</span>
        <div class="h-px flex-1 bg-black/10" />
      </div>
      <div class="space-y-6">
        {groupExhibitions.map((ex) => (
          <div class="flex items-baseline gap-4 font-serif text-sm md:text-base text-[#111111]/70">
            <span class="font-mono text-[10px] tracking-wider text-[#111111]/40 shrink-0 w-14">{ex.year}</span>
            <span class="font-serif">—</span>
            <span>
              <em>{ex.title}</em>, {ex.venue}{ex.venue && (ex.city || ex.country) ? ', ' : ''}{ex.city}{ex.city && ex.country ? ', ' : ''}{ex.country}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
