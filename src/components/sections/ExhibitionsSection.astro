---
import ExhibitionAccordion from '../ExhibitionAccordion.astro';
import ExhibitionGalleryOverlay from '../ExhibitionGalleryOverlay.astro';
import { t, type LocaleKey } from '../../data/translations';
import { exhibitionEntries } from '../../data/content';
import { sortExhibitionEntries } from '../../data/exhibition-display';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
const sortedExhibitions = sortExhibitionEntries(exhibitionEntries);

const filters = [
  { id: 'physical', label: l.physical },
  { id: 'digital', label: l.digitalFilter },
  { id: 'magazine', label: l.magazineFilter },
] as const;
---

<section id="exhibitions" class="scroll-section section-gap">
  <div class="section-shell section-shell--wide magazine-chapter" data-exhibition-filter-root>
    <span class="magazine-giant-type magazine-chapter__giant" aria-hidden="true">E</span>
    <p class="scroll-reveal section-eyebrow">{l.exhibitionsTag}</p>
    <h2 class="scroll-reveal magazine-chapter__title text-3xl md:text-5xl lg:text-6xl text-ink mb-3" set:html={l.exhibitionHistory}></h2>
    <hr class="magazine-rule-crimson magazine-rule-crimson--short scroll-reveal mb-4" />

    <p class="scroll-reveal content-prose text-ink-60 exhibitions-section__intro mb-2">
      {l.exhibitionsIntro}
    </p>

    <div class="exhibition-filters scroll-reveal" role="tablist" aria-label="Exhibition categories">
      {filters.map((filter, index) => (
        <button
          type="button"
          class:list={["exhibition-filter", index === 0 && "is-active"]}
          data-exhibition-filter={filter.id}
          role="tab"
          aria-selected={index === 0 ? "true" : "false"}
        >
          {filter.label}
        </button>
      ))}
    </div>

    <ExhibitionAccordion entries={sortedExhibitions} expandLabel={l.viewMore} />
  </div>
</section>

{/* Gallery overlay — rendered once, shown/hidden via JS */}
<ExhibitionGalleryOverlay />

<script>
  import { initExhibitionFilter } from "../../scripts/exhibition-filter";
  initExhibitionFilter();
  document.addEventListener("astro:page-load", initExhibitionFilter);
</script>
