---
import ExhibitionAccordion from '../ExhibitionAccordion.astro';
import MagazineSectionHeader from '../MagazineSectionHeader.astro';
import { t, type LocaleKey } from '../../data/translations';
import { exhibitionEntries } from '../../data/content';

interface Props {
  locale?: LocaleKey;
}

const { locale = 'en' } = Astro.props;
const l = t[locale];
---

<section id="exhibitions" class="scroll-section">
  <div class="mag-shell">
    <MagazineSectionHeader num="III" eyebrow={l.exhibitionsTag} title={l.exhibitionHistory} />
    <ExhibitionAccordion entries={exhibitionEntries} expandLabel={l.seeMore} />
  </div>
</section>
