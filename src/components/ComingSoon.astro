---
export interface Props {
  message: string;
  note?: string;
}

const { message, note } = Astro.props;
---

<div class="scroll-reveal" style="padding-block: clamp(2rem, 5vw, 3rem); max-width: 42ch;">
  <p style="font-family: var(--font-editorial); font-style: italic; font-size: 1.0625rem; line-height: 1.6; color: var(--ink-55); margin: 0;">
    {message}
  </p>
  {note && (
    <p class="mag-section-header__eyebrow" style="margin-top: 1rem;">{note}</p>
  )}
</div>
