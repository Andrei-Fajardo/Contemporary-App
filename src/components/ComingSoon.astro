---
export interface Props {
  label: string;
  heading: string;
  message: string;
  note?: string;
}

const { label, heading, message, note } = Astro.props;
---

<div class="min-h-[40vh] flex flex-col justify-center">
  <span class="scroll-reveal font-mono text-[10px] tracking-[0.3em] text-neutral-500 block mb-6">{label}</span>
  <h2 class="scroll-reveal font-sans font-black tracking-tighter uppercase text-4xl md:text-6xl lg:text-[8rem] leading-[0.85] text-neutral-900 mb-12 md:mb-16">
    {heading}
  </h2>
  <div class="scroll-reveal border border-neutral-900/20 rounded p-10 md:p-14 lg:p-16 max-w-3xl">
    <p class="content-prose italic text-neutral-700">{message}</p>
    {note && (
      <p class="section-divider-label font-mono text-neutral-400 mt-6">{note}</p>
    )}
  </div>
</div>
