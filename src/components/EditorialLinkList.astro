---
import type { LinkItem } from '../data/content';

interface Props {
  items: LinkItem[];
  emptyMessage?: string;
}

const { items, emptyMessage = 'List forthcoming' } = Astro.props;
---

{items.length > 0 ? (
  <ul class="editorial-link-list editorial-row-list scroll-reveal">
    {items.map((item) => (
      <li class="editorial-row-list__item">
        <span class="editorial-row-list__year">{item.year ?? ''}</span>
        <a href={item.href} target="_blank" rel="noopener noreferrer" class="editorial-row-list__title">
          {item.title}
        </a>
      </li>
    ))}
  </ul>
) : (
  <p class="scroll-reveal content-prose text-ink-55">{emptyMessage}</p>
)}
